{
  "id": "a1ed9877-8e0c-563f-b076-1969b4cf611b",
  "catalog": "elastic",
  "name": "Potential File Download via a Headless Browser",
  "description": "",
  "severity": "critical",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "chrome.exe",
        "msedge.exe",
        "brave.exe",
        "browser.exe",
        "dragon.exe",
        "vivaldi.exe"
      ],
      "raw_values": [
        "chrome.exe",
        "msedge.exe",
        "brave.exe",
        "browser.exe",
        "dragon.exe",
        "vivaldi.exe",
        "?:\\\\inetpub\\\\wwwroot\\\\*\\\\ext\\\\modules\\\\html2pdf\\\\bin\\\\chrome\\\\*\\\\chrome-win64\\\\chrome.exe",
        "\\\\Device\\\\HarddiskVolume*\\\\inetpub\\\\wwwroot\\\\*\\\\ext\\\\modules\\\\html2pdf\\\\bin\\\\chrome\\\\*\\\\chrome-win64\\\\chrome.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "--dump-dom",
        "http",
        "html;base64,",
        "--headless"
      ],
      "raw_values": [
        "--dump-dom",
        "*http*",
        "data:text/html;base64,*",
        "--headless*"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": ":",
      "values": [
        "cmd.exe",
        "powershell.exe",
        "wscript.exe",
        "cscript.exe",
        "mshta.exe",
        "conhost.exe",
        "msiexec.exe",
        "explorer.exe",
        "rundll32.exe",
        "winword.exe",
        "excel.exe",
        "onenote.exe",
        "hh.exe",
        "powerpnt.exe",
        "forfiles.exe",
        "pcalua.exe",
        "wmiprvse.exe"
      ],
      "raw_values": [
        "cmd.exe",
        "powershell.exe",
        "wscript.exe",
        "cscript.exe",
        "mshta.exe",
        "conhost.exe",
        "msiexec.exe",
        "explorer.exe",
        "rundll32.exe",
        "winword.exe",

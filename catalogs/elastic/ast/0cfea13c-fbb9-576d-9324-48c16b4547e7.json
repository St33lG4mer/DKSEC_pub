{
  "id": "0cfea13c-fbb9-576d-9324-48c16b4547e7",
  "catalog": "elastic",
  "name": "Unusual Child Process from a System Virtual Process",
  "description": "",
  "severity": "critical",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "registry",
        "memcompression",
        "smss.exe",
        "hotpatch"
      ],
      "raw_values": [
        "Registry",
        "MemCompression",
        "?:\\\\Windows\\\\System32\\\\smss.exe",
        "HotPatch",
        "?*"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n  process.parent.pid == 4 and process.executable : \"?*\" and\n  not process.executable : (\"Registry\", \"MemCompression\", \"?:\\\\Windows\\\\System32\\\\smss.exe\", \"HotPatch\")\n",
  "language": "eql",
  "translated_query": null,

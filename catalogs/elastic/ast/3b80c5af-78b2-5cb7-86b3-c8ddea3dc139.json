{
  "id": "3b80c5af-78b2-5cb7-86b3-c8ddea3dc139",
  "catalog": "elastic",
  "name": "Potential Remote Install via MsiExec",
  "description": "",
  "severity": "critical",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "-qn",
        "quiet",
        "--set-server=",
        "upgradeadd=",
        "--url=",
        "useserverconfig=",
        "rctenterpriseserver=",
        "app.ninjarmm.com",
        "client",
        "supportserverstsuri=",
        "start_url=",
        "autoconfig=",
        "awscli.amazonaws.com",
        "http"
      ],
      "raw_values": [
        "-i*",
        "/i*",
        "-p*",
        "/p*",
        "/qn",
        "-qn",
        "-q",
        "/q",
        "/quiet",
        "*--set-server=*",
        "*UPGRADEADD=*",
        "*--url=*",
        "*USESERVERCONFIG=*",
        "*RCTENTERPRISESERVER=*",
        "*app.ninjarmm.com*",
        "*zoom.us/client*",
        "*SUPPORTSERVERSTSURI=*",
        "*START_URL=*",
        "*AUTOCONFIG=*",
        "*awscli.amazonaws.com*",
        "*http*"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": ":",
      "values": [
        "sihost.exe",
        "explorer.exe",
        "cmd.exe",
        "wscript.exe",
        "mshta.exe",
        "powershell.exe",
        "wmiprvse.exe",
        "pcalua.exe",
        "forfiles.exe",
        "conhost.exe"
      ],
      "raw_values": [
        "sihost.exe",
        "explorer.exe",
        "cmd.exe",
        "wscript.exe",
        "mshta.exe",
        "powershell.exe",
        "wmiprvse.exe",
        "pcalua.exe",
        "forfiles.exe",
        "conhost.exe"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "msiexec.exe"
      ],
      "raw_values": [
        "msiexec.exe"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n  process.name : \"msiexec.exe\" and process.args : (\"-i*\", \"/i*\", \"-p*\", \"/p*\") and process.command_line : \"*http*\" and\n  process.args : (\"/qn\", \"-qn\", \"-q\", \"/q\", \"/quiet\") and\n  process.parent.name : (\"sihost.exe\", \"explorer.exe\", \"cmd.exe\", \"wscript.exe\", \"mshta.exe\", \"powershell.exe\", \"wmiprvse.exe\", \"pcalua.exe\", \"forfiles.exe\", \"conhost.exe\") and\n  not process.command_line : (\"*--set-server=*\", \"*UPGRADEADD=*\" , \"*--url=*\",\n                              \"*USESERVERCONFIG=*\", \"*RCTENTERPRISESERVER=*\", \"*app.ninjarmm.com*\", \"*zoom.us/client*\",\n                              \"*SUPPORTSERVERSTSURI=*\", \"*START_URL=*\", \"*AUTOCONFIG=*\", \"*awscli.amazonaws.com*\")\n",
  "language": "eql",
  "translated_query": null,
  "source_path": "rules/windows/defense_evasion_msiexec_remote_payload.toml",
  "metadata": {
    "risk_score": 73,

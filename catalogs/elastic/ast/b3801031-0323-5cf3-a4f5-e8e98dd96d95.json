        "regsvr32.exe",
        "iexplore.exe"
      ]
    },
    {
      "field": "dns.question.name",
      "raw_field": "dns.question.name",
      "operator": ":",
      "values": [
        ".microsoft.com",
        ".digicert.com",
        ".msocsp.com",
        ".windowsupdate.com",
        ".bing.com",
        ".identrust.com",
        ".sharepoint.com",

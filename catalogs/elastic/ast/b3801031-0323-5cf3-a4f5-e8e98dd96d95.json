        ".office.com"
      ],
      "raw_values": [
        "*.microsoft.com",
        "*.digicert.com",
        "*.msocsp.com",
        "*.windowsupdate.com",
        "*.bing.com",
        "*.identrust.com",
        "*.sharepoint.com",
        "*.office365.com",
        "*.office.com"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "dll.name",

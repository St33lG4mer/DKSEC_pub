{
  "id": "3614dc04-a675-5be8-870f-8fa92fc6d1ff",
  "catalog": "elastic",
  "name": "MFA Deactivation with no Re-Activation for Okta User Account",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [],
  "event_categories": [
    "any"
  ],
  "conditions": [
    {
      "field": "okta.event_type",
      "raw_field": "okta.event_type",
      "operator": "in",
      "values": [
        "user.mfa.factor.deactivate",
        "user.mfa.factor.reset_all"
      ],
      "raw_values": [
        "user.mfa.factor.deactivate",
        "user.mfa.factor.reset_all"
      ]
    },
    {
      "field": "data_stream.dataset",
      "raw_field": "data_stream.dataset",
      "operator": "==",
      "values": [
        "okta.system"
      ],
      "raw_values": [
        "okta.system"
      ]
    },
    {
      "field": "okta.outcome.reason",
      "raw_field": "okta.outcome.reason",
      "operator": "!=",
      "values": [
        "user reset security_question factor"
      ],
      "raw_values": [
        "User reset SECURITY_QUESTION factor"
      ]
    },
    {
      "field": "okta.outcome.result",
      "raw_field": "okta.outcome.result",
      "operator": "==",
      "values": [
        "success"
      ],
      "raw_values": [
        "SUCCESS"
      ]
    },
    {
      "field": "okta.event_type",
      "raw_field": "okta.event_type",
      "operator": "==",
      "values": [
        "user.mfa.factor.activate"
      ],
      "raw_values": [
        "user.mfa.factor.activate"
      ]

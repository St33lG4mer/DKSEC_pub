      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "==",
      "values": [
        "find"
      ],
      "raw_values": [
        "find"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": "==",
      "values": [
        "uninstall_viewagent.sh"
      ],
      "raw_values": [

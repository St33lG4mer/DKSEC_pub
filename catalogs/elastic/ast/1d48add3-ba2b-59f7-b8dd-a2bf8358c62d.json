    "any"
  ],
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\software\\\\policies\\\\microsoft\\\\windows nt\\\\terminal services\\\\shadow"
      ],
      "raw_values": [
        "*\\\\Software\\\\Policies\\\\Microsoft\\\\Windows NT\\\\Terminal Services\\\\Shadow"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "registry.data.strings",
      "operator": ":",
      "values": [
        "0x00000001",
        "0x00000002",
        "0x00000003",
        "0x00000004"
      ],
      "raw_values": [
        "1",
        "0x00000001",
        "2",
        "0x00000002",
        "3",
        "0x00000003",
        "4",
        "0x00000004"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "rdpsauachelper.exe",
        "rdpsaproxy.exe"
      ],
      "raw_values": [
        "RdpSaUacHelper.exe",
        "RdpSaProxy.exe"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.category",
      "raw_field": "event.category",
      "operator": "==",
      "values": [
        "registry",
        "process"
      ],
      "raw_values": [
        "registry",
        "process"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "change",
        "start"
      ],
      "raw_values": [
        "change",
        "start"
      ]
    },
    {
      "field": "registry.value",
      "raw_field": "registry.value",
      "operator": ":",
      "values": [
        "shadow"
      ],
      "raw_values": [

{
  "id": "487c88e5-7064-5054-9756-5e95a468bbba",
  "catalog": "elastic",
  "name": "Renamed Utility Executed with Short Program Name",
  "description": "",
  "severity": "high",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and \n process.name regex~ \"\"\"[a-z0-9]\\.exe\"\"\" and process.pe.original_file_name != null\n",
  "language": "eql",
  "translated_query": null,
  "source_path": "rules/windows/defense_evasion_suspicious_short_program_name.toml",

        "wsmprovhost.exe",
        "w3wp.exe",
        "wmiprvse.exe",
        "rundll32.exe",
        "regsvr32.exe",
        "cmd.exe",
        "C:\\\\Windows\\\\system32\\\\inetsrv\\\\appcmd.exe"

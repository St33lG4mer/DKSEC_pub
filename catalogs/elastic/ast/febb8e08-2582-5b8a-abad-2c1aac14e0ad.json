      ]
    },
    {
      "field": "process.parent.args",
      "raw_field": "process.parent.args",
      "operator": ":",
      "values": [
        "chcp 437>nul 2>&1 & c:\\\\windows\\\\system32\\\\whoami.exe  /groups",
        "chcp 437>nul 2>&1 & %systemroot%\\\\system32\\\\whoami /user",

{
  "id": "7ae3a3a3-9826-5bb9-adcb-ca4d8df78cc2",
  "catalog": "elastic",
  "name": "Suspicious Command Prompt Network Connection",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [],
  "event_categories": [
    "any"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        ".bat",
        ".cmd"
      ],
      "raw_values": [
        "/c",
        "/k",
        "*.bat",
        "*.cmd",
        "*http://*",
        "*https://*",
        "*ftp://*"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": ":",
      "values": [
        "excel.exe",
        "msaccess.exe",
        "mspub.exe",
        "powerpnt.exe",
        "winword.exe",
        "outlook.exe"
      ],
      "raw_values": [
        "excel.exe",
        "msaccess.exe",
        "mspub.exe",
        "powerpnt.exe",
        "winword.exe",
        "outlook.exe"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "cmd.exe"
      ],
      "raw_values": [
        "cmd.exe"
      ]
    }
  ],
  "raw_query": "sequence by process.entity_id with maxspan=15s\n  [process where host.os.type == \"windows\" and event.type == \"start\" and\n    process.name : \"cmd.exe\" and process.args : (\"/c\", \"/k\") and\n    (\n      process.args : (\"*.bat\", \"*.cmd\") or\n      process.command_line : (\"*http://*\", \"*https://*\", \"*ftp://*\") or\n      process.parent.name : (\"excel.exe\", \"msaccess.exe\", \"mspub.exe\", \"powerpnt.exe\", \"winword.exe\", \"outlook.exe\")\n    )\n  ]\n  [network where host.os.type == \"windows\" and process.name : \"cmd.exe\" and\n     not cidrmatch(destination.ip, \"10.0.0.0/8\", \"127.0.0.0/8\", \"169.254.0.0/16\", \"172.16.0.0/12\", \"192.0.0.0/24\",\n                                  \"192.0.0.0/29\", \"192.0.0.8/32\", \"192.0.0.9/32\", \"192.0.0.10/32\", \"192.0.0.170/32\",\n                                  \"192.0.0.171/32\", \"192.0.2.0/24\", \"192.31.196.0/24\", \"192.52.193.0/24\",\n                                  \"192.168.0.0/16\", \"192.88.99.0/24\", \"224.0.0.0/4\", \"100.64.0.0/10\", \"192.175.48.0/24\",\n                                  \"198.18.0.0/15\", \"198.51.100.0/24\", \"203.0.113.0/24\", \"240.0.0.0/4\", \"::1\",\n                                  \"FE80::/10\", \"FF00::/8\")]\n",
  "language": "eql",
  "translated_query": null,
  "source_path": "rules/windows/execution_command_prompt_connecting_to_the_internet.toml",
  "metadata": {
    "risk_score": 21,
    "tags": [
      "Domain: Endpoint",
      "OS: Windows",
      "Use Case: Threat Detection",
      "Tactic: Execution",
      "Resources: Investigation Guide",
      "Data Source: Elastic Defend",
      "Data Source: Sysmon",
      "Data Source: SentinelOne"
    ]
  }
}
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "net.exe",
        "net1.exe",
        "wmic.exe"
      ],
      "raw_values": [
        "net.exe",
        "net1.exe",
        "wmic.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": "==",
      "values": [
        "net.exe",
        "net1.exe",
        "wmic.exe"
      ],
      "raw_values": [
        "net.exe",
        "net1.exe",
        "wmic.exe"

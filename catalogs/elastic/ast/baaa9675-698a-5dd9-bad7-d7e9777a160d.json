{
  "id": "baaa9675-698a-5dd9-bad7-d7e9777a160d",
  "catalog": "elastic",
  "name": "NTDS or SAM Database File Copied",
  "description": "",
  "severity": "critical",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "cmd.exe",
        "powershell.exe",
        "xcopy.exe",
        "esentutl.exe"
      ],
      "raw_values": [
        "Cmd.Exe",
        "PowerShell.EXE",
        "XCOPY.EXE",
        "esentutl.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "copy",
        "xcopy",
        "copy-item",
        "move",
        "vss",
        "ntds.dit",
        "sam"
      ],
      "raw_values": [
        "copy",
        "xcopy",
        "Copy-Item",
        "move",
        "cp",
        "mv",
        "*/y*",
        "*/vss*",
        "*/d*",
        "*\\\\ntds.dit*",
        "*\\\\config\\\\SAM*",
        "*\\\\*\\\\GLOBALROOT\\\\Device\\\\HarddiskVolumeShadowCopy*\\\\*",
        "*/system32/config/SAM*",
        "*\\\\User Data\\\\*"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": "in",
      "values": [
        "cmd.exe",
        "powershell.exe",
        "xcopy.exe"
      ],
      "raw_values": [
        "Cmd.Exe",
        "PowerShell.EXE",
        "XCOPY.EXE"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "esentutl.exe"
      ],
      "raw_values": [
        "esentutl.exe"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n  (\n    ((?process.pe.original_file_name in (\"Cmd.Exe\", \"PowerShell.EXE\", \"XCOPY.EXE\") or process.name : (\"Cmd.Exe\", \"PowerShell.EXE\", \"XCOPY.EXE\")) and\n       process.args : (\"copy\", \"xcopy\", \"Copy-Item\", \"move\", \"cp\", \"mv\")\n    ) or\n    ((?process.pe.original_file_name : \"esentutl.exe\" or process.name : \"esentutl.exe\") and process.args : (\"*/y*\", \"*/vss*\", \"*/d*\"))\n  ) and\n  process.command_line : (\"*\\\\ntds.dit*\", \"*\\\\config\\\\SAM*\", \"*\\\\*\\\\GLOBALROOT\\\\Device\\\\HarddiskVolumeShadowCopy*\\\\*\", \"*/system32/config/SAM*\", \"*\\\\User Data\\\\*\")\n",
  "language": "eql",
  "translated_query": null,
  "source_path": "rules/windows/credential_access_copy_ntds_sam_volshadowcp_cmdline.toml",

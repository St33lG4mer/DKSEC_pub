{
  "id": "2eadec54-4207-53b3-9c84-2d607daffeed",
  "catalog": "elastic",
  "name": "Potential Privacy Control Bypass via TCCDB Modification",
  "description": "",
  "severity": "high",
  "mitre_techniques": [
    "attack.defense-evasion"
  ],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": "like~",
      "values": [
        "osascript",
        "bash",
        "zsh",
        "terminal",
        "python"
      ],
      "raw_values": [
        "osascript",
        "bash",
        "sh",
        "zsh",
        "Terminal",
        "Python*"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "in",
      "values": [
        "start",
        "process_started"
      ],
      "raw_values": [
        "start",
        "process_started"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "macos"
      ],
      "raw_values": [
        "macos"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "==",
      "values": [
        "sqlite"
      ],
      "raw_values": [
        "sqlite*"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": "like",
      "values": [
        "tcc.db"
      ],
      "raw_values": [
        "/*/Application Support/com.apple.TCC/TCC.db"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"macos\" and event.type in (\"start\", \"process_started\") and process.name == \"sqlite*\" and\n process.args like \"/*/Application Support/com.apple.TCC/TCC.db\" and\n (process.parent.name like~ (\"osascript\", \"bash\", \"sh\", \"zsh\", \"Terminal\", \"Python*\") or (process.parent.code_signature.exists == false or process.parent.code_signature.trusted == false))\n",
  "language": "eql",
  "translated_query": null,
  "source_path": "rules/macos/defense_evasion_privacy_controls_tcc_database_modification.toml",

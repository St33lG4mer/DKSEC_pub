{
  "id": "b0993a45-2889-5137-928f-06593dfafe08",
  "catalog": "elastic",
  "name": "Simple HTTP Web Server Creation",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "in",
      "values": [
        "exec",
        "exec_event",
        "start",
        "processrollup2"
      ],
      "raw_values": [
        "exec",
        "exec_event",
        "start",
        "ProcessRollup2"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": "in",
      "values": [
        "--cgi",
        "cgihttpserver"
      ],
      "raw_values": [
        "--cgi",
        "CGIHTTPServer"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": "in",
      "values": [
        "check_kmp_wrapper",
        "naemon",
        "runc"
      ],
      "raw_values": [
        "check_kmp_wrapper",
        "naemon",
        "runc"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "linux"
      ],
      "raw_values": [
        "linux"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "like",
      "values": [
        "python"
      ],
      "raw_values": [
        "python*"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"linux\" and event.type == \"start\" and\nevent.action in (\"exec\", \"exec_event\", \"start\", \"ProcessRollup2\") and\n(\n  (process.name regex~ \"\"\"php?[0-9]?\\.?[0-9]{0,2}\"\"\" and process.args == \"-S\") or\n  (process.name like \"python*\" and process.args in (\"--cgi\", \"CGIHTTPServer\"))\n) and\nnot process.parent.name in (\"check_kmp_wrapper\", \"naemon\", \"runc\")\n",
  "language": "eql",
  "translated_query": null,
  "source_path": "rules/linux/persistence_simple_web_server_creation.toml",

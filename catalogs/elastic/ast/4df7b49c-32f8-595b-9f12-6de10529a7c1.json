{
  "id": "4df7b49c-32f8-595b-9f12-6de10529a7c1",
  "catalog": "elastic",
  "name": "Suspicious Microsoft HTML Application Child Process",
  "description": "",
  "severity": "critical",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "cmd.exe",
        "powershell.exe",
        "certutil.exe",
        "bitsadmin.exe",
        "curl.exe",
        "msiexec.exe",
        "schtasks.exe",
        "reg.exe",
        "wscript.exe",
        "rundll32.exe",
        ".exe"
      ],
      "raw_values": [
        "cmd.exe",
        "powershell.exe",
        "certutil.exe",
        "bitsadmin.exe",
        "curl.exe",
        "msiexec.exe",
        "schtasks.exe",
        "reg.exe",
        "wscript.exe",
        "rundll32.exe",
        "C:\\\\Users\\\\*\\\\*.exe",
        "\\\\Device\\\\HarddiskVolume*\\\\Users\\\\*\\\\*.exe"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": ":",
      "values": [
        "mshta.exe"
      ],
      "raw_values": [
        "mshta.exe"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n process.parent.name : \"mshta.exe\" and\n (\n  process.name : (\"cmd.exe\", \"powershell.exe\", \"certutil.exe\", \"bitsadmin.exe\", \"curl.exe\", \"msiexec.exe\", \"schtasks.exe\", \"reg.exe\", \"wscript.exe\", \"rundll32.exe\") or\n  process.executable : (\"C:\\\\Users\\\\*\\\\*.exe\", \"\\\\Device\\\\HarddiskVolume*\\\\Users\\\\*\\\\*.exe\")\n  )\n",
  "language": "eql",
  "translated_query": null,
  "source_path": "rules/windows/defense_evasion_mshta_susp_child.toml",

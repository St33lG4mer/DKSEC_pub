{
  "id": "3afcc0e4-a78a-5370-87cb-7fb145762d30",
  "catalog": "elastic",
  "name": "Keychain CommandLine Interaction via Unsigned or Untrusted Process",
  "description": "",
  "severity": "critical",
  "mitre_techniques": [
    "attack.credential-access"
  ],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "login.keychain-db",
        "login.keychain"
      ],
      "raw_values": [
        "/Users/*/Library/Keychains/*",
        "/Library/Keychains/*",
        "login.keychain-db",
        "login.keychain"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "in",
      "values": [
        "start",
        "process_started"
      ],
      "raw_values": [
        "start",
        "process_started"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "in",
      "values": [
        "bash",
        "zsh",
        "osascript",
        "cat",
        "echo"
      ],
      "raw_values": [
        "bash",
        "sh",
        "zsh",
        "osascript",
        "cat",
        "echo",
        "cp"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "macos"
      ],
      "raw_values": [
        "macos"
      ]
    },
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "==",
      "values": [
        "exec"
      ],
      "raw_values": [
        "exec"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"macos\" and event.type in (\"start\", \"process_started\") and event.action == \"exec\" and\n  process.args like (\"/Users/*/Library/Keychains/*\", \"/Library/Keychains/*\", \"login.keychain-db\", \"login.keychain\") and \n  ((process.code_signature.trusted == false or process.code_signature.exists == false) or \n   (process.name in (\"bash\", \"sh\", \"zsh\", \"osascript\", \"cat\", \"echo\", \"cp\") and \n   (process.parent.code_signature.trusted == false or process.parent.code_signature.exists == false)))\n",
  "language": "eql",
  "translated_query": null,
  "source_path": "rules/macos/credential_access_credentials_keychains.toml",
  "metadata": {
    "risk_score": 73,
    "tags": [
      "Domain: Endpoint",
      "OS: macOS",
      "Use Case: Threat Detection",
      "Tactic: Credential Access",
      "Data Source: Elastic Defend",
      "Resources: Investigation Guide"
    ]
  }
}
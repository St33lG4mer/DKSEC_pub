  ],
  "event_categories": [
    "any"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "pid"
      ],
      "raw_values": [
        "/PID",
        "/IM",
        "/T",
        "/F",
        "/t",
        "/f",
        "/im",
        "/pid"
      ]
    }
  ],
  "raw_query": "event.category:process and host.os.type:windows and event.type:start and process.name:(net.exe or sc.exe or taskkill.exe) and\n process.args:(stop or pause or delete or \"/PID\" or \"/IM\" or \"/T\" or \"/F\" or \"/t\" or \"/f\" or \"/im\" or \"/pid\") and\n not process.parent.name:(osquerybeat.exe or agentbeat.exe)\n",
  "language": "kuery",

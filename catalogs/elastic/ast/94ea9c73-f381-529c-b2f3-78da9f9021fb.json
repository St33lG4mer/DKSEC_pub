  "raw_query": "data_stream.dataset: \"aws.cloudtrail\"\n    and event.provider: \"iam.amazonaws.com\"\n    and event.action: (\n        \"CreateAccessKey\" or\n        \"CreateUser\" or\n        \"AttachUserPolicy\" or\n        \"PutUserPolicy\" or\n        \"CreateRole\" or\n        \"AttachRolePolicy\" or\n        \"PutRolePolicy\" or\n        \"CreateInstanceProfile\" or\n        \"AddRoleToInstanceProfile\"\n    )\n    and event.outcome: \"success\"\n    and user_agent.original: *CloudShell*\n",
  "language": "kuery",
  "translated_query": null,

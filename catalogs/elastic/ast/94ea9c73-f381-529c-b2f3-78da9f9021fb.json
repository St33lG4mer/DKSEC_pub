        "createaccesskey",
        "createuser",
        "attachuserpolicy",
        "putuserpolicy",
        "createrole",
        "attachrolepolicy",
        "putrolepolicy",
        "createinstanceprofile",
        "addroletoinstanceprofile"
      ],
      "raw_values": [
        "CreateAccessKey",
        "CreateUser",
        "AttachUserPolicy",
        "PutUserPolicy",
        "CreateRole",
        "AttachRolePolicy",
        "PutRolePolicy",
        "CreateInstanceProfile",
        "AddRoleToInstanceProfile"
      ]
    },
    {
      "field": "data_stream.dataset",
      "raw_field": "data_stream.dataset",
      "operator": ":",
      "values": [
        "aws.cloudtrail"
      ],
      "raw_values": [
        "aws.cloudtrail"
      ]
    },
    {
      "field": "event.provider",
      "raw_field": "event.provider",
      "operator": ":",
      "values": [
        "iam.amazonaws.com"
      ],
      "raw_values": [

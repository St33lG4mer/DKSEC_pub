{
  "id": "8ad9b935-a20b-57ba-872f-9d2fa836b1a0",
  "catalog": "elastic",
  "name": "Volume Shadow Copy Deleted or Resized via VssAdmin",
  "description": "",
  "severity": "critical",
  "mitre_techniques": [
    "attack.impact"
  ],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "delete",
        "resize",
        "shadows"
      ],
      "raw_values": [
        "delete",
        "resize",
        "shadows*"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "vssadmin.exe"
      ],
      "raw_values": [
        "vssadmin.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": "==",
      "values": [
        "vssadmin.exe"
      ],
      "raw_values": [
        "VSSADMIN.EXE"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n  (process.name : \"vssadmin.exe\" or ?process.pe.original_file_name == \"VSSADMIN.EXE\") and\n  process.args : (\"delete\", \"resize\") and process.args : \"shadows*\"\n",
  "language": "eql",
  "translated_query": null,

    "process"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "-wa",
        "-ga",
        "chrome",
        "chromium",
        "opera",
        "safari",
        "brave",
        "microsoft edge",
        "firefox"
      ],
      "raw_values": [
        "-wa",
        "-ga",
        "*Chrome*",
        "*Chromium*",
        "*Opera*",
        "*Safari*",
        "*Brave*",
        "*Microsoft Edge*",
        "*Firefox*"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": "like~",
      "values": [
        "find-generic-password",
        "find-internet-password"
      ],
      "raw_values": [
        "find-generic-password",
        "find-internet-password"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "macos"
      ],
      "raw_values": [
        "macos"
      ]
    },
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "==",
      "values": [
        "exec"
      ],
      "raw_values": [
        "exec"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "==",
      "values": [
        "security"
      ],
      "raw_values": [
        "security"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": "like",
      "values": [
        "keeper password manager helper"
      ],
      "raw_values": [
        "/Applications/Keeper Password Manager.app/Contents/Frameworks/Keeper Password Manager Helper*/Contents/MacOS/Keeper Password Manager Helper*"
      ]
    }

{
  "id": "bdcd7ba7-c66c-5580-ac21-fc97b1818acd",
  "catalog": "elastic",
  "name": "File Deletion via Shred",
  "description": "",
  "severity": "high",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "in",
      "values": [
        "exec",
        "exec_event",
        "start",
        "processrollup2",
        "executed",
        "process_started"
      ],
      "raw_values": [
        "exec",
        "exec_event",
        "start",
        "ProcessRollup2",
        "executed",
        "process_started"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": "in",
      "values": [
        "--remove",
        "--zero"
      ],
      "raw_values": [
        "--remove",
        "--zero"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "linux"
      ],
      "raw_values": [
        "linux"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "==",
      "values": [
        "shred"
      ],
      "raw_values": [
        "shred"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": "==",
      "values": [
        "logrotate"
      ],
      "raw_values": [
        "logrotate"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"linux\" and event.type == \"start\" and event.action in (\"exec\", \"exec_event\", \"start\", \"ProcessRollup2\", \"executed\", \"process_started\") and\nprocess.name == \"shred\" and (\n// Any short-flag cluster containing at least one of u/z, and containing no extra \"-\" after the first one\nprocess.args regex~ \"-[^-]*[uz][^-]*\" or\nprocess.args in (\"--remove\", \"--zero\")\n) and\nnot process.parent.name == \"logrotate\"\n",
  "language": "eql",
  "translated_query": null,
  "source_path": "rules/linux/defense_evasion_file_deletion_via_shred.toml",

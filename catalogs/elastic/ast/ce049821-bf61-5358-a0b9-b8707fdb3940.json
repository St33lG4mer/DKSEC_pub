{
  "id": "ce049821-bf61-5358-a0b9-b8707fdb3940",
  "catalog": "elastic",
  "name": "Adding Hidden File Attribute via Attrib",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [
    "attack.defense-evasion",
    "attack.persistence"
  ],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "drawio.bkp",
        "drawio.dtmp",
        "attrib  +r +h +s +a *.cui"
      ],
      "raw_values": [
        "*drawio.bkp*",
        "*drawio.dtmp*",
        "+h",
        "attrib  +R +H +S +A *.cui"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "attrib.exe"
      ],
      "raw_values": [
        "attrib.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": "==",
      "values": [
        "attrib.exe"
      ],
      "raw_values": [
        "ATTRIB.EXE"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": ":",
      "values": [
        "cmd.exe",
        "draw.io.exe"
      ],
      "raw_values": [
        "cmd.exe",
        "draw.io.exe"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n  (process.name : \"attrib.exe\" or ?process.pe.original_file_name == \"ATTRIB.EXE\") and process.args : \"+h\" and\n  not (process.parent.name: \"cmd.exe\" and process.command_line: \"attrib  +R +H +S +A *.cui\") and\n\n  not (\n    process.parent.name: \"draw.io.exe\" and\n    (\n      process.command_line : (\"*drawio.bkp*\", \"*drawio.dtmp*\")\n    )\n  )\n",
  "language": "eql",
  "translated_query": null,
  "source_path": "rules/windows/defense_evasion_adding_the_hidden_file_attribute_with_via_attribexe.toml",

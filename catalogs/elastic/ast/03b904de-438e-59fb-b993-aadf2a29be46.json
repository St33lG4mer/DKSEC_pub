{
  "id": "03b904de-438e-59fb-b993-aadf2a29be46",
  "catalog": "elastic",
  "name": "UAC Bypass via Windows Firewall Snap-In Hijack",
  "description": "",
  "severity": "high",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": "==",
      "values": [
        "mmc.exe"
      ],
      "raw_values": [
        "mmc.exe"
      ]
    },
    {
      "field": "process.ext.token.integrity_level_name",
      "raw_field": "process.Ext.token.integrity_level_name",
      "operator": "==",
      "values": [
        "high"
      ],
      "raw_values": [
        "high"
      ]
    },
    {
      "field": "process.parent.args",
      "raw_field": "process.parent.args",
      "operator": "==",
      "values": [
        "wf.msc"
      ],
      "raw_values": [
        "WF.msc"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "!=",
      "values": [
        "werfault.exe"
      ],
      "raw_values": [
        "WerFault.exe"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n process.parent.name == \"mmc.exe\" and\n /* process.Ext.token.integrity_level_name == \"high\" can be added in future for tuning */\n /* args of the Windows Firewall SnapIn */\n  process.parent.args == \"WF.msc\" and process.name != \"WerFault.exe\"\n",
  "language": "eql",

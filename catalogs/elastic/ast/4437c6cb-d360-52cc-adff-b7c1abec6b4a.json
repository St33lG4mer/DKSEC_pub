        "exec",
        "start",
        "exec_event"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": "in",
      "values": [
        "libtool",
        "jpenable",
        "configure"
      ],
      "raw_values": [

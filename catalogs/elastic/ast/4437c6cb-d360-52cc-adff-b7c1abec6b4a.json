{
  "id": "4437c6cb-d360-52cc-adff-b7c1abec6b4a",
  "catalog": "elastic",
  "name": "Hidden Directory Creation via Unusual Parent",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "buildah",
        "python-build.",
        "cliphist-wofi-img",
        "snap.rootfs_",
        "acme.sh",
        "test-compile"
      ],
      "raw_values": [
        "/dev/shm/*",
        "/tmp/*",
        "/var/tmp/*",
        "/var/run/*",
        "/root/*",
        "/boot/*",
        "/var/www/html/*",
        "/opt/.*",
        "/tmp/pear/temp/*",
        "/var/tmp/buildah*",
        "/tmp/python-build.*",
        "/tmp/cliphist-wofi-img",
        "/tmp/snap.rootfs_*",
        "/root/.acme.sh/acme.sh",
        "/tmp/buildpacks/*go/bin/test-compile",
        "/tmp/newroot/*",
        "/run/containerd/*"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "mkdir -p .",
        ".ssh",
        "install4j"
      ],
      "raw_values": [
        ".*",
        "/*/.*",
        "mkdir -p .",
        "mkdir ./*",
        "/root/.ssh",
        "/home/*/.ssh",
        "/root/.cache/install4j"
      ]
    },
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "in",
      "values": [
        "exec",

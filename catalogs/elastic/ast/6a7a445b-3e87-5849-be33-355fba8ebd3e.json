{
  "id": "6a7a445b-3e87-5849-be33-355fba8ebd3e",
  "catalog": "elastic",
  "name": "NetSupport Manager Execution from an Unusual Path",
  "description": "",
  "severity": "critical",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        ".exe",
        "client32.exe"
      ],
      "raw_values": [
        "?:\\\\Users\\\\*.exe",
        "?:\\\\ProgramData\\\\*.exe",
        "\\\\Device\\\\HarddiskVolume*\\\\Users\\\\*.exe",
        "\\\\Device\\\\HarddiskVolume*\\\\ProgramData\\\\*.exe",
        "client32.exe"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "client32.exe"
      ],
      "raw_values": [
        "?:\\\\Users\\\\*\\\\client32.exe",
        "?:\\\\ProgramData\\\\*\\\\client32.exe",
        "client32.exe"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": "==",
      "values": [
        "client32.exe"
      ],
      "raw_values": [
        "client32.exe"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n (process.name : \"client32.exe\" or ?process.pe.original_file_name == \"client32.exe\" or process.parent.name : \"client32.exe\") and\n (\n  process.executable :\n               (\"?:\\\\Users\\\\*.exe\",\n                \"?:\\\\ProgramData\\\\*.exe\",\n                \"\\\\Device\\\\HarddiskVolume*\\\\Users\\\\*.exe\",\n                \"\\\\Device\\\\HarddiskVolume*\\\\ProgramData\\\\*.exe\") or\n  ?process.parent.executable : (\"?:\\\\Users\\\\*\\\\client32.exe\", \"?:\\\\ProgramData\\\\*\\\\client32.exe\")\n  )\n",
  "language": "eql",
  "translated_query": null,
  "source_path": "rules/windows/command_and_control_rmm_netsupport_susp_path.toml",
  "metadata": {
    "risk_score": 73,

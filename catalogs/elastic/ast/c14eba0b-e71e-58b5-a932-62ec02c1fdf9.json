        "vmx",
        "vmxf",
        "vmsd",
        "vmsn",
        "vswp",
        "vmss",
        "nvram",
        "vmem"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": "in",
      "values": [
        "qemu-kvm-init",
        "kvm.modules"
      ],
      "raw_values": [
        "/usr/share/qemu/init/qemu-kvm-init",
        "/etc/sysconfig/modules/kvm.modules"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "linux"
      ],
      "raw_values": [
        "linux"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],

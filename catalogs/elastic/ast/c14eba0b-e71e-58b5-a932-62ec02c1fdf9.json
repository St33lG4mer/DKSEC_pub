{
  "id": "c14eba0b-e71e-58b5-a932-62ec02c1fdf9",
  "catalog": "elastic",
  "name": "ESXI Discovery via Grep",
  "description": "",
  "severity": "high",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "in",
      "values": [
        "exec",
        "exec_event",
        "start",
        "executed",
        "process_started",
        "processrollup2"
      ],
      "raw_values": [
        "exec",
        "exec_event",
        "start",
        "executed",
        "process_started",
        "ProcessRollup2"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "in",
      "values": [
        "grep",
        "egrep",
        "pgrep"
      ],
      "raw_values": [
        "grep",
        "egrep",
        "pgrep"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": "in",
      "values": [
        "vmdk",
        "vmx",
        "vmxf",
        "vmsd",
        "vmsn",
        "vswp",
        "vmss",
        "nvram",
        "vmem"
      ],
      "raw_values": [

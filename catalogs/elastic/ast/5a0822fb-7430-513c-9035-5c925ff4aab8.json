      ],
      "raw_values": [
        "wuauclt.exe"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "wuauclt.exe"
      ],
      "raw_values": [
        "wuauclt.exe"
      ]

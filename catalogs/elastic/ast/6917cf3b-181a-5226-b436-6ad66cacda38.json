      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": ":",
      "values": [
        "dns.exe"
      ],
      "raw_values": [
        "dns.exe",
        "?:\\\\Program Files\\\\ReasonLabs\\\\DNS\\\\ui\\\\DNS.exe"

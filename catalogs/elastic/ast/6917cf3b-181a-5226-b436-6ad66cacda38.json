  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "conhost.exe"
      ],
      "raw_values": [
        "?:\\\\Windows\\\\System32\\\\conhost.exe",
        "\\\\Device\\\\HarddiskVolume*\\\\Windows\\\\System32\\\\conhost.exe",
        "\\\\Device\\\\HarddiskVolume*\\\\Program Files\\\\ReasonLabs\\\\*"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [

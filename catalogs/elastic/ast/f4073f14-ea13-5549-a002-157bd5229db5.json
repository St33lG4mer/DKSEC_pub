{
  "id": "f4073f14-ea13-5549-a002-157bd5229db5",
  "catalog": "elastic",
  "name": "Curl Execution via Shell Profile",
  "description": "",
  "severity": "critical",
  "mitre_techniques": [
    "attack.persistence",
    "attack.command-and-control"
  ],
  "event_categories": [
    "any"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "upload.elastic.co",
        "vault-ci-prod.elastic.dev",
        "artifacts.elastic.co"
      ],
      "raw_values": [
        "https://upload.elastic.co*",
        "https://vault-ci-prod.elastic.dev",
        "https://artifacts.elastic.co*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "in",
      "values": [
        "bash",
        "zsh",
        "curl",
        "nscurl"
      ],
      "raw_values": [
        "bash",
        "zsh",
        "sh",
        "curl",
        "nscurl"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": "in",
      "values": [
        "-zsh",
        "-sh",
        "-bash",
        "--output",
        "--download",
        "-dl",
        "-dir",
        "--directory",
        "--form"
      ],
      "raw_values": [
        "-zsh",
        "-sh",
        "-bash",
        "-o",
        "--output",
        "--download",
        "-dl",
        "-dir",
        "--directory",
        "-F",
        "--form"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "macos"
      ],
      "raw_values": [
        "macos"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "==",
      "values": [
        "exec"
      ],
      "raw_values": [
        "exec"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": "==",
      "values": [
        "login"
      ],
      "raw_values": [
        "login"
      ]
    }
  ],
  "raw_query": "sequence with maxspan=10s\n  [process where host.os.type == \"macos\" and event.type == \"start\" and event.action == \"exec\" and\n    process.name in (\"bash\", \"zsh\", \"sh\") and\n    process.args in (\"-zsh\", \"-sh\", \"-bash\") and process.args_count == 1 and\n    process.parent.name == \"login\"] by process.entity_id\n  [process where host.os.type == \"macos\" and event.type == \"start\" and event.action == \"exec\" and\n    process.name in (\"curl\", \"nscurl\") and\n    process.args in (\"-o\", \"--output\", \"--download\", \"-dl\", \"-dir\", \"--directory\", \"-F\", \"--form\") and\n    not process.args like (\"https://upload.elastic.co*\", \"https://vault-ci-prod.elastic.dev\", \"https://artifacts.elastic.co*\")] by process.parent.entity_id\n",
  "language": "eql",
  "translated_query": null,
  "source_path": "rules/macos/persistence_curl_execution_via_shell_profile.toml",

  "name": "Git Repository or File Download to Suspicious Directory",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [
    "attack.command-and-control"
  ],
  "event_categories": [
    "any"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "in",
      "values": [
        "wget",

      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": "==",
      "values": [
        "clone"
      ],
      "raw_values": [
        "clone"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "github"
      ],
      "raw_values": [
        "*github*"
      ]
    },
    {
      "field": "process.parent.args",
      "raw_field": "process.parent.args",
      "operator": "like",
      "values": [
        "/root/.ansible/tmp/ansible"
      ],
      "raw_values": [
        "/root/.ansible/tmp/ansible*"
      ]
    }
  ],
  "raw_query": "sequence by process.entity_id, host.id with maxspan=10s\n  [process where host.os.type == \"linux\" and event.type == \"start\" and event.action == \"exec\" and (\n     (process.name == \"git\" and process.args == \"clone\") or\n     (process.name in (\"wget\", \"curl\") and process.command_line like~ \"*github*\")\n  ) and not (\n    process.parent.name in (\"git\", \"cmake\") or\n     process.parent.args like \"/root/.ansible/tmp/ansible*\"\n  )]\n  [file where host.os.type == \"linux\" and event.type == \"creation\" and file.path like (\"/tmp/*\", \"/var/tmp/*\", \"/dev/shm/*\")]\n",
  "language": "eql",
  "translated_query": null,

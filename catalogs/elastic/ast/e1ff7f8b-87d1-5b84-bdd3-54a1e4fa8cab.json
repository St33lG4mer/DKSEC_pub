{
  "id": "e1ff7f8b-87d1-5b84-bdd3-54a1e4fa8cab",
  "catalog": "elastic",
  "name": "Kernel Load or Unload via Kexec Detected",
  "description": "",
  "severity": "high",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "in",
      "values": [
        "exec",
        "exec_event",
        "start",
        "processrollup2",
        "executed",
        "process_started"
      ],
      "raw_values": [
        "exec",
        "exec_event",
        "start",
        "ProcessRollup2",
        "executed",
        "process_started"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": "in",
      "values": [
        "--exec",
        "--load",
        "--unload"
      ],
      "raw_values": [
        "--exec",
        "-e",
        "--load",
        "-l",
        "--unload",
        "-u"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": "in",
      "values": [
        "kdumpctl",
        "unload.sh"
      ],
      "raw_values": [
        "kdumpctl",
        "unload.sh"
      ]
    },
    {
      "field": "process.parent.args",
      "raw_field": "process.parent.args",
      "operator": "in",
      "values": [
        "/usr/bin/kdumpctl",
        "/usr/sbin/kdump-config",
        "/usr/lib/kdump/unload.sh"
      ],
      "raw_values": [
        "/usr/bin/kdumpctl",
        "/usr/sbin/kdump-config",
        "/usr/lib/kdump/unload.sh"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "linux"
      ],
      "raw_values": [
        "linux"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "==",
      "values": [
        "kexec"
      ],
      "raw_values": [
        "kexec"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"linux\" and event.type == \"start\" and\nevent.action in (\"exec\", \"exec_event\", \"start\", \"ProcessRollup2\", \"executed\", \"process_started\") and\nprocess.name == \"kexec\" and process.args in (\"--exec\", \"-e\", \"--load\", \"-l\", \"--unload\", \"-u\") and\nnot (\n  process.parent.name in (\"kdumpctl\", \"unload.sh\") or\n  process.parent.args in (\"/usr/bin/kdumpctl\", \"/usr/sbin/kdump-config\", \"/usr/lib/kdump/unload.sh\")\n)\n",
  "language": "eql",
  "translated_query": null,

  "mitre_techniques": [],
  "event_categories": [
    "any"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "-hup",
        "-sigusr1",
        "-usr2",
        "-winch",
        "-usr1"
      ],
      "raw_values": [
        "-HUP",
        "-SIGUSR1",
        "-USR2",
        "-WINCH",
        "-USR1"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "systemd",
        "qualys-cloud-agent",
        "xargs",
        "sudo",
        "safe_asterisk",
        "dcservice",
        "nessuscli",
        "start_stop_bootstrap.sh",
        "dcpatchscan"
      ],
      "raw_values": [
        "/usr/lib/systemd/systemd",
        "/usr/local/qualys/cloud-agent/bin/qualys-cloud-agent",
        "/bin/xargs",
        "/usr/bin/xargs",
        "/usr/bin/sudo",
        "/usr/sbin/safe_asterisk",
        "/usr/local/manageengine/uems_agent/bin/dcservice",

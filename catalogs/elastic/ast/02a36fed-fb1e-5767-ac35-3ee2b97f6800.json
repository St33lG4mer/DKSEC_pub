{
  "id": "02a36fed-fb1e-5767-ac35-3ee2b97f6800",
  "catalog": "elastic",
  "name": "Kubernetes Direct API Request via Curl or Wget",
  "description": "",
  "severity": "high",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "curl",
        "wget",
        "curl.exe",
        "wget.exe"
      ],
      "raw_values": [
        "curl",
        "wget",
        "curl.exe",
        "wget.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "secrets",
        "configmaps",
        "pods",
        "deployments"
      ],
      "raw_values": [
        "*http*//*/apis/authorization.k8s.io/*",
        "*http*//*/apis/rbac.authorization.k8s.io/*",
        "*http*//*/api/v1/secrets*",
        "*http*//*/api/v1/namespaces/*/secrets*",
        "*http*//*/api/v1/configmaps*",
        "*http*//*/api/v1/pods*",
        "*http*//*/apis/apps/v1/deployments*"
      ]
    },
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "in",
      "values": [
        "exec",
        "exec_event",
        "start",
        "executed",
        "process_started",
        "processrollup2"
      ],
      "raw_values": [
        "exec",
        "exec_event",
        "start",
        "executed",
        "process_started",
        "ProcessRollup2"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    }
  ],
  "raw_query": "process where event.type == \"start\" and\nevent.action in (\"exec\", \"exec_event\", \"start\", \"executed\", \"process_started\", \"ProcessRollup2\") and\nprocess.name : (\"curl\", \"wget\", \"curl.exe\", \"wget.exe\") and process.command_line like~ (\n  \"*http*//*/apis/authorization.k8s.io/*\",\n  \"*http*//*/apis/rbac.authorization.k8s.io/*\",\n  \"*http*//*/api/v1/secrets*\",\n  \"*http*//*/api/v1/namespaces/*/secrets*\",\n  \"*http*//*/api/v1/configmaps*\",\n  \"*http*//*/api/v1/pods*\",\n  \"*http*//*/apis/apps/v1/deployments*\"\n)\n",
  "language": "eql",
  "translated_query": null,
  "source_path": "rules/cross-platform/execution_kubernetes_direct_api_request_via_curl_or_wget.toml",
  "metadata": {
    "risk_score": 47,
    "tags": [
      "Domain: Endpoint",
      "Domain: Container",
      "Domain: Kubernetes",
      "OS: Linux",
      "OS: macOS",
      "OS: Windows",
      "Use Case: Threat Detection",
      "Tactic: Execution",
      "Tactic: Discovery",
      "Data Source: Sysmon",
      "Data Source: Windows Security Event Logs",
      "Data Source: Auditd Manager",
      "Data Source: Elastic Defend",
      "Data Source: Elastic Endgame",
      "Data Source: Crowdstrike",
      "Data Source: SentinelOne",
      "Data Source: Elastic Defend for Containers",
      "Resources: Investigation Guide"
    ]
  }
}
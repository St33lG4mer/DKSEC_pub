        "agent",
        "polkit-kde-authentication-agent-1",
        "xfce-polkit",
        "dolphin"
      ],
      "raw_values": [
        "/usr/libexec/oracle-cloud-agent/plugins/unifiedmonitoring/unifiedmonitoring",
        "/usr/libexec/oracle-cloud-agent/agent",
        "/usr/lib/x86_64-linux-gnu/libexec/polkit-kde-authentication-agent-1",
        "/usr/libexec/xfce-polkit",
        "/usr/bin/dolphin"

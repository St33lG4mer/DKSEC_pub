        "dbus-daemon-launch-helper",
        "ssh-keysign",
        "pkexec",
        "polkit-agent-helper-1",
        "snap-confine"
      ],
      "raw_values": [
        "/bin/su",
        "/usr/bin/su",
        "/usr/bin/sudo",
        "/bin/mount",
        "/usr/bin/mount",
        "/bin/umount",
        "/usr/bin/umount",
        "/usr/bin/fusermount3",
        "/bin/passwd",

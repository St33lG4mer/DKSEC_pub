{
  "id": "a915214c-81e4-592e-affc-15e37fd229fd",
  "catalog": "elastic",
  "name": "Potential Ransomware Note File Dropped via SMB",
  "description": "",
  "severity": "critical",
  "mitre_techniques": [
    "attack.impact"
  ],
  "event_categories": [
    "any"
  ],
  "conditions": [
    {
      "field": "user.id",
      "raw_field": "user.id",
      "operator": ":",
      "values": [
        "s-1-5-21",
        "s-1-12-"
      ],
      "raw_values": [
        "S-1-5-21*",
        "S-1-12-*"
      ]
    },
    {

      "values": [
        "hta",
        "txt",
        "readme",
        "htm"
      ],
      "raw_values": [
        "hta",
        "txt",
        "readme",
        "htm*"
      ]
    },
    {
      "field": "file.name",
      "raw_field": "file.name",
      "operator": ":",
      "values": [
        "read*me",
        "lock",
        "recover",
        "decrypt",
        "restore*file",
        "files_back",
        "how*to"
      ],
      "raw_values": [
        "*read*me*",
        "*lock*",
        "*@*",
        "*RECOVER*",
        "*decrypt*",
        "*restore*file*",
        "*FILES_BACK*",
        "*how*to*"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "==",
      "values": [
        "connection_accepted",
        "creation"
      ],
      "raw_values": [
        "connection_accepted",
        "creation"
      ]
    },
    {
      "field": "source.ip",
      "raw_field": "source.ip",
      "operator": "!=",
      "values": [
        "127.0.0.1",
        "::1"
      ],
      "raw_values": [
        "127.0.0.1",
        "::1"
      ]
    },
    {
      "field": "network.type",
      "raw_field": "network.type",
      "operator": "==",
      "values": [
        "ipv4"
      ],
      "raw_values": [

  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "conhost.exe",
        "devicecensus.exe",
        "compattelrunner.exe",
        "dismhost.exe",
        "rundll32.exe",
        "powershell.exe"
      ],
      "raw_values": [
        "conhost.exe",
        "DeviceCensus.exe",
        "CompatTelRunner.exe",
        "DismHost.exe",
        "rundll32.exe",
        "powershell.exe"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": ":",
      "values": [
        "compattelrunner.exe"
      ],
      "raw_values": [
        "CompatTelRunner.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "-cv"
      ],
      "raw_values": [
        "-cv*"
      ]
    }

{
  "id": "4ebe6941-1052-559c-b58d-7dbd2e7a02e6",
  "catalog": "elastic",
  "name": "Enumerating Domain Trusts via NLTEST.EXE",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [
    "attack.discovery"
  ],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "dclist:",
        "dcname:",
        "dsget",
        "lsaqueryfti:",
        "parentdomain",
        "domain_trusts",
        "bdc_query:"
      ],
      "raw_values": [
        "/DCLIST:*",
        "/DCNAME:*",
        "/DSGET*",
        "/LSAQUERYFTI:*",
        "/PARENTDOMAIN",
        "/DOMAIN_TRUSTS",
        "/BDC_QUERY:*"
      ]
    },
    {
      "field": "data_stream.dataset",
      "raw_field": "data_stream.dataset",
      "operator": ":",
      "values": [
        "windows.sysmon_operational",
        "windows.sysmon"
      ],
      "raw_values": [
        "windows.sysmon_operational",
        "windows.sysmon"
      ]
    },
    {
      "field": "user.id",
      "raw_field": "user.id",
      "operator": "in",
      "values": [
        "s-1-5-18",
        "s-1-5-19",
        "s-1-5-20"
      ],
      "raw_values": [
        "S-1-5-18",
        "S-1-5-19",
        "S-1-5-20"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "nltest.exe"
      ],
      "raw_values": [
        "nltest.exe"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": ":",
      "values": [
        "pdqinventoryscanner.exe"
      ],
      "raw_values": [
        "PDQInventoryScanner.exe"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n    process.name : \"nltest.exe\" and process.args : (\n        \"/DCLIST:*\", \"/DCNAME:*\", \"/DSGET*\",\n        \"/LSAQUERYFTI:*\", \"/PARENTDOMAIN\",\n        \"/DOMAIN_TRUSTS\", \"/BDC_QUERY:*\"\n        ) and \nnot process.parent.name : \"PDQInventoryScanner.exe\" and\nnot (\n  user.id in (\"S-1-5-18\", \"S-1-5-19\", \"S-1-5-20\") and\n  /* Don't apply the user.id exclusion to Sysmon for compatibility */\n  not data_stream.dataset : (\"windows.sysmon_operational\", \"windows.sysmon\")\n)\n",
  "language": "eql",
  "translated_query": null,
  "source_path": "rules/windows/discovery_enumerating_domain_trusts_via_nltest.toml",
  "metadata": {
    "risk_score": 21,
    "tags": [
      "Domain: Endpoint",
      "OS: Windows",
      "Use Case: Threat Detection",
      "Tactic: Discovery",
      "Data Source: Elastic Endgame",
      "Resources: Investigation Guide",
      "Data Source: Elastic Defend",
      "Data Source: Windows Security Event Logs",
      "Data Source: Microsoft Defender for Endpoint",
      "Data Source: Crowdstrike",
      "Data Source: Sysmon"
    ]
  }
}
{
  "id": "b95a8afd-6c2e-5de2-8370-3717703a7f60",
  "catalog": "elastic",
  "name": "UAC Bypass via DiskCleanup Scheduled Task Hijack",
  "description": "",
  "severity": "high",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "cleanmgr.exe",
        "taskhostw.exe"
      ],
      "raw_values": [
        "C:\\\\Windows\\\\System32\\\\cleanmgr.exe",
        "C:\\\\Windows\\\\SysWOW64\\\\cleanmgr.exe",
        "C:\\\\Windows\\\\System32\\\\taskhostw.exe",
        "\\\\Device\\\\HarddiskVolume*\\\\Windows\\\\System32\\\\cleanmgr.exe",
        "\\\\Device\\\\HarddiskVolume*\\\\Windows\\\\SysWOW64\\\\cleanmgr.exe",
        "\\\\Device\\\\HarddiskVolume*\\\\Windows\\\\System32\\\\taskhostw.exe"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "autoclean"
      ],
      "raw_values": [
        "/autoclean",
        "/d"
      ]
    }
  ],
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n process.args : \"/autoclean\" and process.args : \"/d\" and process.executable != null and\n not process.executable : (\n        \"C:\\\\Windows\\\\System32\\\\cleanmgr.exe\",\n        \"C:\\\\Windows\\\\SysWOW64\\\\cleanmgr.exe\",\n        \"C:\\\\Windows\\\\System32\\\\taskhostw.exe\",\n\n        /* Crowdstrike specific exclusion as it uses NT Object paths */\n        \"\\\\Device\\\\HarddiskVolume*\\\\Windows\\\\System32\\\\cleanmgr.exe\",\n        \"\\\\Device\\\\HarddiskVolume*\\\\Windows\\\\SysWOW64\\\\cleanmgr.exe\",\n        \"\\\\Device\\\\HarddiskVolume*\\\\Windows\\\\System32\\\\taskhostw.exe\"\n)\n",
  "language": "eql",
  "translated_query": null,
  "source_path": "rules/windows/privilege_escalation_uac_bypass_diskcleanup_hijack.toml",

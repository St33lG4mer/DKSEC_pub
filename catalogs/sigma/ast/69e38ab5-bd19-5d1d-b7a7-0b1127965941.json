{
  "id": "69e38ab5-bd19-5d1d-b7a7-0b1127965941",
  "catalog": "sigma",
  "name": "proc_creation_win_susp_browser_launch_from_document_reader_process",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [
    "attack.t1204.002"
  ],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": "like~",
      "values": [
        "acrobat reader",
        "microsoft office",
        "pdf reader"
      ],
      "raw_values": [
        "*Acrobat Reader*",
        "*Microsoft Office*",
        "*PDF Reader*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "brave.exe",
        "chrome.exe",
        "firefox.exe",
        "msedge.exe",
        "opera.exe",
        "maxthon.exe",
        "seamonkey.exe",
        "vivaldi.exe"
      ],
      "raw_values": [
        "*\\\\brave.exe",
        "*\\\\chrome.exe",
        "*\\\\firefox.exe",
        "*\\\\msedge.exe",
        "*\\\\opera.exe",
        "*\\\\maxthon.exe",
        "*\\\\seamonkey.exe",
        "*\\\\vivaldi.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "adlog.php",
        "go.php?do=redirect"
      ],
      "raw_values": [
        "*http://ad.foxitsoftware.com/adlog.php?*",
        "*https://globe-map.foxitservice.com/go.php?do=redirect*"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "http"
      ],
      "raw_values": [
        "*http*",
        "*https://go.microsoft.com/fwlink/*"
      ]
    }
  ],
  "raw_query": "any where ((process.parent.executable like~ (\"*Acrobat Reader*\", \"*Microsoft Office*\", \"*PDF Reader*\")) and (process.executable like~ (\"*\\\\brave.exe\", \"*\\\\chrome.exe\", \"*\\\\firefox.exe\", \"*\\\\msedge.exe\", \"*\\\\opera.exe\", \"*\\\\maxthon.exe\", \"*\\\\seamonkey.exe\", \"*\\\\vivaldi.exe\")) and process.command_line:\"*http*\") and (not process.command_line:\"*https://go.microsoft.com/fwlink/*\") and (not (process.command_line like~ (\"*http://ad.foxitsoftware.com/adlog.php?*\", \"*https://globe-map.foxitservice.com/go.php?do=redirect*\")))",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/process_creation/proc_creation_win_susp_browser_launch_from_document_reader_process.eql",

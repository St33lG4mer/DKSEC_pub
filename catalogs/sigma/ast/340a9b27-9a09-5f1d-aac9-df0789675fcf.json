  "id": "340a9b27-9a09-5f1d-aac9-df0789675fcf",
  "catalog": "sigma",
  "name": "proc_creation_win_remote_access_tools_rurat_non_default_location",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "rutserv.exe",
        "rfusclient.exe",
        "remote utilities"
      ],
      "raw_values": [
        "*\\\\rutserv.exe",
        "*\\\\rfusclient.exe",
        "C:\\\\Program Files\\\\Remote Utilities*"
      ]
    },
    {
      "field": "process.pe.product",
      "raw_field": "process.pe.product",
      "operator": ":",
      "values": [
        "remote utilities"
      ],
      "raw_values": [
        "Remote Utilities"
      ]
    }
  ],
  "raw_query": "any where ((process.executable like~ (\"*\\\\rutserv.exe\", \"*\\\\rfusclient.exe\")) or process.pe.product:\"Remote Utilities\") and (not (process.executable like~ (\"C:\\\\Program Files\\\\Remote Utilities*\", \"C:\\\\Program Files (x86)\\\\Remote Utilities*\")))",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/process_creation/proc_creation_win_remote_access_tools_rurat_non_default_location.eql",

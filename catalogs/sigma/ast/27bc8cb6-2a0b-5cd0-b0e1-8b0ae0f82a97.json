{
  "id": "27bc8cb6-2a0b-5cd0-b0e1-8b0ae0f82a97",
  "catalog": "sigma",
  "name": "proc_access_win_lsass_python_based_tool",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "winlog.event_data.calltrace",
      "raw_field": "winlog.event_data.CallTrace",
      "operator": "like~",
      "values": [
        "python27.dll+",
        "python3*.dll+"
      ],
      "raw_values": [
        "*python27.dll+*",
        "*python3*.dll+*"
      ]
    },
    {
      "field": "winlog.event_data.targetimage",
      "raw_field": "winlog.event_data.TargetImage",
      "operator": ":",
      "values": [
        "\\\\lsass.exe"
      ],
      "raw_values": [
        "*\\\\lsass.exe"
      ]
    },
    {
      "field": "winlog.event_data.calltrace",
      "raw_field": "winlog.event_data.CallTrace",
      "operator": ":",
      "values": [
        "_ctypes.pyd+",
        ":\\\\windows\\\\system32\\\\kernelbase.dll+",
        ":\\\\windows\\\\system32\\\\ntdll.dll+"
      ],
      "raw_values": [
        "*_ctypes.pyd+*",
        "*:\\\\Windows\\\\System32\\\\KERNELBASE.dll+*",
        "*:\\\\Windows\\\\SYSTEM32\\\\ntdll.dll+*"
      ]
    },
    {
      "field": "winlog.event_data.grantedaccess",
      "raw_field": "winlog.event_data.GrantedAccess",
      "operator": ":",
      "values": [
        "0x1fffff"
      ],
      "raw_values": [
        "0x1FFFFF"
      ]
    }
  ],
  "raw_query": "any where winlog.event_data.TargetImage:\"*\\\\lsass.exe\" and (winlog.event_data.CallTrace:\"*_ctypes.pyd+*\" and winlog.event_data.CallTrace:\"*:\\\\Windows\\\\System32\\\\KERNELBASE.dll+*\" and winlog.event_data.CallTrace:\"*:\\\\Windows\\\\SYSTEM32\\\\ntdll.dll+*\") and (winlog.event_data.CallTrace like~ (\"*python27.dll+*\", \"*python3*.dll+*\")) and winlog.event_data.GrantedAccess:\"0x1FFFFF\"",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/process_access/proc_access_win_lsass_python_based_tool.eql",
  "metadata": {}
}
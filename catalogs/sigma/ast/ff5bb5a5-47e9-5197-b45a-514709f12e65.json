      ],
      "raw_values": [
        "SharpImpersonation.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "user:",
        "binary:",
        "shellcode:"

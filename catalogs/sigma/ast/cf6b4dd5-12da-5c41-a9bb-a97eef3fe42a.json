  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "powershell.exe",
        "pwsh.exe",
        "cmd.exe"
      ],
      "raw_values": [
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe",
        "*\\\\cmd.exe"
      ]
    },
    {
      "field": "process.parent.command_line",
      "raw_field": "process.parent.command_line",
      "operator": ":",
      "values": [
        "msiexec.exe",
        "-embedding",
        "msiexec.exe -embedding",
        "msi0000"
      ],
      "raw_values": [
        "*MsiExec.exe*",
        "*-Embedding *",
        "*\\\\MsiExec.exe -Embedding *",
        "*Global\\\\MSI0000*"

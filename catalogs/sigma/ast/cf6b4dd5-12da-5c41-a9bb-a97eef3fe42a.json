    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "cmd.exe"
      ],
      "raw_values": [
        "*:\\\\Windows\\\\System32\\\\cmd.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "dismfodinstall.cmd"
      ],
      "raw_values": [
        "*C:\\\\Program Files\\\\SplunkUniversalForwarder\\\\bin\\\\*",
        "*\\\\DismFoDInstall.cmd*"

  "name": "proc_creation_win_wab_execution_from_non_default_location",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "wab.exe",
        "wabmig.exe"
      ],
      "raw_values": [
        "*\\\\wab.exe",
        "*\\\\wabmig.exe",
        "C:\\\\Windows\\\\WinSxS\\\\*",
        "C:\\\\Program Files\\\\Windows Mail\\\\*"
      ]
    }
  ],
  "raw_query": "any where (process.executable like~ (\"*\\\\wab.exe\", \"*\\\\wabmig.exe\")) and (not (process.executable like~ (\"C:\\\\Windows\\\\WinSxS\\\\*\", \"C:\\\\Program Files\\\\Windows Mail\\\\*\", \"C:\\\\Program Files (x86)\\\\Windows Mail\\\\*\")))",
  "language": "sigma",

{
  "id": "c7d65535-7e9d-52c1-a0c1-b68a7c067e0f",
  "catalog": "sigma",
  "name": "proc_access_win_svchost_credential_dumping",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [
    "attack.t1548"
  ],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "services.exe",
        "msiexec.exe"
      ],
      "raw_values": [
        "*\\\\services.exe",
        "*\\\\msiexec.exe"
      ]
    },
    {
      "field": "winlog.event_data.targetimage",
      "raw_field": "winlog.event_data.TargetImage",
      "operator": ":",
      "values": [
        "\\\\svchost.exe"
      ],
      "raw_values": [
        "*\\\\svchost.exe"
      ]
    },
    {
      "field": "winlog.event_data.grantedaccess",
      "raw_field": "winlog.event_data.GrantedAccess",
      "operator": ":",
      "values": [
        "0x143a"
      ],
      "raw_values": [
        "0x143a"
      ]
    }
  ],
  "raw_query": "any where (winlog.event_data.TargetImage:\"*\\\\svchost.exe\" and winlog.event_data.GrantedAccess:\"0x143a\") and (not (process.executable like~ (\"*\\\\services.exe\", \"*\\\\msiexec.exe\")))",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/process_access/proc_access_win_svchost_credential_dumping.eql",
  "metadata": {}
}
  "raw_query": "any where (registry.path:\"*\\\\SOFTWARE\\\\ODBC\\\\ODBCINST.INI\\\\*\" and registry.path:\"*\\\\Driver\") and (not (registry.path:\"*\\\\SQL Server\\\\*\" and winlog.event_data.Details:\"%WINDIR%\\\\System32\\\\SQLSRV32.dll\")) and (not ((registry.path:\"*\\\\Microsoft Access *\" and winlog.event_data.Details:\"C:\\\\Progra*\" and winlog.event_data.Details:\"*\\\\ACEODBC.DLL\") or (registry.path:\"*\\\\Microsoft Excel Driver*\" and winlog.event_data.Details:\"C:\\\\Progra*\" and winlog.event_data.Details:\"*\\\\ACEODBC.DLL\")))",

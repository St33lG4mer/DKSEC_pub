{
  "id": "3d2303c4-b083-51fc-a25c-0f03edd46b16",
  "catalog": "sigma",
  "name": "registry_set_add_port_monitor",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [],
  "event_categories": [
    "registry"
  ],
  "conditions": [
    {
      "field": "user.name",
      "raw_field": "user.name",
      "operator": "like~",
      "values": [
        "authori",
        "autori"
      ],
      "raw_values": [
        "*AUTHORI*",
        "*AUTORI*"
      ]
    },
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\control\\\\print\\\\monitors\\\\",
        "\\\\control\\\\print\\\\monitors\\\\cutepdf writer monitor v4.0\\\\driver",
        "\\\\control\\\\print\\\\monitors\\\\monvnc\\\\driver",
        "control\\\\print\\\\environments\\\\",
        "\\\\drivers\\\\",
        "\\\\vnc printer"
      ],
      "raw_values": [
        "*\\\\Control\\\\Print\\\\Monitors\\\\*",
        "*\\\\Control\\\\Print\\\\Monitors\\\\CutePDF Writer Monitor v4.0\\\\Driver*",
        "*\\\\Control\\\\Print\\\\Monitors\\\\MONVNC\\\\Driver*",
        "*Control\\\\Print\\\\Environments\\\\*",
        "*\\\\Drivers\\\\*",
        "*\\\\VNC Printer*"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        ".dll",
        "cpwmon64_v40.dll"
      ],
      "raw_values": [
        "*.dll",
        "cpwmon64_v40.dll"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "spoolsv.exe"
      ],
      "raw_values": [
        "C:\\\\Windows\\\\System32\\\\spoolsv.exe"
      ]
    }
  ],
  "raw_query": "any where (registry.path:\"*\\\\Control\\\\Print\\\\Monitors\\\\*\" and winlog.event_data.Details:\"*.dll\") and (not ((process.executable:\"C:\\\\Windows\\\\System32\\\\spoolsv.exe\" and registry.path:\"*\\\\Control\\\\Print\\\\Monitors\\\\CutePDF Writer Monitor v4.0\\\\Driver*\" and winlog.event_data.Details:\"cpwmon64_v40.dll\" and (user.name like~ (\"*AUTHORI*\", \"*AUTORI*\"))) or registry.path:\"*\\\\Control\\\\Print\\\\Monitors\\\\MONVNC\\\\Driver*\" or (registry.path:\"*Control\\\\Print\\\\Environments\\\\*\" and registry.path:\"*\\\\Drivers\\\\*\" and registry.path:\"*\\\\VNC Printer*\")))",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/registry/registry_set/registry_set_add_port_monitor.eql",
  "metadata": {}
}
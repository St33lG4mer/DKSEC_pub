  "id": "b480b085-cc49-560e-ac8e-1b6268820faa",
  "catalog": "sigma",
  "name": "proc_creation_win_cmd_ping_copy_combined_execution",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [
    "attack.t1070.004"
  ],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "cmd.exe"
      ],
      "raw_values": [
        "*\\\\cmd.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "cmd.exe"
      ],
      "raw_values": [
        "Cmd.Exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "ping",
        "copy"
      ],
      "raw_values": [
        "*ping*",
        "*copy *"
      ]
    }
  ],
  "raw_query": "any where (process.executable:\"*\\\\cmd.exe\" or process.pe.original_file_name:\"Cmd.Exe\") and (process.command_line:\"*ping*\" and process.command_line:\"*copy *\") and process.command_line like~ (\"* -n *\", \"* /n *\", \"* –n *\", \"* —n *\", \"* ―n *\") and process.command_line like~ (\"* -y *\", \"* /y *\", \"* –y *\", \"* —y *\", \"* ―y *\")",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/process_creation/proc_creation_win_cmd_ping_copy_combined_execution.eql",

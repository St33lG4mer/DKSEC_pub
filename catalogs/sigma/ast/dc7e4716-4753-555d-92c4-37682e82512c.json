{
  "id": "dc7e4716-4753-555d-92c4-37682e82512c",
  "catalog": "sigma",
  "name": "file_event_win_ntds_dit_uncommon_parent_process",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [
    "attack.t1003.003"
  ],
  "event_categories": [
    "file"
  ],
  "conditions": [
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": "like~",
      "values": [
        "cscript.exe",
        "httpd.exe",
        "nginx.exe",
        "php-cgi.exe",
        "powershell.exe",
        "pwsh.exe",
        "w3wp.exe",
        "wscript.exe",
        "apache",
        "tomcat"
      ],
      "raw_values": [
        "*\\\\cscript.exe",
        "*\\\\httpd.exe",
        "*\\\\nginx.exe",
        "*\\\\php-cgi.exe",
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe",
        "*\\\\w3wp.exe",
        "*\\\\wscript.exe",
        "*\\\\apache*",
        "*\\\\tomcat*",
        "*\\\\AppData\\\\*",
        "*\\\\Temp\\\\*",
        "*\\\\Public\\\\*",
        "*\\\\PerfLogs\\\\*"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        "ntds.dit"
      ],
      "raw_values": [
        "*\\\\ntds.dit"
      ]
    }
  ],
  "raw_query": "any where file.path:\"*\\\\ntds.dit\" and ((process.parent.executable like~ (\"*\\\\cscript.exe\", \"*\\\\httpd.exe\", \"*\\\\nginx.exe\", \"*\\\\php-cgi.exe\", \"*\\\\powershell.exe\", \"*\\\\pwsh.exe\", \"*\\\\w3wp.exe\", \"*\\\\wscript.exe\")) or (process.parent.executable like~ (\"*\\\\apache*\", \"*\\\\tomcat*\", \"*\\\\AppData\\\\*\", \"*\\\\Temp\\\\*\", \"*\\\\Public\\\\*\", \"*\\\\PerfLogs\\\\*\")))",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/file/file_event/file_event_win_ntds_dit_uncommon_parent_process.eql",
  "metadata": {}
}
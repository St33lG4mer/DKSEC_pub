{
  "id": "660ac481-370e-5b2a-9a67-584edc5fe8c6",
  "catalog": "sigma",
  "name": "proc_creation_win_schtasks_delete",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "bitlocker",
        "exploitguard"
      ],
      "raw_values": [
        "*\\\\Windows\\\\BitLocker*",
        "*\\\\Windows\\\\ExploitGuard*",
        "*\\\\Windows\\\\SystemRestore\\\\SR*",
        "*\\\\Windows\\\\UpdateOrchestrator\\\\*",
        "*\\\\Windows\\\\Windows Defender\\\\*",
        "*\\\\Windows\\\\WindowsBackup\\\\*",
        "*\\\\Windows\\\\WindowsUpdate\\\\*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "schtasks.exe"
      ],
      "raw_values": [
        "*\\\\schtasks.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "delete"
      ],
      "raw_values": [
        "*/delete*",
        "*/tn*"
      ]
    }
  ],
  "raw_query": "any where process.executable:\"*\\\\schtasks.exe\" and (process.command_line:\"*/delete*\" and process.command_line:\"*/tn*\") and (process.command_line like~ (\"*\\\\Windows\\\\BitLocker*\", \"*\\\\Windows\\\\ExploitGuard*\", \"*\\\\Windows\\\\SystemRestore\\\\SR*\", \"*\\\\Windows\\\\UpdateOrchestrator\\\\*\", \"*\\\\Windows\\\\Windows Defender\\\\*\", \"*\\\\Windows\\\\WindowsBackup\\\\*\", \"*\\\\Windows\\\\WindowsUpdate\\\\*\"))",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/process_creation/proc_creation_win_schtasks_delete.eql",

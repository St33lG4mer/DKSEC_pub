{
  "id": "da604392-ddcd-5a64-8acf-a6051e64e237",
  "catalog": "sigma",
  "name": "proc_creation_win_winrm_susp_child_process",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [
    "attack.t1190"
  ],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "cmd.exe",
        "sh.exe",
        "bash.exe",
        "powershell.exe",
        "pwsh.exe",
        "wsl.exe",
        "schtasks.exe",
        "certutil.exe",
        "whoami.exe",
        "bitsadmin.exe"
      ],
      "raw_values": [
        "*\\\\cmd.exe",
        "*\\\\sh.exe",
        "*\\\\bash.exe",
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe",
        "*\\\\wsl.exe",
        "*\\\\schtasks.exe",
        "*\\\\certutil.exe",
        "*\\\\whoami.exe",
        "*\\\\bitsadmin.exe"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "wsmprovhost.exe"
      ],
      "raw_values": [
        "*\\\\wsmprovhost.exe"
      ]
    }
  ],
  "raw_query": "any where process.parent.executable:\"*\\\\wsmprovhost.exe\" and (process.executable like~ (\"*\\\\cmd.exe\", \"*\\\\sh.exe\", \"*\\\\bash.exe\", \"*\\\\powershell.exe\", \"*\\\\pwsh.exe\", \"*\\\\wsl.exe\", \"*\\\\schtasks.exe\", \"*\\\\certutil.exe\", \"*\\\\whoami.exe\", \"*\\\\bitsadmin.exe\"))",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/process_creation/proc_creation_win_winrm_susp_child_process.eql",

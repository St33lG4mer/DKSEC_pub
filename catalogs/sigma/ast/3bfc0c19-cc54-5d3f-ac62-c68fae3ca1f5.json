{
  "id": "3bfc0c19-cc54-5d3f-ac62-c68fae3ca1f5",
  "catalog": "sigma",
  "name": "proc_creation_win_wbadmin_restore_sensitive_files",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "sam",
        "security",
        "system",
        "ntds.dit"
      ],
      "raw_values": [
        "*\\\\config\\\\SAM*",
        "*\\\\config\\\\SECURITY*",
        "*\\\\config\\\\SYSTEM*",
        "*\\\\Windows\\\\NTDS\\\\NTDS.dit*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "wbadmin.exe"
      ],
      "raw_values": [
        "*\\\\wbadmin.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "wbadmin.exe"
      ],
      "raw_values": [
        "WBADMIN.EXE"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "recovery",
        "recoverytarget",
        "itemtype:file"
      ],
      "raw_values": [
        "* recovery*",
        "*recoveryTarget*",
        "*itemtype:File*"
      ]
    }
  ],
  "raw_query": "any where (process.executable:\"*\\\\wbadmin.exe\" or process.pe.original_file_name:\"WBADMIN.EXE\") and ((process.command_line:\"* recovery*\" and process.command_line:\"*recoveryTarget*\" and process.command_line:\"*itemtype:File*\") and (process.command_line like~ (\"*\\\\config\\\\SAM*\", \"*\\\\config\\\\SECURITY*\", \"*\\\\config\\\\SYSTEM*\", \"*\\\\Windows\\\\NTDS\\\\NTDS.dit*\")))",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/process_creation/proc_creation_win_wbadmin_restore_sensitive_files.eql",
  "metadata": {}
}
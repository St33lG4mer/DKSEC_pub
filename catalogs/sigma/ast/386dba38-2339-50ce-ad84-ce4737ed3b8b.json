  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "install",
        "add",
        "--manifest"
      ],
      "raw_values": [
        "*install*",
        "* add *",
        "*-m *",
        "*--manifest*"
      ]
    },
    {

      ],
      "raw_values": [
        "*\\\\winget.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "winget.exe"
      ],
      "raw_values": [
        "winget.exe"
      ]
    }
  ],
  "raw_query": "any where (process.executable:\"*\\\\winget.exe\" or process.pe.original_file_name:\"winget.exe\") and (process.command_line like~ (\"*install*\", \"* add *\")) and (process.command_line like~ (\"*-m *\", \"*--manifest*\"))",

  "raw_query": "any where process.parent.executable:\"*:\\\\Users\\\\Public\\\\*\" and ((process.executable like~ (\"*\\\\bitsadmin.exe\", \"*\\\\certutil.exe\", \"*\\\\cmd.exe\", \"*\\\\cscript.exe\", \"*\\\\mshta.exe\", \"*\\\\powershell.exe\", \"*\\\\pwsh.exe\", \"*\\\\regsvr32.exe\", \"*\\\\rundll32.exe\", \"*\\\\wscript.exe\")) or (process.command_line like~ (\"*bitsadmin*\", \"*certutil*\", \"*cscript*\", \"*mshta*\", \"*powershell*\", \"*regsvr32*\", \"*rundll32*\", \"*wscript*\")))",

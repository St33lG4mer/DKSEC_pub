  "raw_query": "any where ((process.executable:\"*\\\\dotnet.exe\" or process.pe.original_file_name:\".NET Host\") and (process.command_line like~ (\"*.csproj\", \"*.csproj\\\"\", \"*.dll\", \"*.dll\\\"\", \"*.csproj'\", \"*.dll'\"))) and (not ((process.parent.executable like~ (\"C:\\\\Program Files (x86)\\\\Notepad++\\\\notepad++.exe\", \"C:\\\\Program Files\\\\Notepad++\\\\notepad++.exe\")) and (process.command_line:\"*C:\\\\ProgramData\\\\CSScriptNpp\\\\*\" and process.command_line:\"*-cscs_path:*\" and process.command_line:\"*\\\\cs-script\\\\cscs.dll*\")))",

{
  "id": "1a0cc2ac-97f2-55e5-a88a-6dd2e2d3f698",
  "catalog": "sigma",
  "name": "proc_creation_win_sc_service_path_modification",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [
    "attack.t1543.003"
  ],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "powershell",
        "cmd",
        "mshta",
        "wscript",
        "cscript",
        "rundll32",
        "svchost",
        "dllhost",
        "public",
        "temp"
      ],
      "raw_values": [
        "*powershell*",
        "*cmd *",
        "*mshta*",
        "*wscript*",
        "*cscript*",
        "*rundll32*",
        "*svchost*",
        "*dllhost*",
        "*cmd.exe /c*",
        "*cmd.exe /k*",
        "*cmd.exe /r*",
        "*cmd /c*",
        "*cmd /k*",
        "*cmd /r*",
        "*C:\\\\Users\\\\Public*",
        "*\\\\Downloads\\\\*",
        "*\\\\Desktop\\\\*",
        "*\\\\Microsoft\\\\Windows\\\\Start Menu\\\\Programs\\\\Startup\\\\*",
        "*C:\\\\Windows\\\\TEMP\\\\*",
        "*\\\\AppData\\\\Local\\\\Temp*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "sc.exe"
      ],
      "raw_values": [
        "*\\\\sc.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "config",
        "binpath"
      ],
      "raw_values": [
        "*config*",
        "*binPath*"
      ]
    }
  ],
  "raw_query": "any where process.executable:\"*\\\\sc.exe\" and (process.command_line:\"*config*\" and process.command_line:\"*binPath*\") and (process.command_line like~ (\"*powershell*\", \"*cmd *\", \"*mshta*\", \"*wscript*\", \"*cscript*\", \"*rundll32*\", \"*svchost*\", \"*dllhost*\", \"*cmd.exe /c*\", \"*cmd.exe /k*\", \"*cmd.exe /r*\", \"*cmd /c*\", \"*cmd /k*\", \"*cmd /r*\", \"*C:\\\\Users\\\\Public*\", \"*\\\\Downloads\\\\*\", \"*\\\\Desktop\\\\*\", \"*\\\\Microsoft\\\\Windows\\\\Start Menu\\\\Programs\\\\Startup\\\\*\", \"*C:\\\\Windows\\\\TEMP\\\\*\", \"*\\\\AppData\\\\Local\\\\Temp*\"))",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/process_creation/proc_creation_win_sc_service_path_modification.eql",

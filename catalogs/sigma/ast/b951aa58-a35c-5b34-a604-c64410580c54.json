{
  "id": "b951aa58-a35c-5b34-a604-c64410580c54",
  "catalog": "sigma",
  "name": "proc_creation_win_susp_service_creation",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "powershell",
        "mshta",
        "wscript",
        "cscript",
        "svchost",
        "dllhost",
        "cmd",
        "rundll32",
        "public",
        "temp"
      ],
      "raw_values": [
        "*powershell*",
        "*mshta*",
        "*wscript*",
        "*cscript*",
        "*svchost*",
        "*dllhost*",
        "*cmd *",
        "*cmd.exe /c*",
        "*cmd.exe /k*",
        "*cmd.exe /r*",
        "*rundll32*",
        "*C:\\\\Users\\\\Public*",
        "*\\\\Downloads\\\\*",
        "*\\\\Desktop\\\\*",
        "*\\\\Microsoft\\\\Windows\\\\Start Menu\\\\Programs\\\\Startup\\\\*",
        "*C:\\\\Windows\\\\TEMP\\\\*",
        "*\\\\AppData\\\\Local\\\\Temp*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "sc.exe"
      ],
      "raw_values": [
        "*\\\\sc.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "create",
        "binpath=",
        "new-service",
        "-binarypathname"
      ],
      "raw_values": [
        "*create*",
        "*binPath=*",
        "*New-Service*",
        "*-BinaryPathName*"
      ]
    }
  ],
  "raw_query": "any where ((process.executable:\"*\\\\sc.exe\" and (process.command_line:\"*create*\" and process.command_line:\"*binPath=*\")) or (process.command_line:\"*New-Service*\" and process.command_line:\"*-BinaryPathName*\")) and (process.command_line like~ (\"*powershell*\", \"*mshta*\", \"*wscript*\", \"*cscript*\", \"*svchost*\", \"*dllhost*\", \"*cmd *\", \"*cmd.exe /c*\", \"*cmd.exe /k*\", \"*cmd.exe /r*\", \"*rundll32*\", \"*C:\\\\Users\\\\Public*\", \"*\\\\Downloads\\\\*\", \"*\\\\Desktop\\\\*\", \"*\\\\Microsoft\\\\Windows\\\\Start Menu\\\\Programs\\\\Startup\\\\*\", \"*C:\\\\Windows\\\\TEMP\\\\*\", \"*\\\\AppData\\\\Local\\\\Temp*\"))",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/process_creation/proc_creation_win_susp_service_creation.eql",
  "metadata": {}
}
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "cmd",
        "cmd.exe",
        "psinject",
        "spawnas",
        "make_token",
        "remote-exec",
        "rev2self",
        "dcsync",
        "logonpasswords",
        "execute-assembly",
        "getsystem"

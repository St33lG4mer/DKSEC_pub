        "cmd.exe*",
        "c:\\\\windows\\\\system32\\\\cmd.exe*",
        "*psinject*",
        "*spawnas*",
        "*make_token*",
        "*remote-exec*",
        "*rev2self*",
        "*dcsync*",
        "*logonpasswords*",
        "*execute-assembly*",

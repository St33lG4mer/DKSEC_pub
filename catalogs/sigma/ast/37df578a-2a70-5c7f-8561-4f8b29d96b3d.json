  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "hklm",
        "hkey_local_machine",
        "system",
        "sam",
        "security"
      ],
      "raw_values": [
        "* -E *",
        "* /E *",
        "* –E *",
        "* —E *",
        "* ―E *",
        "*hklm*",
        "*hkey_local_machine*",
        "*\\\\system",
        "*\\\\sam",
        "*\\\\security"
      ]

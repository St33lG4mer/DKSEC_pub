{
  "id": "5d43f0e2-a647-5ae8-9bbf-9aa6eb3fb50f",
  "catalog": "sigma",
  "name": "proc_creation_win_provlaunch_potential_abuse",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [
    "attack.t1218"
  ],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "calc.exe",
        "cmd.exe",
        "cscript.exe",
        "mshta.exe",
        "notepad.exe",
        "powershell.exe",
        "pwsh.exe",
        "regsvr32.exe",
        "rundll32.exe",
        "wscript.exe"
      ],
      "raw_values": [
        "*\\\\calc.exe",
        "*\\\\cmd.exe",
        "*\\\\cscript.exe",
        "*\\\\mshta.exe",
        "*\\\\notepad.exe",
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe",
        "*\\\\regsvr32.exe",
        "*\\\\rundll32.exe",
        "*\\\\wscript.exe",
        "*:\\\\PerfLogs\\\\*",
        "*:\\\\Temp\\\\*",
        "*:\\\\Users\\\\Public\\\\*",
        "*\\\\AppData\\\\Temp\\\\*",
        "*\\\\Windows\\\\System32\\\\Tasks\\\\*",
        "*\\\\Windows\\\\Tasks\\\\*",
        "*\\\\Windows\\\\Temp\\\\*"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "provlaunch.exe"
      ],
      "raw_values": [
        "*\\\\provlaunch.exe"
      ]
    }
  ],
  "raw_query": "any where process.parent.executable:\"*\\\\provlaunch.exe\" and (not ((process.executable like~ (\"*\\\\calc.exe\", \"*\\\\cmd.exe\", \"*\\\\cscript.exe\", \"*\\\\mshta.exe\", \"*\\\\notepad.exe\", \"*\\\\powershell.exe\", \"*\\\\pwsh.exe\", \"*\\\\regsvr32.exe\", \"*\\\\rundll32.exe\", \"*\\\\wscript.exe\")) or (process.executable like~ (\"*:\\\\PerfLogs\\\\*\", \"*:\\\\Temp\\\\*\", \"*:\\\\Users\\\\Public\\\\*\", \"*\\\\AppData\\\\Temp\\\\*\", \"*\\\\Windows\\\\System32\\\\Tasks\\\\*\", \"*\\\\Windows\\\\Tasks\\\\*\", \"*\\\\Windows\\\\Temp\\\\*\"))))",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/process_creation/proc_creation_win_provlaunch_potential_abuse.eql",
  "metadata": {}
}
      "operator": ":",
      "values": [
        "bitsadmin.exe"
      ],
      "raw_values": [
        "bitsadmin.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "transfer",
        "http"
      ],
      "raw_values": [
        "* /transfer *",

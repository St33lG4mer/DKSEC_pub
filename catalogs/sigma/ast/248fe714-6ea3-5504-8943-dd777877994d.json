  "raw_query": "any where (registry.path:\"*\\\\SOFTWARE\\\\Microsoft\\\\Office\\\\*\" and registry.path:\"*\\\\Security\\\\ProtectedView\\\\*\") and ((winlog.event_data.Details:\"DWORD (0x00000001)\" and (registry.path like~ (\"*\\\\DisableAttachementsInPV\", \"*\\\\DisableInternetFilesInPV\", \"*\\\\DisableIntranetCheck\", \"*\\\\DisableUnsafeLocationsInPV\"))) or (winlog.event_data.Details:\"DWORD (0x00000000)\" and (registry.path like~ (\"*\\\\enabledatabasefileprotectedview\", \"*\\\\enableforeigntextfileprotectedview\"))))",

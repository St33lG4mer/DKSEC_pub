{
  "id": "79e29198-b92d-5cd2-9e87-fea69adcb78b",
  "catalog": "sigma",
  "name": "proc_creation_win_cmd_copy_dmp_from_share",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        ".dmp",
        ".dump",
        ".hdmp"
      ],
      "raw_values": [
        "*.dmp*",
        "*.dump*",
        "*.hdmp*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "cmd.exe"
      ],
      "raw_values": [
        "*\\\\cmd.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "cmd.exe"
      ],
      "raw_values": [
        "Cmd.Exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "copy"
      ],
      "raw_values": [
        "*copy *",
        "* \\\\\\\\*"
      ]
    }
  ],
  "raw_query": "any where (process.executable:\"*\\\\cmd.exe\" or process.pe.original_file_name:\"Cmd.Exe\") and ((process.command_line:\"*copy *\" and process.command_line:\"* \\\\\\\\*\") and (process.command_line like~ (\"*.dmp*\", \"*.dump*\", \"*.hdmp*\")))",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/process_creation/proc_creation_win_cmd_copy_dmp_from_share.eql",
  "metadata": {}
}
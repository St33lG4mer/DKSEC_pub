  "raw_query": "any where ((((?process.pe.original_file_name == null) and process.command_line:\"*.exe tunnel\") or (process.command_line:\"*.exe tunnel*\" and process.command_line:\"*--accept-server-license-terms*\") or (process.command_line:\"*tunnel *\" and process.command_line:\"*service*\" and process.command_line:\"*internal-run*\" and process.command_line:\"*tunnel-service.log*\")) and (not (process.executable like~ (\"*\\\\code-tunnel.exe\", \"*\\\\code.exe\")))) or ((process.parent.command_line:\"* tunnel\" and process.executable:\"*\\\\cmd.exe\" and (process.command_line:\"*/d /c *\" and process.command_line:\"*\\\\servers\\\\Stable-*\" and process.command_line:\"*code-server.cmd*\")) and (not (process.parent.executable like~ (\"*\\\\code-tunnel.exe\", \"*\\\\code.exe\"))))",

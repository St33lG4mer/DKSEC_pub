  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "--full",
        "--name",
        ".dmp"
      ],
      "raw_values": [
        "* -u *",
        "* --full *",
        "* -f *",
        "* --name *",
        "*.dmp *"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "createdump.exe"
      ],
      "raw_values": [
        "*\\\\createdump.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "fx_ver_internalname_str"
      ],
      "raw_values": [
        "FX_VER_INTERNALNAME_STR"
      ]
    }
  ],
  "raw_query": "any where (process.executable:\"*\\\\createdump.exe\" or process.pe.original_file_name:\"FX_VER_INTERNALNAME_STR\") and (process.command_line like~ (\"* -u *\", \"* --full *\", \"* -f *\", \"* --name *\", \"*.dmp *\"))",

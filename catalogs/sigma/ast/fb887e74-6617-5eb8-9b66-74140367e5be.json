  "id": "fb887e74-6617-5eb8-9b66-74140367e5be",
  "catalog": "sigma",
  "name": "proc_creation_win_createdump_lolbin_execution",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [
    "attack.t1036",
    "attack.t1003.001"

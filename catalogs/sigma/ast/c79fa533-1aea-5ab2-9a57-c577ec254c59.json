{
  "id": "c79fa533-1aea-5ab2-9a57-c577ec254c59",
  "catalog": "sigma",
  "name": "proc_creation_win_mssql_susp_child_process",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [
    "attack.t1505.003",
    "attack.t1190"
  ],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "bash.exe",
        "bitsadmin.exe",
        "cmd.exe",
        "netstat.exe",
        "nltest.exe",
        "ping.exe",
        "powershell.exe",
        "pwsh.exe",
        "regsvr32.exe",
        "rundll32.exe",
        "sh.exe",
        "systeminfo.exe",
        "tasklist.exe",
        "wsl.exe"
      ],
      "raw_values": [
        "*\\\\bash.exe",
        "*\\\\bitsadmin.exe",
        "*\\\\cmd.exe",
        "*\\\\netstat.exe",
        "*\\\\nltest.exe",
        "*\\\\ping.exe",
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe",
        "*\\\\regsvr32.exe",
        "*\\\\rundll32.exe",
        "*\\\\sh.exe",
        "*\\\\systeminfo.exe",
        "*\\\\tasklist.exe",
        "*\\\\wsl.exe"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "sqlservr.exe"
      ],
      "raw_values": [
        "*\\\\sqlservr.exe",
        "C:\\\\Program Files\\\\Microsoft SQL Server\\\\*",
        "*DATEV_DBENGINE\\\\MSSQL\\\\Binn\\\\sqlservr.exe"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "cmd.exe"
      ],
      "raw_values": [
        "C:\\\\Windows\\\\System32\\\\cmd.exe"
      ]
    }
  ],
  "raw_query": "any where (process.parent.executable:\"*\\\\sqlservr.exe\" and (process.executable like~ (\"*\\\\bash.exe\", \"*\\\\bitsadmin.exe\", \"*\\\\cmd.exe\", \"*\\\\netstat.exe\", \"*\\\\nltest.exe\", \"*\\\\ping.exe\", \"*\\\\powershell.exe\", \"*\\\\pwsh.exe\", \"*\\\\regsvr32.exe\", \"*\\\\rundll32.exe\", \"*\\\\sh.exe\", \"*\\\\systeminfo.exe\", \"*\\\\tasklist.exe\", \"*\\\\wsl.exe\"))) and (not (process.parent.executable:\"C:\\\\Program Files\\\\Microsoft SQL Server\\\\*\" and process.parent.executable:\"*DATEV_DBENGINE\\\\MSSQL\\\\Binn\\\\sqlservr.exe\" and process.executable:\"C:\\\\Windows\\\\System32\\\\cmd.exe\" and process.command_line:\"\\\"C:\\\\Windows\\\\system32\\\\cmd.exe\\\" *\"))",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/process_creation/proc_creation_win_mssql_susp_child_process.eql",
  "metadata": {}
}
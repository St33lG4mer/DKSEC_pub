  "name": "proc_creation_win_gup_suspicious_execution",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [],
  "event_categories": [
    "process"
  ],
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "gup.exe"
      ],
      "raw_values": [
        "*\\\\Program Files\\\\Notepad++\\\\updater\\\\GUP.exe",
        "*\\\\AppData\\\\Local\\\\Notepad++\\\\updater\\\\GUP.exe",
        "*\\\\AppData\\\\Roaming\\\\Notepad++\\\\updater\\\\GUP.exe"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "gup.exe"
      ],
      "raw_values": [
        "*\\\\GUP.exe",
        "*\\\\Users\\\\*"
      ]
    }
  ],
  "raw_query": "any where process.executable:\"*\\\\GUP.exe\" and (not ((process.executable like~ (\"*\\\\Program Files\\\\Notepad++\\\\updater\\\\GUP.exe\", \"*\\\\Program Files (x86)\\\\Notepad++\\\\updater\\\\GUP.exe\")) or (process.executable:\"*\\\\Users\\\\*\" and (process.executable like~ (\"*\\\\AppData\\\\Local\\\\Notepad++\\\\updater\\\\GUP.exe\", \"*\\\\AppData\\\\Roaming\\\\Notepad++\\\\updater\\\\GUP.exe\")))))",
  "language": "sigma",

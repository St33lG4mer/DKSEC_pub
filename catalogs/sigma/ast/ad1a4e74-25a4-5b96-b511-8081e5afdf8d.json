  "raw_query": "any where ((process.parent.executable:\"*\\\\ManageEngine\\\\ServiceDesk\\\\*\" and process.parent.executable:\"*\\\\java.exe*\") and (process.executable like~ (\"*\\\\AppVLP.exe\", \"*\\\\bash.exe\", \"*\\\\bitsadmin.exe\", \"*\\\\calc.exe\", \"*\\\\certutil.exe\", \"*\\\\cscript.exe\", \"*\\\\curl.exe\", \"*\\\\forfiles.exe\", \"*\\\\mftrace.exe\", \"*\\\\mshta.exe\", \"*\\\\net.exe\", \"*\\\\net1.exe\", \"*\\\\notepad.exe\", \"*\\\\powershell.exe\", \"*\\\\pwsh.exe\", \"*\\\\query.exe\", \"*\\\\reg.exe\", \"*\\\\schtasks.exe\", \"*\\\\scrcons.exe\", \"*\\\\sh.exe\", \"*\\\\systeminfo.exe\", \"*\\\\whoami.exe\", \"*\\\\wmic.exe\", \"*\\\\wscript.exe\"))) and (not ((process.executable like~ (\"*\\\\net.exe\", \"*\\\\net1.exe\")) and process.command_line:\"* stop*\"))",

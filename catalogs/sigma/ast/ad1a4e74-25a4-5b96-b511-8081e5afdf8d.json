      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "java.exe"
      ],
      "raw_values": [
        "*\\\\ManageEngine\\\\ServiceDesk\\\\*",
        "*\\\\java.exe*"

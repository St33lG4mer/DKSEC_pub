      ],
      "raw_values": [
        "*\\\\AppVLP.exe",
        "*\\\\bash.exe",
        "*\\\\bitsadmin.exe",
        "*\\\\calc.exe",
        "*\\\\certutil.exe",
        "*\\\\cscript.exe",
        "*\\\\curl.exe",
        "*\\\\forfiles.exe",
        "*\\\\mftrace.exe",
        "*\\\\mshta.exe",

        "openssh."
      ],
      "raw_values": [
        "*Add-WindowsCapability*",
        "*OpenSSH.*"
      ]
    }
  ],
  "raw_query": "any where ((process.executable like~ (\"*\\\\powershell.exe\", \"*\\\\pwsh.exe\")) or (process.pe.original_file_name like~ (\"PowerShell.EXE\", \"pwsh.dll\"))) and process.command_line:\"*Add-WindowsCapability*\" and process.command_line:\"*OpenSSH.*\"",

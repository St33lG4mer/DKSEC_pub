{
  "id": "2e69eab7-c6ee-5913-94ed-09920850aed8",
  "catalog": "sigma",
  "name": "registry_set_desktop_background_change",
  "description": "",
  "severity": "medium",
  "mitre_techniques": [
    "attack.t1112",
    "attack.t1491.001"
  ],
  "event_categories": [
    "registry"
  ],
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": "like~",
      "values": [
        "control panel\\\\desktop",
        "currentversion\\\\policies\\\\activedesktop",
        "currentversion\\\\policies\\\\system"
      ],
      "raw_values": [
        "*Control Panel\\\\Desktop*",
        "*CurrentVersion\\\\Policies\\\\ActiveDesktop*",
        "*CurrentVersion\\\\Policies\\\\System*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "ec2launch.exe"
      ],
      "raw_values": [
        "C:\\\\Program Files\\\\Amazon\\\\EC2Launch\\\\EC2Launch.exe"
      ]
    },
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "nochangingwallpaper",
        "\\\\wallpaper",
        "\\\\wallpaperstyle",
        "\\\\control panel\\\\desktop\\\\wallpaper"
      ],
      "raw_values": [
        "*NoChangingWallpaper",
        "*\\\\Wallpaper",
        "*\\\\WallpaperStyle",
        "*\\\\Control Panel\\\\Desktop\\\\Wallpaper"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        "dword (0x00000001)",
        "(empty)"
      ],
      "raw_values": [
        "DWORD (0x00000001)",
        "2",
        "(Empty)"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "svchost.exe",
        "explorer.exe"
      ],
      "raw_values": [
        "*\\\\svchost.exe",
        "*C:\\\\Windows\\\\Explorer.EXE"
      ]
    }
  ],
  "raw_query": "any where (registry.path like~ (\"*Control Panel\\\\Desktop*\", \"*CurrentVersion\\\\Policies\\\\ActiveDesktop*\", \"*CurrentVersion\\\\Policies\\\\System*\")) and ((registry.path:\"*NoChangingWallpaper\" and winlog.event_data.Details:\"DWORD (0x00000001)\") or registry.path:\"*\\\\Wallpaper\" or (registry.path:\"*\\\\WallpaperStyle\" and winlog.event_data.Details:\"2\")) and (not (process.executable:\"*\\\\svchost.exe\" or (registry.path:\"*\\\\Control Panel\\\\Desktop\\\\Wallpaper\" and winlog.event_data.Details:\"(Empty)\") or process.executable:\"*C:\\\\Windows\\\\Explorer.EXE\")) and (not ((process.executable like~ (\"C:\\\\Program Files\\\\Amazon\\\\EC2Launch\\\\EC2Launch.exe\", \"C:\\\\Program Files (x86)\\\\Amazon\\\\EC2Launch\\\\EC2Launch.exe\")) and registry.path:\"*\\\\Control Panel\\\\Desktop\\\\Wallpaper\"))",
  "language": "sigma",
  "translated_query": null,
  "source_path": "rules/windows/registry/registry_set/registry_set_desktop_background_change.eql",
  "metadata": {}
}
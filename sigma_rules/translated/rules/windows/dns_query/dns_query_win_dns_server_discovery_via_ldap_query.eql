any where dns.question.name:"_ldap.*" and (not ((process.executable like~ ("*:\\Program Files\\*", "*:\\Program Files (x86)\\*", "*:\\Windows\\*")) or (process.executable:"*:\\ProgramData\\Microsoft\\Windows Defender\\Platform\\*" and process.executable:"*\\MsMpEng.exe") or process.executable:"<unknown process>" or (?process.executable == null))) and (not (process.executable:"C:\\WindowsAzure\\GuestAgent*" or (process.executable like~ ("*\\chrome.exe", "*\\firefox.exe", "*\\opera.exe"))))
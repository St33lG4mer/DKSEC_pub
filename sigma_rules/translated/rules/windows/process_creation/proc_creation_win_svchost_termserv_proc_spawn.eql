any where (process.parent.command_line:"*\\svchost.exe*" and process.parent.command_line:"*termsvcs*") and (not ((process.executable like~ ("*\\rdpclip.exe", "*:\\Windows\\System32\\csrss.exe", "*:\\Windows\\System32\\wininit.exe", "*:\\Windows\\System32\\winlogon.exe")) or (?process.executable == null)))
any where (((process.executable:"*\\reg.exe" or process.pe.original_file_name:"reg.exe") and process.command_line:"*add*") or (((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) or (process.pe.original_file_name like~ ("powershell.exe", "pwsh.dll"))) and (process.command_line like~ ("*New-ItemProperty*", "*Set-ItemProperty*", "*ni *", "*sp *")))) and process.command_line:"*\\ms-settings\\shell\\open\\command*"
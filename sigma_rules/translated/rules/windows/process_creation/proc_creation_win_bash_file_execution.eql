any where ((process.executable like~ ("*:\\Windows\\System32\\bash.exe", "*:\\Windows\\SysWOW64\\bash.exe")) or process.pe.original_file_name:"Bash.exe") and (not ((process.command_line like~ ("*bash.exe -*", "*bash -*")) or (?process.command_line == null) or process.command_line=="" or (process.command_line like~ ("bash.exe", "bash"))))
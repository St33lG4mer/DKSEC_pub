any where (process.command_line like~ ("*\\TrolleyExpress 7*", "*\\TrolleyExpress 8*", "*\\TrolleyExpress 9*", "*\\TrolleyExpress.exe 7*", "*\\TrolleyExpress.exe 8*", "*\\TrolleyExpress.exe 9*", "*\\TrolleyExpress.exe -ma *")) or (process.executable:"*\\TrolleyExpress.exe" and (not (process.pe.original_file_name:"*CtxInstall*" or (?process.pe.original_file_name == null))))
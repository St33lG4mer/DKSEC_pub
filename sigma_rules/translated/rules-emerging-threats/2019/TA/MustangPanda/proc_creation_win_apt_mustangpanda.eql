any where ((process.command_line like~ ("*Temp\\wtask.exe /create*", "*%windir:~-3,1%%PUBLIC:~-9,1%*", "*/tn \"Security Script *", "*%windir:~-1,1%*")) or (process.command_line:"*/E:vbscript*" and process.command_line:"*C:\\Users\\*" and process.command_line:"*.txt*" and process.command_line:"*/F*")) or process.executable:"*Temp\\winwsh.exe"
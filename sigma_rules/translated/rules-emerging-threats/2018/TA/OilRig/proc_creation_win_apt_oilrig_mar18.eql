any where (process.command_line:"*SC Scheduled Scan*" and process.command_line:"*\\microsoft\\Taskbar\\autoit3.exe*") or (process.executable:"*\\Windows\\Temp\\DB\\*" and process.executable:"*.exe") or (process.executable:"C:\\Windows\\system32\\Service.exe" and (process.command_line like~ ("*i*", "*u*"))) or (process.parent.executable:"*\\local\\microsoft\\Taskbar\\autoit3.exe" and (process.command_line:"*nslookup.exe*" and process.command_line:"*-q=TXT*"))
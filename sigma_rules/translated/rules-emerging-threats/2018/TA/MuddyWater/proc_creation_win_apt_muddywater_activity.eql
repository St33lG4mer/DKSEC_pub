any where (process.command_line:"*vbscript:Close(Execute(\"CreateObject(*" and process.command_line:"*powershell*" and process.command_line:"*-w 1 -exec Bypass*" and process.command_line:"*\\ProgramData\\*") or (process.command_line:"*Win32_OperatingSystem*" and process.command_line:"*Win32_NetworkAdapterConfiguration*" and process.command_line:"*root\\SecurityCenter2*" and process.command_line:"*[System.Net.DNS]*") or (process.command_line:"*[Convert]::ToBase64String*" and process.command_line:"*[System.Text.Encoding]::UTF8.GetString]*" and process.command_line:"*GetResponse().GetResponseStream()*" and process.command_line:"*[System.Net.HttpWebRequest]::Create(*" and process.command_line:"*-bxor *")
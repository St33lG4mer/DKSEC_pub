any where (process.executable:"*\\dllhost.exe" and network.direction:"true") and (not ((cidrMatch(destination.ip, "::1/128") or cidrMatch(destination.ip, "10.0.0.0/8") or cidrMatch(destination.ip, "127.0.0.0/8") or cidrMatch(destination.ip, "172.16.0.0/12") or cidrMatch(destination.ip, "192.168.0.0/16") or cidrMatch(destination.ip, "169.254.0.0/16") or cidrMatch(destination.ip, "fc00::/7") or cidrMatch(destination.ip, "fe80::/10")) or (cidrMatch(destination.ip, "20.184.0.0/13") or cidrMatch(destination.ip, "20.192.0.0/10") or cidrMatch(destination.ip, "23.72.0.0/13") or cidrMatch(destination.ip, "51.10.0.0/15") or cidrMatch(destination.ip, "51.103.0.0/16") or cidrMatch(destination.ip, "51.104.0.0/15") or cidrMatch(destination.ip, "52.224.0.0/11") or cidrMatch(destination.ip, "150.171.0.0/19") or cidrMatch(destination.ip, "204.79.197.0/24"))))
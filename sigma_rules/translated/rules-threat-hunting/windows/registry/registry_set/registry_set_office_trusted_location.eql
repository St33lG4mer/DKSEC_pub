any where (registry.path:"*Security\\Trusted Locations\\Location*" and registry.path:"*\\Path") and (not ((process.executable:"*:\\Program Files\\Common Files\\Microsoft Shared\\ClickToRun\\*" and process.executable:"*\\OfficeClickToRun.exe") or (process.executable like~ ("*:\\Program Files\\Microsoft Office\\*", "*:\\Program Files (x86)\\Microsoft Office\\*"))))
any where ((registry.path:"*ControlSet*" and registry.path:"*\\Services\\*") and registry.path:"*\\ImagePath" and (winlog.event_data.Details like~ ("*:\\ProgramData\\*", "*\\AppData\\Local\\*", "*\\AppData\\Roaming\\*"))) and (not ((registry.path like~ ("*\\Services\\WinDefend\\*", "*\\Services\\MpKs*")) and winlog.event_data.Details:"*C:\\ProgramData\\Microsoft\\Windows Defender\\*")) and (not ((registry.path:"*\\Services\\ZoomCptService*" and winlog.event_data.Details:"*C:\\Program Files\\Common Files\\Zoom\\Support\\CptService.exe*") or (registry.path:"*\\Services\\MBAMInstallerService*" and (winlog.event_data.Details:"*C:\\Users\\*" and winlog.event_data.Details:"*AppData\\Local\\Temp\\MBAMInstallerService.exe*"))))
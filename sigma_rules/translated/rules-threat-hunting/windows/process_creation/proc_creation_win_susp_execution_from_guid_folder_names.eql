any where ((process.command_line like~ ("*\\AppData\\Roaming\\*", "*\\AppData\\Local\\Temp\\*")) and (process.command_line:"*\\{*" and process.command_line:"*}\\*")) and (not ((process.executable:"*\\{*" and process.executable:"*}\\*") or (?process.executable == null) or process.executable:"C:\\Windows\\System32\\drvinst.exe" or (process.executable like~ ("C:\\Windows\\System32\\msiexec.exe", "C:\\Windows\\SysWOW64\\msiexec.exe"))))
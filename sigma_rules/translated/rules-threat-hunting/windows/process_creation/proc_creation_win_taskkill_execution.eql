any where ((process.executable:"*\\taskkill.exe" or process.pe.original_file_name:"taskkill.exe") and (process.command_line like~ ("* -f *", "* /f *", "* –f *", "* —f *", "* ―f *") or process.command_line like~ ("* -f", "* /f", "* –f", "* —f", "* ―f")) and (process.command_line like~ ("* -im *", "* /im *", "* –im *", "* —im *", "* ―im *") or process.command_line like~ ("* -pid *", "* /pid *", "* –pid *", "* —pid *", "* ―pid *"))) and (not ((process.parent.executable like~ ("*\\AppData\\Local\\Temp\\*", "*:\\Windows\\Temp*")) and process.parent.executable:"*.tmp"))
any where ((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) or (process.pe.original_file_name like~ ("PowerShell.EXE", "pwsh.dll"))) and process.command_line:"*System.Security.Cryptography.*" and (process.command_line like~ ("*.AesCryptoServiceProvider*", "*.DESCryptoServiceProvider*", "*.DSACryptoServiceProvider*", "*.RC2CryptoServiceProvider*", "*.Rijndael*", "*.RSACryptoServiceProvider*", "*.TripleDESCryptoServiceProvider*"))
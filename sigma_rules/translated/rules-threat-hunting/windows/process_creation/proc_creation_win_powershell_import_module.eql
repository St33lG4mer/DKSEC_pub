any where (((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) or (process.pe.original_file_name like~ ("PowerShell.EXE", "pwsh.dll"))) and (process.command_line like~ ("*Import-Module *", "*ipmo *"))) and (not ((process.parent.executable like~ ("*:\\Program Files\\WindowsApps\\Microsoft.WindowsTerminal_*", "*:\\Windows\\System32\\cmd.exe*")) and (process.command_line:"*:\\Program Files\\Microsoft Visual Studio\\*" and process.command_line:"*Tools\\Microsoft.VisualStudio.DevShell.dll*")))
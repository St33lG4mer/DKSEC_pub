any where ((process.executable:"*\\regsvr32.exe" or process.pe.original_file_name:"REGSVR32.EXE") and (process.command_line like~ ("* /s *", "* /e *"))) and (not (((process.command_line like~ ("*:\\Program Files (x86)*", "*:\\Program Files\\*", "*:\\Windows\\System32\\*", "*:\\Windows\\SysWOW64\\*")) or (process.working_directory like~ ("*:\\Program Files (x86)*", "*:\\Program Files\\*", "*:\\Windows\\System32\\*", "*:\\Windows\\SysWOW64\\*"))) or (process.command_line like~ ("* /i:*", "*/U *")) or (process.parent.command_line:"*:\\Windows\\System32\\RpcProxy\\RpcProxy.dll" and process.command_line:"regsvr32 /s rpcproxy.dll")))
any where ((process.pe.description:"WMI Commandline Utility" or process.pe.original_file_name:"wmic.exe" or process.executable:"*\\WMIC.exe") and process.command_line:"*get*" and (process.command_line like~ ("*baseboard*", "*bios*", "*cpu*", "*diskdrive*", "*logicaldisk*", "*memphysical*", "*os*", "*path*", "*startup*", "*win32_videocontroller*")) and (process.command_line like~ ("*caption*", "*command*", "*driverversion*", "*maxcapacity*", "*name*", "*osarchitecture*", "*product*", "*size*", "*smbiosbiosversion*", "*version*", "*videomodedescription*"))) and (not process.parent.command_line:"*\\VMware\\VMware Tools\\serviceDiscovery\\scripts\\*")
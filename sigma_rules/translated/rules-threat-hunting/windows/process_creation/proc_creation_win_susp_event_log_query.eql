any where (process.command_line:"*Select*" and process.command_line:"*Win32_NTLogEvent*") or ((process.executable:"*\\wevtutil.exe" or process.pe.original_file_name:"wevtutil.exe") and (process.command_line like~ ("* qe *", "* query-events *"))) or ((process.executable:"*\\wmic.exe" or process.pe.original_file_name:"wmic.exe") and process.command_line:"* ntevent*") or (process.command_line like~ ("*Get-WinEvent *", "*get-eventlog *"))
any where ((process.executable:"*\\rundll32.exe" or process.pe.original_file_name:"RUNDLL32.EXE") and (process.command_line like~ ("*,#*", "*, #*", "*.dll #*", "*.ocx #*"))) and (not ((process.command_line:"*EDGEHTML.dll*" and process.command_line:"*#141*") or ((process.parent.executable like~ ("*\\Msbuild\\Current\\Bin\\*", "*\\VC\\Tools\\MSVC\\*", "*\\Tracker.exe*")) and (process.command_line like~ ("*\\FileTracker32.dll,#1*", "*\\FileTracker32.dll\",#1*", "*\\FileTracker64.dll,#1*", "*\\FileTracker64.dll\",#1*")))))
any where ((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) or (process.pe.original_file_name like~ ("PowerShell.EXE", "pwsh.dll")) or process.pe.description:"Windows Powershell" or process.pe.product:"PowerShell Core 6") and process.command_line:"SigmaRegularExpression(regexp=SigmaString(['.{1000,}']), flags=set())"
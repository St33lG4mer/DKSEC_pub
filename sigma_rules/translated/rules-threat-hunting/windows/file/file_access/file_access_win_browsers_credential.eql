any where (file.path:"*\\Appdata\\Local\\Microsoft\\Windows\\WebCache\\WebCacheV01.dat" or (file.path like~ ("*\\cookies.sqlite", "*\\places.sqlite", "*release\\key3.db", "*release\\key4.db", "*release\\logins.json")) or (file.path like~ ("*\\User Data\\Default\\Login Data*", "*\\User Data\\Local State*"))) and (not (process.executable:"System" or (process.executable like~ ("C:\\Program Files (x86)\\*", "C:\\Program Files\\*", "C:\\Windows\\system32\\*", "C:\\Windows\\SysWOW64\\*")))) and (not ((process.executable:"C:\\ProgramData\\Microsoft\\Windows Defender\\*" and (process.executable like~ ("*\\MpCopyAccelerator.exe", "*\\MsMpEng.exe"))) or (process.executable like~ ("*\\thor.exe", "*\\thor64.exe"))))
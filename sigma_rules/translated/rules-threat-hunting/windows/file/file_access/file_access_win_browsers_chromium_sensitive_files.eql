any where (file.path like~ ("*\\User Data\\Default\\Cookies*", "*\\User Data\\Default\\History*", "*\\User Data\\Default\\Network\\Cookies*", "*\\User Data\\Default\\Web Data*")) and (not (process.executable:"System" or (process.executable like~ ("C:\\Program Files (x86)\\*", "C:\\Program Files\\*", "C:\\Windows\\system32\\*", "C:\\Windows\\SysWOW64\\*")))) and (not (process.executable:"C:\\ProgramData\\Microsoft\\Windows Defender\\*" and (process.executable like~ ("*\\MpCopyAccelerator.exe", "*\\MsMpEng.exe"))))
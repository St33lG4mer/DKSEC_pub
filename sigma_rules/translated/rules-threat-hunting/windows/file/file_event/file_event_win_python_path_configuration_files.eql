any where (file.path:"SigmaRegularExpression(regexp=SigmaString(['(', <SpecialChars.WILDCARD_SINGLE: 2>, 'i)\\\\(venv|python(.+)', <SpecialChars.WILDCARD_SINGLE: 2>, ')\\\\lib\\\\site-packages\\\\']), flags=set())" and file.path:"*.pth") and (not (process.executable:"*\\python.exe" and (file.path like~ ("*\\pywin32.pth", "*\\distutils-precedence.pth"))))
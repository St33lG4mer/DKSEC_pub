any where ((file.path like~ ("*\\dbghelp.dll", "*\\dbgcore.dll")) and (process.executable like~ ("*\\bash.exe", "*\\cmd.exe", "*\\cscript.exe", "*\\dnx.exe", "*\\excel.exe", "*\\monitoringhost.exe", "*\\msbuild.exe", "*\\mshta.exe", "*\\outlook.exe", "*\\powerpnt.exe", "*\\regsvcs.exe", "*\\rundll32.exe", "*\\sc.exe", "*\\scriptrunner.exe", "*\\winword.exe", "*\\wmic.exe", "*\\wscript.exe"))) and (not ((winlog.event_data.CommandLine:"C:\\WINDOWS\\WinSxS\\*" and winlog.event_data.CommandLine:"*\\TiWorker.exe -Embedding") or (process.executable:"*\\svchost.exe" and (winlog.event_data.CommandLine like~ ("*-k LocalServiceNetworkRestricted", "*-k WerSvcGroup"))) or (process.executable:"*\\rundll32.exe" and (winlog.event_data.CommandLine like~ ("*/d srrstr.dll,ExecuteScheduledSPPCreation*", "*aepdu.dll,AePduRunUpdate*", "*shell32.dll,OpenAs_RunDL*", "*Windows.Storage.ApplicationData.dll,CleanupTemporaryState*")))))
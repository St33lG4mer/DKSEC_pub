{
  "source": "sigma",
  "name": "proc_creation_win_sc_create_service",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_sc_create_service.eql",
  "raw_query": "any where (process.executable:\"*\\\\sc.exe\" and (process.command_line:\"*create*\" and process.command_line:\"*binPath*\")) and (not ((process.parent.executable like~ (\"C:\\\\Program Files (x86)\\\\Dropbox\\\\Client\\\\*\", \"C:\\\\Program Files\\\\Dropbox\\\\Client\\\\*\")) and process.parent.executable:\"*\\\\Dropbox.exe\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "sc.exe"
      ],
      "raw_values": [
        "*\\\\sc.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "create",
        "binpath"
      ],
      "raw_values": [
        "*create*",
        "*binPath*"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "dropbox.exe"
      ],
      "raw_values": [
        "*\\\\Dropbox.exe"
      ]
    }
  ]
}
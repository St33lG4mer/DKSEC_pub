{
  "source": "sigma",
  "name": "registry_set_clickonce_trust_prompt",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_clickonce_trust_prompt.eql",
  "raw_query": "any where registry.path:\"*\\\\SOFTWARE\\\\MICROSOFT\\\\.NETFramework\\\\Security\\\\TrustManager\\\\PromptingLevel\\\\*\" and (registry.path like~ (\"*\\\\Internet\", \"*\\\\LocalIntranet\", \"*\\\\MyComputer\", \"*\\\\TrustedSites\", \"*\\\\UntrustedSites\")) and winlog.event_data.Details:\"Enabled\"",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": "like~",
      "values": [
        "\\\\internet",
        "\\\\localintranet",
        "\\\\mycomputer",
        "\\\\trustedsites",
        "\\\\untrustedsites"
      ],
      "raw_values": [
        "*\\\\Internet",
        "*\\\\LocalIntranet",
        "*\\\\MyComputer",
        "*\\\\TrustedSites",
        "*\\\\UntrustedSites"
      ]
    },
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\software\\\\microsoft\\\\.netframework\\\\security\\\\trustmanager\\\\promptinglevel\\\\"
      ],
      "raw_values": [
        "*\\\\SOFTWARE\\\\MICROSOFT\\\\.NETFramework\\\\Security\\\\TrustManager\\\\PromptingLevel\\\\*"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        "enabled"
      ],
      "raw_values": [
        "Enabled"
      ]
    }
  ]
}
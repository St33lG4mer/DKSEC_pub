{
  "source": "sigma",
  "name": "file_event_win_vscode_tunnel_renamed_execution",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_vscode_tunnel_renamed_execution.eql",
  "raw_query": "any where file.path:\"*\\\\code_tunnel.json\" and (not (process.executable like~ (\"*\\\\code-tunnel.exe\", \"*\\\\code.exe\")))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "code-tunnel.exe",
        "code.exe"
      ],
      "raw_values": [
        "*\\\\code-tunnel.exe",
        "*\\\\code.exe"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        "code_tunnel.json"
      ],
      "raw_values": [
        "*\\\\code_tunnel.json"
      ]
    }
  ]
}
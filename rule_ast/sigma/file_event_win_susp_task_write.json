{
  "source": "sigma",
  "name": "file_event_win_susp_task_write",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_susp_task_write.eql",
  "raw_query": "any where file.path:\"*\\\\Windows\\\\System32\\\\Tasks*\" and (process.executable like~ (\"*\\\\AppData\\\\*\", \"*C:\\\\PerfLogs*\", \"*\\\\Windows\\\\System32\\\\config\\\\systemprofile*\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "perflogs",
        "systemprofile"
      ],
      "raw_values": [
        "*\\\\AppData\\\\*",
        "*C:\\\\PerfLogs*",
        "*\\\\Windows\\\\System32\\\\config\\\\systemprofile*"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        "tasks"
      ],
      "raw_values": [
        "*\\\\Windows\\\\System32\\\\Tasks*"
      ]
    }
  ]
}
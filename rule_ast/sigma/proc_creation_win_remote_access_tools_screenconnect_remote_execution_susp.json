{
  "source": "sigma",
  "name": "proc_creation_win_remote_access_tools_screenconnect_remote_execution_susp",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_remote_access_tools_screenconnect_remote_execution_susp.eql",
  "raw_query": "any where (process.parent.command_line:\"*:\\\\Windows\\\\TEMP\\\\ScreenConnect\\\\*\" and process.parent.command_line:\"*run.cmd*\") and (process.executable like~ (\"*\\\\bitsadmin.exe\", \"*\\\\cmd.exe\", \"*\\\\curl.exe\", \"*\\\\dllhost.exe\", \"*\\\\net.exe\", \"*\\\\nltest.exe\", \"*\\\\powershell.exe\", \"*\\\\pwsh.exe\", \"*\\\\rundll32.exe\", \"*\\\\wevtutil.exe\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "bitsadmin.exe",
        "cmd.exe",
        "curl.exe",
        "dllhost.exe",
        "net.exe",
        "nltest.exe",
        "powershell.exe",
        "pwsh.exe",
        "rundll32.exe",
        "wevtutil.exe"
      ],
      "raw_values": [
        "*\\\\bitsadmin.exe",
        "*\\\\cmd.exe",
        "*\\\\curl.exe",
        "*\\\\dllhost.exe",
        "*\\\\net.exe",
        "*\\\\nltest.exe",
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe",
        "*\\\\rundll32.exe",
        "*\\\\wevtutil.exe"
      ]
    },
    {
      "field": "process.parent.command_line",
      "raw_field": "process.parent.command_line",
      "operator": ":",
      "values": [
        "run.cmd"
      ],
      "raw_values": [
        "*:\\\\Windows\\\\TEMP\\\\ScreenConnect\\\\*",
        "*run.cmd*"
      ]
    }
  ]
}
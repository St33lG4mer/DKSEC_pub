{
  "source": "sigma",
  "name": "proc_creation_win_office_arbitrary_cli_download",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_office_arbitrary_cli_download.eql",
  "raw_query": "any where ((process.executable like~ (\"*\\\\EXCEL.EXE\", \"*\\\\POWERPNT.EXE\", \"*\\\\WINWORD.exe\")) or (process.pe.original_file_name like~ (\"Excel.exe\", \"POWERPNT.EXE\", \"WinWord.exe\"))) and (process.command_line like~ (\"*http://*\", \"*https://*\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "excel.exe",
        "powerpnt.exe",
        "winword.exe"
      ],
      "raw_values": [
        "*\\\\EXCEL.EXE",
        "*\\\\POWERPNT.EXE",
        "*\\\\WINWORD.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": "like~",
      "values": [
        "excel.exe",
        "powerpnt.exe",
        "winword.exe"
      ],
      "raw_values": [
        "Excel.exe",
        "POWERPNT.EXE",
        "WinWord.exe"
      ]
    }
  ]
}
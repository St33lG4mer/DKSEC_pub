{
  "source": "sigma",
  "name": "proc_creation_win_wmic_recon_product_class",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_wmic_recon_product_class.eql",
  "raw_query": "any where (process.executable:\"*\\\\wmic.exe\" or process.pe.original_file_name:\"wmic.exe\") and (process.command_line like~ (\"*AntiVirusProduct*\", \"*AntiSpywareProduct*\", \"*FirewallProduct*\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "antivirusproduct",
        "antispywareproduct",
        "firewallproduct"
      ],
      "raw_values": [
        "*AntiVirusProduct*",
        "*AntiSpywareProduct*",
        "*FirewallProduct*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "wmic.exe"
      ],
      "raw_values": [
        "*\\\\wmic.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "wmic.exe"
      ],
      "raw_values": [
        "wmic.exe"
      ]
    }
  ]
}
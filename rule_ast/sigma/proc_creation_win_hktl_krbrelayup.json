{
  "source": "sigma",
  "name": "proc_creation_win_hktl_krbrelayup",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_hktl_krbrelayup.eql",
  "raw_query": "any where (process.executable:\"*\\\\KrbRelayUp.exe\" or process.pe.original_file_name:\"KrbRelayUp.exe\") or (process.command_line:\"* relay *\" and process.command_line:\"* -Domain *\" and process.command_line:\"* -ComputerName *\") or (process.command_line:\"* krbscm *\" and process.command_line:\"* -sc *\") or (process.command_line:\"* spawn *\" and process.command_line:\"* -d *\" and process.command_line:\"* -cn *\" and process.command_line:\"* -cp *\")",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "krbrelayup.exe"
      ],
      "raw_values": [
        "*\\\\KrbRelayUp.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "krbrelayup.exe"
      ],
      "raw_values": [
        "KrbRelayUp.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "relay",
        "-domain",
        "-computername",
        "krbscm",
        "-sc",
        "spawn",
        "-cn",
        "-cp"
      ],
      "raw_values": [
        "* relay *",
        "* -Domain *",
        "* -ComputerName *",
        "* krbscm *",
        "* -sc *",
        "* spawn *",
        "* -d *",
        "* -cn *",
        "* -cp *"
      ]
    }
  ]
}
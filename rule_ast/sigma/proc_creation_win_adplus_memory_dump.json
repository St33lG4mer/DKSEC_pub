{
  "source": "sigma",
  "name": "proc_creation_win_adplus_memory_dump",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_adplus_memory_dump.eql",
  "raw_query": "any where (process.executable:\"*\\\\adplus.exe\" or process.pe.original_file_name:\"Adplus.exe\") and (process.command_line like~ (\"* -hang *\", \"* -pn *\", \"* -pmn *\", \"* -p *\", \"* -po *\", \"* -c *\", \"* -sc *\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "-hang",
        "-pn",
        "-pmn",
        "-po",
        "-sc"
      ],
      "raw_values": [
        "* -hang *",
        "* -pn *",
        "* -pmn *",
        "* -p *",
        "* -po *",
        "* -c *",
        "* -sc *"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "adplus.exe"
      ],
      "raw_values": [
        "*\\\\adplus.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "adplus.exe"
      ],
      "raw_values": [
        "Adplus.exe"
      ]
    }
  ]
}
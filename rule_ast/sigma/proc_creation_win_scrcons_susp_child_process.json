{
  "source": "sigma",
  "name": "proc_creation_win_scrcons_susp_child_process",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_scrcons_susp_child_process.eql",
  "raw_query": "any where process.parent.executable:\"*\\\\scrcons.exe\" and (process.executable like~ (\"*\\\\svchost.exe\", \"*\\\\dllhost.exe\", \"*\\\\powershell.exe\", \"*\\\\pwsh.exe\", \"*\\\\wscript.exe\", \"*\\\\cscript.exe\", \"*\\\\schtasks.exe\", \"*\\\\regsvr32.exe\", \"*\\\\mshta.exe\", \"*\\\\rundll32.exe\", \"*\\\\msiexec.exe\", \"*\\\\msbuild.exe\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "svchost.exe",
        "dllhost.exe",
        "powershell.exe",
        "pwsh.exe",
        "wscript.exe",
        "cscript.exe",
        "schtasks.exe",
        "regsvr32.exe",
        "mshta.exe",
        "rundll32.exe",
        "msiexec.exe",
        "msbuild.exe"
      ],
      "raw_values": [
        "*\\\\svchost.exe",
        "*\\\\dllhost.exe",
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe",
        "*\\\\wscript.exe",
        "*\\\\cscript.exe",
        "*\\\\schtasks.exe",
        "*\\\\regsvr32.exe",
        "*\\\\mshta.exe",
        "*\\\\rundll32.exe",
        "*\\\\msiexec.exe",
        "*\\\\msbuild.exe"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "scrcons.exe"
      ],
      "raw_values": [
        "*\\\\scrcons.exe"
      ]
    }
  ]
}
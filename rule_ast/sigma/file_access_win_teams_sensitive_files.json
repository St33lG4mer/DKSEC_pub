{
  "source": "sigma",
  "name": "file_access_win_teams_sensitive_files",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_access/file_access_win_teams_sensitive_files.eql",
  "raw_query": "any where (file.path like~ (\"*\\\\Microsoft\\\\Teams\\\\Cookies*\", \"*\\\\Microsoft\\\\Teams\\\\Local Storage\\\\leveldb*\")) and (not process.executable:\"*\\\\Microsoft\\\\Teams\\\\current\\\\Teams.exe\")",
  "conditions": [
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": "like~",
      "values": [
        "cookies",
        "leveldb"
      ],
      "raw_values": [
        "*\\\\Microsoft\\\\Teams\\\\Cookies*",
        "*\\\\Microsoft\\\\Teams\\\\Local Storage\\\\leveldb*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "teams.exe"
      ],
      "raw_values": [
        "*\\\\Microsoft\\\\Teams\\\\current\\\\Teams.exe"
      ]
    }
  ]
}
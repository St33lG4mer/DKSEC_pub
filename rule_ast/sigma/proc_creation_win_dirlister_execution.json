{
  "source": "sigma",
  "name": "proc_creation_win_dirlister_execution",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_dirlister_execution.eql",
  "raw_query": "any where process.pe.original_file_name:\"DirLister.exe\" or process.executable:\"*\\\\DirLister.exe\"",
  "conditions": [
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "dirlister.exe"
      ],
      "raw_values": [
        "DirLister.exe"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "dirlister.exe"
      ],
      "raw_values": [
        "*\\\\DirLister.exe"
      ]
    }
  ]
}
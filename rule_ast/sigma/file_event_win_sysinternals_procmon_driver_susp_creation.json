{
  "source": "sigma",
  "name": "file_event_win_sysinternals_procmon_driver_susp_creation",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_sysinternals_procmon_driver_susp_creation.eql",
  "raw_query": "any where (file.path:\"*\\\\procmon*\" and file.path:\"*.sys\") and (not (process.executable like~ (\"*\\\\procmon.exe\", \"*\\\\procmon64.exe\")))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "procmon.exe",
        "procmon64.exe"
      ],
      "raw_values": [
        "*\\\\procmon.exe",
        "*\\\\procmon64.exe"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        "procmon",
        ".sys"
      ],
      "raw_values": [
        "*\\\\procmon*",
        "*.sys"
      ]
    }
  ]
}
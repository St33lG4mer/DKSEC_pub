{
  "source": "sigma",
  "name": "file_event_win_uac_bypass_wmp",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_uac_bypass_wmp.eql",
  "raw_query": "any where (file.path:\"C:\\\\Users\\\\*\" and file.path:\"*\\\\AppData\\\\Local\\\\Temp\\\\OskSupport.dll\") or (process.executable:\"C:\\\\Windows\\\\system32\\\\DllHost.exe\" and file.path:\"C:\\\\Program Files\\\\Windows Media Player\\\\osk.exe\")",
  "conditions": [
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        "osksupport.dll",
        "osk.exe"
      ],
      "raw_values": [
        "C:\\\\Users\\\\*",
        "*\\\\AppData\\\\Local\\\\Temp\\\\OskSupport.dll",
        "C:\\\\Program Files\\\\Windows Media Player\\\\osk.exe"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "dllhost.exe"
      ],
      "raw_values": [
        "C:\\\\Windows\\\\system32\\\\DllHost.exe"
      ]
    }
  ]
}
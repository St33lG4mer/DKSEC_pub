{
  "source": "sigma",
  "name": "proc_creation_win_sysinternals_procdump_evasion",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_sysinternals_procdump_evasion.eql",
  "raw_query": "any where (process.command_line like~ (\"*copy procdump*\", \"*move procdump*\")) or ((process.command_line:\"*copy *\" and process.command_line:\"*.dmp *\") and (process.command_line like~ (\"*2.dmp*\", \"*lsass*\", \"*out.dmp*\"))) or (process.command_line like~ (\"*copy lsass.exe_*\", \"*move lsass.exe_*\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "copy procdump",
        "move procdump",
        "2.dmp",
        "lsass",
        "out.dmp",
        "copy lsass.exe_",
        "move lsass.exe_"
      ],
      "raw_values": [
        "*copy procdump*",
        "*move procdump*",
        "*2.dmp*",
        "*lsass*",
        "*out.dmp*",
        "*copy lsass.exe_*",
        "*move lsass.exe_*"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "copy",
        ".dmp"
      ],
      "raw_values": [
        "*copy *",
        "*.dmp *"
      ]
    }
  ]
}
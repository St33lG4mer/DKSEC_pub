{
  "source": "sigma",
  "name": "proc_creation_win_sysinternals_psexec_remote_execution",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_sysinternals_psexec_remote_execution.eql",
  "raw_query": "any where (process.command_line:\"*accepteula*\" and process.command_line:\"* -u *\" and process.command_line:\"* -p *\" and process.command_line:\"* \\\\\\\\*\") and (not (process.command_line like~ (\"*\\\\\\\\localhost*\", \"*\\\\\\\\127.*\")))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "localhost",
        "127."
      ],
      "raw_values": [
        "*\\\\\\\\localhost*",
        "*\\\\\\\\127.*"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "accepteula"
      ],
      "raw_values": [
        "*accepteula*",
        "* -u *",
        "* -p *",
        "* \\\\\\\\*"
      ]
    }
  ]
}
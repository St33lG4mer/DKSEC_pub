{
  "source": "sigma",
  "name": "proc_creation_win_reg_delete_services",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_reg_delete_services.eql",
  "raw_query": "any where (process.executable:\"*reg.exe\" or process.pe.original_file_name:\"reg.exe\") and process.command_line:\"* delete *\" and process.command_line:\"*\\\\SYSTEM\\\\CurrentControlSet\\\\services\\\\*\"",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "reg.exe"
      ],
      "raw_values": [
        "*reg.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "reg.exe"
      ],
      "raw_values": [
        "reg.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "delete"
      ],
      "raw_values": [
        "* delete *",
        "*\\\\SYSTEM\\\\CurrentControlSet\\\\services\\\\*"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "image_load_side_load_appverifui",
  "subtree": "rules",
  "category": "library",
  "sigma_path": "rules/windows/image_load/image_load_side_load_appverifui.eql",
  "raw_query": "any where file.path:\"*\\\\appverifUI.dll\" and (not ((process.executable like~ (\"C:\\\\Windows\\\\SysWOW64\\\\appverif.exe\", \"C:\\\\Windows\\\\System32\\\\appverif.exe\")) and (file.path like~ (\"C:\\\\Windows\\\\System32\\\\*\", \"C:\\\\Windows\\\\SysWOW64\\\\*\", \"C:\\\\Windows\\\\WinSxS\\\\*\"))))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "appverif.exe"
      ],
      "raw_values": [
        "C:\\\\Windows\\\\SysWOW64\\\\appverif.exe",
        "C:\\\\Windows\\\\System32\\\\appverif.exe"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        "appverifui.dll"
      ],
      "raw_values": [
        "*\\\\appverifUI.dll"
      ]
    }
  ]
}
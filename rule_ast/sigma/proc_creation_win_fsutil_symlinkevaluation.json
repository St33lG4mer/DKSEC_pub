{
  "source": "sigma",
  "name": "proc_creation_win_fsutil_symlinkevaluation",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_fsutil_symlinkevaluation.eql",
  "raw_query": "any where ((process.executable like~ (\"*\\\\cmd.exe\", \"*\\\\powershell.exe\", \"*\\\\pwsh.exe\")) or (process.pe.original_file_name like~ (\"Cmd.Exe\", \"PowerShell.EXE\", \"pwsh.dll\"))) and (process.command_line:\"*fsutil*\" and process.command_line:\"*behavior*\" and process.command_line:\"*set*\" and process.command_line:\"*SymlinkEvaluation*\") and (process.command_line like~ (\"*R2L:1*\", \"*R2R:1*\", \"*L2L:1*\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "cmd.exe",
        "powershell.exe",
        "pwsh.exe"
      ],
      "raw_values": [
        "*\\\\cmd.exe",
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": "like~",
      "values": [
        "cmd.exe",
        "powershell.exe",
        "pwsh.dll"
      ],
      "raw_values": [
        "Cmd.Exe",
        "PowerShell.EXE",
        "pwsh.dll"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "r2l:1",
        "r2r:1",
        "l2l:1"
      ],
      "raw_values": [
        "*R2L:1*",
        "*R2R:1*",
        "*L2L:1*"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "fsutil",
        "behavior",
        "set",
        "symlinkevaluation"
      ],
      "raw_values": [
        "*fsutil*",
        "*behavior*",
        "*set*",
        "*SymlinkEvaluation*"
      ]
    }
  ]
}
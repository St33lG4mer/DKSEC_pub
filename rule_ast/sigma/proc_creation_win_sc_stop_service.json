{
  "source": "sigma",
  "name": "proc_creation_win_sc_stop_service",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_sc_stop_service.eql",
  "raw_query": "any where (process.pe.original_file_name:\"sc.exe\" or process.executable:\"*\\\\sc.exe\") and process.command_line:\"* stop *\"",
  "conditions": [
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "sc.exe"
      ],
      "raw_values": [
        "sc.exe"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "sc.exe"
      ],
      "raw_values": [
        "*\\\\sc.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "stop"
      ],
      "raw_values": [
        "* stop *"
      ]
    }
  ]
}
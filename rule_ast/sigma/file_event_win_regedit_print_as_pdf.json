{
  "source": "sigma",
  "name": "file_event_win_regedit_print_as_pdf",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_regedit_print_as_pdf.eql",
  "raw_query": "any where process.executable:\"*\\\\regedit.exe\" and file.path:\"*.pdf\"",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "regedit.exe"
      ],
      "raw_values": [
        "*\\\\regedit.exe"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        ".pdf"
      ],
      "raw_values": [
        "*.pdf"
      ]
    }
  ]
}
    {
      "field": "winlog.channel",
      "raw_field": "winlog.channel",
      "operator": ":",
      "values": [
        "security"
      ],
      "raw_values": [
        "Security"
      ]
    },
    {
      "field": "event.code",
      "raw_field": "event.code",
      "operator": ":",
      "values": [
        "5145"
      ],
      "raw_values": [
        "5145"
      ]
    },
    {
      "field": "winlog.event_data.accessmask",
      "raw_field": "winlog.event_data.AccessMask",
      "operator": ":",
      "values": [
        "0x2"
      ],
      "raw_values": [
        "0x2"
      ]
    },
    {
      "field": "source.ip",
      "raw_field": "source.ip",
      "operator": "==",
      "values": [
        "::1"
      ],
      "raw_values": [
        "::1"
      ]
    }
  ]
}
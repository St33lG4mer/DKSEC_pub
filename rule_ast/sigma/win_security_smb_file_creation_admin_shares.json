{
  "source": "sigma",
  "name": "win_security_smb_file_creation_admin_shares",
  "subtree": "rules",
  "category": "builtin",
  "sigma_path": "rules/windows/builtin/security/win_security_smb_file_creation_admin_shares.eql",
  "raw_query": "any where winlog.channel:\"Security\" and ((event.code:\"5145\" and winlog.event_data.ShareName:\"*C$\" and winlog.event_data.AccessMask:\"0x2\") and (not user.name:\"*$\") and (not source.ip==\"::1\"))",

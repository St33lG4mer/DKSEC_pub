{
  "source": "sigma",
  "name": "proc_creation_win_wab_unusual_parents",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_wab_unusual_parents.eql",
  "raw_query": "any where ((process.parent.executable like~ (\"*\\\\WmiPrvSE.exe\", \"*\\\\svchost.exe\", \"*\\\\dllhost.exe\")) and (process.executable like~ (\"*\\\\wab.exe\", \"*\\\\wabmig.exe\"))) or (process.parent.executable like~ (\"*\\\\wab.exe\", \"*\\\\wabmig.exe\"))",
  "conditions": [
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": "like~",
      "values": [
        "wmiprvse.exe",
        "svchost.exe",
        "dllhost.exe",
        "wab.exe",
        "wabmig.exe"
      ],
      "raw_values": [
        "*\\\\WmiPrvSE.exe",
        "*\\\\svchost.exe",
        "*\\\\dllhost.exe",
        "*\\\\wab.exe",
        "*\\\\wabmig.exe"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "wab.exe",
        "wabmig.exe"
      ],
      "raw_values": [
        "*\\\\wab.exe",
        "*\\\\wabmig.exe"
      ]
    }
  ]
}
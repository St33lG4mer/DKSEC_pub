{
  "source": "sigma",
  "name": "registry_set_hide_file",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_hide_file.eql",
  "raw_query": "any where (registry.path like~ (\"*\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Explorer\\\\Advanced\\\\ShowSuperHidden\", \"*\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Explorer\\\\Advanced\\\\Hidden\")) and winlog.event_data.Details:\"DWORD (0x00000000)\"",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": "like~",
      "values": [
        "\\\\microsoft\\\\windows\\\\currentversion\\\\explorer\\\\advanced\\\\showsuperhidden",
        "\\\\microsoft\\\\windows\\\\currentversion\\\\explorer\\\\advanced\\\\hidden"
      ],
      "raw_values": [
        "*\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Explorer\\\\Advanced\\\\ShowSuperHidden",
        "*\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Explorer\\\\Advanced\\\\Hidden"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        "dword (0x00000000)"
      ],
      "raw_values": [
        "DWORD (0x00000000)"
      ]
    }
  ]
}
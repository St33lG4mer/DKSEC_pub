{
  "source": "sigma",
  "name": "win_system_service_install_sliver",
  "subtree": "rules",
  "category": "builtin",
  "sigma_path": "rules/windows/builtin/system/service_control_manager/win_system_service_install_sliver.eql",
  "raw_query": "any where winlog.channel:\"System\" and ((winlog.provider_name:\"Service Control Manager\" and event.code:\"7045\") and (winlog.event_data.ImagePath:\"SigmaRegularExpression(regexp=SigmaString(['^[a-zA-Z]:\\\\\\\\windows\\\\\\\\temp\\\\\\\\[a-zA-Z0-9]{10}\\\\.exe']), flags=set())\" or (winlog.event_data.ServiceName like~ (\"Sliver\", \"Sliver implant\"))))",
  "conditions": [
    {
      "field": "winlog.event_data.servicename",
      "raw_field": "winlog.event_data.ServiceName",
      "operator": "like~",
      "values": [
        "sliver",
        "sliver implant"
      ],
      "raw_values": [
        "Sliver",
        "Sliver implant"
      ]
    },
    {
      "field": "winlog.channel",
      "raw_field": "winlog.channel",
      "operator": ":",
      "values": [
        "system"
      ],
      "raw_values": [
        "System"
      ]
    },
    {
      "field": "winlog.provider_name",
      "raw_field": "winlog.provider_name",
      "operator": ":",
      "values": [
        "service control manager"
      ],
      "raw_values": [
        "Service Control Manager"
      ]
    },
    {
      "field": "event.code",
      "raw_field": "event.code",
      "operator": ":",
      "values": [
        "7045"
      ],
      "raw_values": [
        "7045"
      ]
    },
    {
      "field": "winlog.event_data.imagepath",
      "raw_field": "winlog.event_data.ImagePath",
      "operator": ":",
      "values": [
        "sigmaregularexpression(regexp=sigmastring(['^[a-za-z]:\\\\\\\\windows\\\\\\\\temp\\\\\\\\[a-za-z0-9]{10}\\\\.exe']), flags=set())"
      ],
      "raw_values": [
        "SigmaRegularExpression(regexp=SigmaString(['^[a-zA-Z]:\\\\\\\\windows\\\\\\\\temp\\\\\\\\[a-zA-Z0-9]{10}\\\\.exe']), flags=set())"
      ]
    }
  ]
}
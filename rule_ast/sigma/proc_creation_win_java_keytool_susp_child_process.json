{
  "source": "sigma",
  "name": "proc_creation_win_java_keytool_susp_child_process",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_java_keytool_susp_child_process.eql",
  "raw_query": "any where process.parent.executable:\"*\\\\keytool.exe\" and (process.executable like~ (\"*\\\\cmd.exe\", \"*\\\\sh.exe\", \"*\\\\bash.exe\", \"*\\\\powershell.exe\", \"*\\\\pwsh.exe\", \"*\\\\schtasks.exe\", \"*\\\\certutil.exe\", \"*\\\\whoami.exe\", \"*\\\\bitsadmin.exe\", \"*\\\\wscript.exe\", \"*\\\\cscript.exe\", \"*\\\\scrcons.exe\", \"*\\\\regsvr32.exe\", \"*\\\\hh.exe\", \"*\\\\wmic.exe\", \"*\\\\mshta.exe\", \"*\\\\rundll32.exe\", \"*\\\\forfiles.exe\", \"*\\\\scriptrunner.exe\", \"*\\\\mftrace.exe\", \"*\\\\AppVLP.exe\", \"*\\\\systeminfo.exe\", \"*\\\\reg.exe\", \"*\\\\query.exe\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "cmd.exe",
        "sh.exe",
        "bash.exe",
        "powershell.exe",
        "pwsh.exe",
        "schtasks.exe",
        "certutil.exe",
        "whoami.exe",
        "bitsadmin.exe",
        "wscript.exe",
        "cscript.exe",
        "scrcons.exe",
        "regsvr32.exe",
        "hh.exe",
        "wmic.exe",
        "mshta.exe",
        "rundll32.exe",
        "forfiles.exe",
        "scriptrunner.exe",
        "mftrace.exe",
        "appvlp.exe",
        "systeminfo.exe",
        "reg.exe",
        "query.exe"
      ],
      "raw_values": [
        "*\\\\cmd.exe",
        "*\\\\sh.exe",
        "*\\\\bash.exe",
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe",
        "*\\\\schtasks.exe",
        "*\\\\certutil.exe",
        "*\\\\whoami.exe",
        "*\\\\bitsadmin.exe",
        "*\\\\wscript.exe",
        "*\\\\cscript.exe",
        "*\\\\scrcons.exe",
        "*\\\\regsvr32.exe",
        "*\\\\hh.exe",
        "*\\\\wmic.exe",
        "*\\\\mshta.exe",
        "*\\\\rundll32.exe",
        "*\\\\forfiles.exe",
        "*\\\\scriptrunner.exe",
        "*\\\\mftrace.exe",
        "*\\\\AppVLP.exe",
        "*\\\\systeminfo.exe",
        "*\\\\reg.exe",
        "*\\\\query.exe"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "keytool.exe"
      ],
      "raw_values": [
        "*\\\\keytool.exe"
      ]
    }
  ]
}
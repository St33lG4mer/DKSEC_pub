{
  "source": "sigma",
  "name": "proc_creation_win_setspn_spn_enumeration",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_setspn_spn_enumeration.eql",
  "raw_query": "any where (process.executable:\"*\\\\setspn.exe\" or process.pe.original_file_name:\"setspn.exe\" or (process.pe.description:\"*Query or reset the computer*\" and process.pe.description:\"*SPN attribute*\")) and (process.command_line like~ (\"* -q *\", \"* /q *\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "setspn.exe"
      ],
      "raw_values": [
        "*\\\\setspn.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "setspn.exe"
      ],
      "raw_values": [
        "setspn.exe"
      ]
    },
    {
      "field": "process.pe.description",
      "raw_field": "process.pe.description",
      "operator": ":",
      "values": [
        "query or reset the computer",
        "spn attribute"
      ],
      "raw_values": [
        "*Query or reset the computer*",
        "*SPN attribute*"
      ]
    }
  ]
}
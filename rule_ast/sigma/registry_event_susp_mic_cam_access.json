{
  "source": "sigma",
  "name": "registry_event_susp_mic_cam_access",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_event/registry_event_susp_mic_cam_access.eql",
  "raw_query": "any where (registry.path:\"*\\\\Software\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\CapabilityAccessManager\\\\ConsentStore\\\\*\" and registry.path:\"*\\\\NonPackaged*\") and (registry.path like~ (\"*microphone*\", \"*webcam*\")) and (registry.path like~ (\"*:#Windows#Temp#*\", \"*:#$Recycle.bin#*\", \"*:#Temp#*\", \"*:#Users#Public#*\", \"*:#Users#Default#*\", \"*:#Users#Desktop#*\"))",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": "like~",
      "values": [
        "microphone",
        "webcam",
        ":#windows#temp#",
        ":#$recycle.bin#",
        ":#temp#",
        ":#users#public#",
        ":#users#default#",
        ":#users#desktop#"
      ],
      "raw_values": [
        "*microphone*",
        "*webcam*",
        "*:#Windows#Temp#*",
        "*:#$Recycle.bin#*",
        "*:#Temp#*",
        "*:#Users#Public#*",
        "*:#Users#Default#*",
        "*:#Users#Desktop#*"
      ]
    },
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\software\\\\microsoft\\\\windows\\\\currentversion\\\\capabilityaccessmanager\\\\consentstore\\\\",
        "\\\\nonpackaged"
      ],
      "raw_values": [
        "*\\\\Software\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\CapabilityAccessManager\\\\ConsentStore\\\\*",
        "*\\\\NonPackaged*"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "proc_creation_win_sysinternals_psexesvc",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_sysinternals_psexesvc.eql",
  "raw_query": "any where process.executable:\"C:\\\\Windows\\\\PSEXESVC.exe\" or process.pe.original_file_name:\"psexesvc.exe\"",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "psexesvc.exe"
      ],
      "raw_values": [
        "C:\\\\Windows\\\\PSEXESVC.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "psexesvc.exe"
      ],
      "raw_values": [
        "psexesvc.exe"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "proc_creation_win_renamed_office_processes",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_renamed_office_processes.eql",
  "raw_query": "any where ((process.pe.original_file_name like~ (\"Excel.exe\", \"MSACCESS.EXE\", \"MSPUB.EXE\", \"OneNote.exe\", \"OneNoteM.exe\", \"OUTLOOK.EXE\", \"POWERPNT.EXE\", \"WinWord.exe\", \"Olk.exe\")) or (process.pe.description like~ (\"Microsoft Access\", \"Microsoft Excel\", \"Microsoft OneNote\", \"Microsoft Outlook\", \"Microsoft PowerPoint\", \"Microsoft Publisher\", \"Microsoft Word\", \"Sent to OneNote Tool\"))) and (not (process.executable like~ (\"*\\\\EXCEL.exe\", \"*\\\\excelcnv.exe\", \"*\\\\MSACCESS.exe\", \"*\\\\MSPUB.EXE\", \"*\\\\ONENOTE.EXE\", \"*\\\\ONENOTEM.EXE\", \"*\\\\OUTLOOK.EXE\", \"*\\\\POWERPNT.EXE\", \"*\\\\WINWORD.exe\", \"*\\\\OLK.EXE\")))",
  "conditions": [
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": "like~",
      "values": [
        "excel.exe",
        "msaccess.exe",
        "mspub.exe",
        "onenote.exe",
        "onenotem.exe",
        "outlook.exe",
        "powerpnt.exe",
        "winword.exe",
        "olk.exe"
      ],
      "raw_values": [
        "Excel.exe",
        "MSACCESS.EXE",
        "MSPUB.EXE",
        "OneNote.exe",
        "OneNoteM.exe",
        "OUTLOOK.EXE",
        "POWERPNT.EXE",
        "WinWord.exe",
        "Olk.exe"
      ]
    },
    {
      "field": "process.pe.description",
      "raw_field": "process.pe.description",
      "operator": "like~",
      "values": [
        "microsoft access",
        "microsoft excel",
        "microsoft onenote",
        "microsoft outlook",
        "microsoft powerpoint",
        "microsoft publisher",
        "microsoft word",
        "sent to onenote tool"
      ],
      "raw_values": [
        "Microsoft Access",
        "Microsoft Excel",
        "Microsoft OneNote",
        "Microsoft Outlook",
        "Microsoft PowerPoint",
        "Microsoft Publisher",
        "Microsoft Word",
        "Sent to OneNote Tool"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "excel.exe",
        "excelcnv.exe",
        "msaccess.exe",
        "mspub.exe",
        "onenote.exe",
        "onenotem.exe",
        "outlook.exe",
        "powerpnt.exe",
        "winword.exe",
        "olk.exe"
      ],
      "raw_values": [
        "*\\\\EXCEL.exe",
        "*\\\\excelcnv.exe",
        "*\\\\MSACCESS.exe",
        "*\\\\MSPUB.EXE",
        "*\\\\ONENOTE.EXE",
        "*\\\\ONENOTEM.EXE",
        "*\\\\OUTLOOK.EXE",
        "*\\\\POWERPNT.EXE",
        "*\\\\WINWORD.exe",
        "*\\\\OLK.EXE"
      ]
    }
  ]
}
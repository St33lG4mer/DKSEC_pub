{
  "source": "sigma",
  "name": "file_event_win_susp_creation_by_mobsync",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_susp_creation_by_mobsync.eql",
  "raw_query": "any where process.executable:\"*\\\\mobsync.exe\" and (file.path like~ (\"*.dll\", \"*.exe\"))",
  "conditions": [
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": "like~",
      "values": [
        ".dll",
        ".exe"
      ],
      "raw_values": [
        "*.dll",
        "*.exe"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "mobsync.exe"
      ],
      "raw_values": [
        "*\\\\mobsync.exe"
      ]
    }
  ]
}
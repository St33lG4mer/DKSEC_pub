{
  "source": "sigma",
  "name": "proc_creation_win_wsl_child_processes_anomalies",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_wsl_child_processes_anomalies.eql",
  "raw_query": "any where (process.parent.executable like~ (\"*\\\\wsl.exe\", \"*\\\\wslhost.exe\")) and ((process.executable like~ (\"*\\\\calc.exe\", \"*\\\\cmd.exe\", \"*\\\\cscript.exe\", \"*\\\\mshta.exe\", \"*\\\\powershell.exe\", \"*\\\\pwsh.exe\", \"*\\\\regsvr32.exe\", \"*\\\\rundll32.exe\", \"*\\\\wscript.exe\")) or (process.executable like~ (\"*\\\\AppData\\\\Local\\\\Temp\\\\*\", \"*C:\\\\Users\\\\Public\\\\*\", \"*C:\\\\Windows\\\\Temp\\\\*\", \"*C:\\\\Temp\\\\*\", \"*\\\\Downloads\\\\*\", \"*\\\\Desktop\\\\*\")))",
  "conditions": [
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": "like~",
      "values": [
        "wsl.exe",
        "wslhost.exe"
      ],
      "raw_values": [
        "*\\\\wsl.exe",
        "*\\\\wslhost.exe"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "calc.exe",
        "cmd.exe",
        "cscript.exe",
        "mshta.exe",
        "powershell.exe",
        "pwsh.exe",
        "regsvr32.exe",
        "rundll32.exe",
        "wscript.exe"
      ],
      "raw_values": [
        "*\\\\calc.exe",
        "*\\\\cmd.exe",
        "*\\\\cscript.exe",
        "*\\\\mshta.exe",
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe",
        "*\\\\regsvr32.exe",
        "*\\\\rundll32.exe",
        "*\\\\wscript.exe",
        "*\\\\AppData\\\\Local\\\\Temp\\\\*",
        "*C:\\\\Users\\\\Public\\\\*",
        "*C:\\\\Windows\\\\Temp\\\\*",
        "*C:\\\\Temp\\\\*",
        "*\\\\Downloads\\\\*",
        "*\\\\Desktop\\\\*"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "proc_creation_win_driverquery_recon",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_driverquery_recon.eql",
  "raw_query": "any where (process.executable:\"*driverquery.exe\" or process.pe.original_file_name:\"drvqry.exe\") and ((process.parent.executable like~ (\"*\\\\cscript.exe\", \"*\\\\mshta.exe\", \"*\\\\regsvr32.exe\", \"*\\\\rundll32.exe\", \"*\\\\wscript.exe\")) or (process.parent.executable like~ (\"*\\\\AppData\\\\Local\\\\*\", \"*\\\\Users\\\\Public\\\\*\", \"*\\\\Windows\\\\Temp\\\\*\")))",
  "conditions": [
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": "like~",
      "values": [
        "cscript.exe",
        "mshta.exe",
        "regsvr32.exe",
        "rundll32.exe",
        "wscript.exe"
      ],
      "raw_values": [
        "*\\\\cscript.exe",
        "*\\\\mshta.exe",
        "*\\\\regsvr32.exe",
        "*\\\\rundll32.exe",
        "*\\\\wscript.exe",
        "*\\\\AppData\\\\Local\\\\*",
        "*\\\\Users\\\\Public\\\\*",
        "*\\\\Windows\\\\Temp\\\\*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "driverquery.exe"
      ],
      "raw_values": [
        "*driverquery.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "drvqry.exe"
      ],
      "raw_values": [
        "drvqry.exe"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "proc_creation_win_whoami_all_execution",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_whoami_all_execution.eql",
  "raw_query": "any where (process.executable:\"*\\\\whoami.exe\" or process.pe.original_file_name:\"whoami.exe\") and process.command_line like~ (\"* -all*\", \"* /all*\", \"* \u2013all*\", \"* \u2014all*\", \"* \u2015all*\")",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "-all",
        "all",
        "\u2013all",
        "\u2014all",
        "\u2015all"
      ],
      "raw_values": [
        "* -all*",
        "* /all*",
        "* \u2013all*",
        "* \u2014all*",
        "* \u2015all*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "whoami.exe"
      ],
      "raw_values": [
        "*\\\\whoami.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "whoami.exe"
      ],
      "raw_values": [
        "whoami.exe"
      ]
    }
  ]
}
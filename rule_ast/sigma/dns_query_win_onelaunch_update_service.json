{
  "source": "sigma",
  "name": "dns_query_win_onelaunch_update_service",
  "subtree": "rules",
  "category": "dns",
  "sigma_path": "rules/windows/dns_query/dns_query_win_onelaunch_update_service.eql",
  "raw_query": "any where dns.question.name:\"update.onelaunch.com\" and process.executable:\"*\\\\OneLaunch.exe\"",
  "conditions": [
    {
      "field": "dns.question.name",
      "raw_field": "dns.question.name",
      "operator": ":",
      "values": [
        "update.onelaunch.com"
      ],
      "raw_values": [
        "update.onelaunch.com"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "onelaunch.exe"
      ],
      "raw_values": [
        "*\\\\OneLaunch.exe"
      ]
    }
  ]
}
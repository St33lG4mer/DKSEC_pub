{
  "source": "sigma",
  "name": "file_event_win_susp_desktop_txt",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_susp_desktop_txt.eql",
  "raw_query": "any where process.executable:\"*\\\\cmd.exe\" and (file.path:\"*\\\\Users\\\\*\" and file.path:\"*\\\\Desktop\\\\*\") and file.path:\"*.txt\"",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "cmd.exe"
      ],
      "raw_values": [
        "*\\\\cmd.exe"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        ".txt"
      ],
      "raw_values": [
        "*\\\\Users\\\\*",
        "*\\\\Desktop\\\\*",
        "*.txt"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "proc_creation_win_wmic_remote_execution",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_wmic_remote_execution.eql",
  "raw_query": "any where ((process.executable:\"*\\\\WMIC.exe\" or process.pe.original_file_name:\"wmic.exe\") and process.command_line like~ (\"*-node:*\", \"*/node:*\", \"*\u2013node:*\", \"*\u2014node:*\", \"*\u2015node:*\")) and (not (process.command_line like~ (\"*localhost*\", \"*127.0.0.1*\")))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "-node:",
        "node:",
        "\u2013node:",
        "\u2014node:",
        "\u2015node:",
        "localhost",
        "127.0.0.1"
      ],
      "raw_values": [
        "*-node:*",
        "*/node:*",
        "*\u2013node:*",
        "*\u2014node:*",
        "*\u2015node:*",
        "*localhost*",
        "*127.0.0.1*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "wmic.exe"
      ],
      "raw_values": [
        "*\\\\WMIC.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "wmic.exe"
      ],
      "raw_values": [
        "wmic.exe"
      ]
    }
  ]
}
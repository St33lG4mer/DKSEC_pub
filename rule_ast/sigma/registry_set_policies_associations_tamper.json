{
  "source": "sigma",
  "name": "registry_set_policies_associations_tamper",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_policies_associations_tamper.eql",
  "raw_query": "any where registry.path:\"*\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Policies\\\\Associations\\\\*\" and ((registry.path:\"*\\\\DefaultFileTypeRisk\" and winlog.event_data.Details:\"DWORD (0x00006152)\") or (registry.path:\"*\\\\LowRiskFileTypes\" and (winlog.event_data.Details like~ (\"*.zip;*\", \"*.rar;*\", \"*.exe;*\", \"*.bat;*\", \"*.com;*\", \"*.cmd;*\", \"*.reg;*\", \"*.msi;*\", \"*.htm;*\", \"*.html;*\"))))",
  "conditions": [
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": "like~",
      "values": [
        ".zip;",
        ".rar;",
        ".exe;",
        ".bat;",
        ".com;",
        ".cmd;",
        ".reg;",
        ".msi;",
        ".htm;",
        ".html;"
      ],
      "raw_values": [
        "*.zip;*",
        "*.rar;*",
        "*.exe;*",
        "*.bat;*",
        "*.com;*",
        "*.cmd;*",
        "*.reg;*",
        "*.msi;*",
        "*.htm;*",
        "*.html;*"
      ]
    },
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\software\\\\microsoft\\\\windows\\\\currentversion\\\\policies\\\\associations\\\\",
        "\\\\defaultfiletyperisk",
        "\\\\lowriskfiletypes"
      ],
      "raw_values": [
        "*\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Policies\\\\Associations\\\\*",
        "*\\\\DefaultFileTypeRisk",
        "*\\\\LowRiskFileTypes"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        "dword (0x00006152)"
      ],
      "raw_values": [
        "DWORD (0x00006152)"
      ]
    }
  ]
}
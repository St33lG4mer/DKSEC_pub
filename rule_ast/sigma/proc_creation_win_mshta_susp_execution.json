        ".rtf",
        ".svg",
        ".tar",
        ".tmp",
        ".txt",
        ".xls",
        ".xml",
        ".yaml",
        ".yml",
        ".zip",
        "vbscript"
      ],
      "raw_values": [
        "*.7z*",
        "*.avi*",
        "*.bat*",
        "*.bmp*",
        "*.conf*",
        "*.csv*",
        "*.dll*",
        "*.doc*",
        "*.gif*",
        "*.gz*",
        "*.ini*",
        "*.jpe*",
        "*.jpg*",
        "*.json*",
        "*.lnk*",
        "*.log*",
        "*.mkv*",
        "*.mp3*",
        "*.mp4*",
        "*.pdf*",
        "*.png*",
        "*.ppt*",
        "*.rar*",
        "*.rtf*",
        "*.svg*",
        "*.tar*",
        "*.tmp*",
        "*.txt*",
        "*.xls*",
        "*.xml*",
        "*.yaml*",
        "*.yml*",
        "*.zip*",
        "*vbscript*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "mshta.exe"
      ],
      "raw_values": [
        "*\\\\mshta.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "mshta.exe"
      ],
      "raw_values": [
        "mshta.exe"
      ]
    }
  ]

{
  "source": "sigma",
  "name": "proc_creation_win_explorer_break_process_tree",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_explorer_break_process_tree.eql",
  "raw_query": "any where process.command_line:\"*/factory,{75dff2b7-6936-4c06-a8bb-676a7b00b24b}*\" or (process.command_line:\"*explorer.exe*\" and process.command_line like~ (\"* -root,*\", \"* /root,*\", \"* \u2013root,*\", \"* \u2014root,*\", \"* \u2015root,*\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "-root,",
        "root,",
        "\u2013root,",
        "\u2014root,",
        "\u2015root,"
      ],
      "raw_values": [
        "* -root,*",
        "* /root,*",
        "* \u2013root,*",
        "* \u2014root,*",
        "* \u2015root,*"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "factory,{75dff2b7-6936-4c06-a8bb-676a7b00b24b}",
        "explorer.exe"
      ],
      "raw_values": [
        "*/factory,{75dff2b7-6936-4c06-a8bb-676a7b00b24b}*",
        "*explorer.exe*"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "registry_set_office_trust_record_susp_location",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_office_trust_record_susp_location.eql",
  "raw_query": "any where registry.path:\"*\\\\Security\\\\Trusted Documents\\\\TrustRecords*\" and (registry.path like~ (\"*/AppData/Local/Microsoft/Windows/INetCache/*\", \"*/AppData/Local/Temp/*\", \"*/PerfLogs/*\", \"*C:/Users/Public/*\", \"*file:///D:/*\", \"*file:///E:/*\"))",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": "like~",
      "values": [
        "/appdata/local/microsoft/windows/inetcache/",
        "/appdata/local/temp/",
        "/perflogs/",
        "c:/users/public/",
        "file:///d:/",
        "file:///e:/"
      ],
      "raw_values": [
        "*/AppData/Local/Microsoft/Windows/INetCache/*",
        "*/AppData/Local/Temp/*",
        "*/PerfLogs/*",
        "*C:/Users/Public/*",
        "*file:///D:/*",
        "*file:///E:/*"
      ]
    },
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\security\\\\trusted documents\\\\trustrecords"
      ],
      "raw_values": [
        "*\\\\Security\\\\Trusted Documents\\\\TrustRecords*"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "file_event_win_susp_procexplorer_driver_created_in_tmp_folder",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_susp_procexplorer_driver_created_in_tmp_folder.eql",
  "raw_query": "any where (file.path:\"*\\\\AppData\\\\Local\\\\Temp\\\\*\" and file.path:\"*PROCEXP152.sys\") and (not (process.executable like~ (\"*\\\\procexp64.exe*\", \"*\\\\procexp.exe*\", \"*\\\\procmon64.exe*\", \"*\\\\procmon.exe*\")))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "procexp64.exe",
        "procexp.exe",
        "procmon64.exe",
        "procmon.exe"
      ],
      "raw_values": [
        "*\\\\procexp64.exe*",
        "*\\\\procexp.exe*",
        "*\\\\procmon64.exe*",
        "*\\\\procmon.exe*"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        "procexp152.sys"
      ],
      "raw_values": [
        "*\\\\AppData\\\\Local\\\\Temp\\\\*",
        "*PROCEXP152.sys"
      ]
    }
  ]
}
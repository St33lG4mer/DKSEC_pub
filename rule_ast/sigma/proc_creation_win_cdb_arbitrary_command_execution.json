{
  "source": "sigma",
  "name": "proc_creation_win_cdb_arbitrary_command_execution",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_cdb_arbitrary_command_execution.eql",
  "raw_query": "any where (process.executable:\"*\\\\cdb.exe\" or process.pe.original_file_name:\"CDB.Exe\") and (process.command_line like~ (\"* -c *\", \"* -cf *\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "-cf"
      ],
      "raw_values": [
        "* -c *",
        "* -cf *"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "cdb.exe"
      ],
      "raw_values": [
        "*\\\\cdb.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "cdb.exe"
      ],
      "raw_values": [
        "CDB.Exe"
      ]
    }
  ]
}
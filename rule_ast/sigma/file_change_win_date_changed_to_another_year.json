  "raw_query": "any where winlog.event_data.PreviousCreationUtcTime:\"202*\" and (not (winlog.event_data.CreationUtcTime:\"202*\" or ((file.path like~ (\"C:\\\\Program Files\\\\*\", \"C:\\\\Program Files (x86)\\\\*\")) or (process.executable like~ (\"C:\\\\Program Files\\\\*\", \"C:\\\\Program Files (x86)\\\\*\"))))) and (not (((process.executable like~ (\"C:\\\\Windows\\\\system32\\\\ProvTool.exe\", \"C:\\\\Windows\\\\System32\\\\usocoreworker.exe\", \"C:\\\\Windows\\\\ImmersiveControlPanel\\\\SystemSettings.exe\")) or file.path:\"C:\\\\ProgramData\\\\USOPrivate\\\\UpdateStore\\\\*\" or (file.path like~ (\"*.tmp\", \"*.temp\"))) or (process.executable:\"C:\\\\WINDOWS\\\\System32\\\\*\" and (process.executable like~ (\"*\\\\TiWorker.exe\", \"*\\\\svchost.exe\", \"*\\\\sihclient.exe\")) and file.path:\"*.cab\") or process.executable:\"C:\\\\Windows\\\\system32\\\\msiexec.exe\" or (process.executable:\"C:\\\\Windows\\\\Temp\\\\*\" and process.executable:\"*\\\\VCREDI~1.EXE\")))",
  "conditions": [
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": "like~",
      "values": [
        ".tmp",
        ".temp"
      ],
      "raw_values": [
        "C:\\\\Program Files\\\\*",
        "*.tmp",
        "*.temp"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "provtool.exe",
        "usocoreworker.exe",
        "systemsettings.exe",
        "tiworker.exe",
        "svchost.exe",
        "sihclient.exe"
      ],
      "raw_values": [
        "C:\\\\Program Files\\\\*",
        "C:\\\\Windows\\\\system32\\\\ProvTool.exe",
        "C:\\\\Windows\\\\System32\\\\usocoreworker.exe",
        "C:\\\\Windows\\\\ImmersiveControlPanel\\\\SystemSettings.exe",
        "*\\\\TiWorker.exe",
        "*\\\\svchost.exe",
        "*\\\\sihclient.exe"
      ]
    },
    {
      "field": "winlog.event_data.previouscreationutctime",
      "raw_field": "winlog.event_data.PreviousCreationUtcTime",
      "operator": ":",
      "values": [
        "202"
      ],
      "raw_values": [
        "202*"
      ]
    },
    {
      "field": "winlog.event_data.creationutctime",

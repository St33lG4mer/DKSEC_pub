        ".cab"
      ],
      "raw_values": [
        "C:\\\\ProgramData\\\\USOPrivate\\\\UpdateStore\\\\*",
        "*.cab"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "msiexec.exe",
        "vcredi~1.exe"
      ],
      "raw_values": [
        "C:\\\\WINDOWS\\\\System32\\\\*",
        "C:\\\\Windows\\\\system32\\\\msiexec.exe",
        "C:\\\\Windows\\\\Temp\\\\*",
        "*\\\\VCREDI~1.EXE"
      ]
    }
  ]

{
  "source": "sigma",
  "name": "image_load_uac_bypass_iscsicpl",
  "subtree": "rules",
  "category": "library",
  "sigma_path": "rules/windows/image_load/image_load_uac_bypass_iscsicpl.eql",
  "raw_query": "any where (process.executable:\"C:\\\\Windows\\\\SysWOW64\\\\iscsicpl.exe\" and file.path:\"*\\\\iscsiexe.dll\") and (not (file.path:\"*C:\\\\Windows\\\\*\" and file.path:\"*iscsiexe.dll*\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "iscsicpl.exe"
      ],
      "raw_values": [
        "C:\\\\Windows\\\\SysWOW64\\\\iscsicpl.exe"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        "iscsiexe.dll"
      ],
      "raw_values": [
        "*\\\\iscsiexe.dll",
        "*C:\\\\Windows\\\\*",
        "*iscsiexe.dll*"
      ]
    }
  ]
}
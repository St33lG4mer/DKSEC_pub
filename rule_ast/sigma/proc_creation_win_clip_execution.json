{
  "source": "sigma",
  "name": "proc_creation_win_clip_execution",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_clip_execution.eql",
  "raw_query": "any where process.executable:\"*\\\\clip.exe\" or process.pe.original_file_name:\"clip.exe\"",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "clip.exe"
      ],
      "raw_values": [
        "*\\\\clip.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "clip.exe"
      ],
      "raw_values": [
        "clip.exe"
      ]
    }
  ]
}
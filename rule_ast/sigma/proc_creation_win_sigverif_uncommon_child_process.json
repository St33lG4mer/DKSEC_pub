{
  "source": "sigma",
  "name": "proc_creation_win_sigverif_uncommon_child_process",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_sigverif_uncommon_child_process.eql",
  "raw_query": "any where process.parent.executable:\"*\\\\sigverif.exe\" and (not (process.executable like~ (\"C:\\\\Windows\\\\System32\\\\WerFault.exe\", \"C:\\\\Windows\\\\SysWOW64\\\\WerFault.exe\")))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "werfault.exe"
      ],
      "raw_values": [
        "C:\\\\Windows\\\\System32\\\\WerFault.exe",
        "C:\\\\Windows\\\\SysWOW64\\\\WerFault.exe"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "sigverif.exe"
      ],
      "raw_values": [
        "*\\\\sigverif.exe"
      ]
    }
  ]
}
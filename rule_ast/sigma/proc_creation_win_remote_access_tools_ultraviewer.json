{
  "source": "sigma",
  "name": "proc_creation_win_remote_access_tools_ultraviewer",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_remote_access_tools_ultraviewer.eql",
  "raw_query": "any where process.pe.product:\"UltraViewer\" or process.pe.company:\"DucFabulous Co,ltd\" or process.pe.original_file_name:\"UltraViewer_Desktop.exe\"",
  "conditions": [
    {
      "field": "process.pe.product",
      "raw_field": "process.pe.product",
      "operator": ":",
      "values": [
        "ultraviewer"
      ],
      "raw_values": [
        "UltraViewer"
      ]
    },
    {
      "field": "process.pe.company",
      "raw_field": "process.pe.company",
      "operator": ":",
      "values": [
        "ducfabulous co,ltd"
      ],
      "raw_values": [
        "DucFabulous Co,ltd"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "ultraviewer_desktop.exe"
      ],
      "raw_values": [
        "UltraViewer_Desktop.exe"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "proc_creation_win_net_use_password_plaintext",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_net_use_password_plaintext.eql",
  "raw_query": "any where (((process.executable like~ (\"*\\\\net.exe\", \"*\\\\net1.exe\")) or (process.pe.original_file_name like~ (\"net.exe\", \"net1.exe\"))) and (process.command_line:\"* use *\" and process.command_line:\"*:*\\\\*\" and process.command_line:\"*/USER:* *\")) and (not process.command_line:\"* \")",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "net.exe",
        "net1.exe"
      ],
      "raw_values": [
        "*\\\\net.exe",
        "*\\\\net1.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": "like~",
      "values": [
        "net.exe",
        "net1.exe"
      ],
      "raw_values": [
        "net.exe",
        "net1.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "use",
        "user:"
      ],
      "raw_values": [
        "* use *",
        "*:*\\\\*",
        "*/USER:* *",
        "* "
      ]
    }
  ]
}
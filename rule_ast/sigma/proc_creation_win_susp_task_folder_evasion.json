{
  "source": "sigma",
  "name": "proc_creation_win_susp_task_folder_evasion",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_susp_task_folder_evasion.eql",
  "raw_query": "any where (process.command_line like~ (\"*echo *\", \"*copy *\", \"*type *\", \"*file createnew*\")) and (process.command_line like~ (\"* C:\\\\Windows\\\\System32\\\\Tasks\\\\*\", \"* C:\\\\Windows\\\\SysWow64\\\\Tasks\\\\*\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "echo",
        "copy",
        "type",
        "file createnew"
      ],
      "raw_values": [
        "*echo *",
        "*copy *",
        "*type *",
        "*file createnew*",
        "* C:\\\\Windows\\\\System32\\\\Tasks\\\\*",
        "* C:\\\\Windows\\\\SysWow64\\\\Tasks\\\\*"
      ]
    }
  ]
}
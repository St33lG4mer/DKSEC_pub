{
  "source": "sigma",
  "name": "proc_creation_win_susp_add_user_local_admin_group",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_susp_add_user_local_admin_group.eql",
  "raw_query": "any where ((process.command_line:\"*localgroup *\" and process.command_line:\"* /add*\") or (process.command_line:\"*Add-LocalGroupMember *\" and process.command_line:\"* -Group *\")) and (process.command_line like~ (\"* administrators *\", \"* administrateur*\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "administrators",
        "administrateur"
      ],
      "raw_values": [
        "* administrators *",
        "* administrateur*"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "localgroup",
        "add",
        "add-localgroupmember",
        "-group"
      ],
      "raw_values": [
        "*localgroup *",
        "* /add*",
        "*Add-LocalGroupMember *",
        "* -Group *"
      ]
    }
  ]
}
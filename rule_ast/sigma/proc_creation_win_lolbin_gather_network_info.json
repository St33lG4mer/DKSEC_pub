{
  "source": "sigma",
  "name": "proc_creation_win_lolbin_gather_network_info",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_lolbin_gather_network_info.eql",
  "raw_query": "any where ((process.executable like~ (\"*\\\\cscript.exe\", \"*\\\\wscript.exe\")) or (process.pe.original_file_name like~ (\"cscript.exe\", \"wscript.exe\"))) and process.command_line:\"*gatherNetworkInfo.vbs*\"",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "cscript.exe",
        "wscript.exe"
      ],
      "raw_values": [
        "*\\\\cscript.exe",
        "*\\\\wscript.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": "like~",
      "values": [
        "cscript.exe",
        "wscript.exe"
      ],
      "raw_values": [
        "cscript.exe",
        "wscript.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "gathernetworkinfo.vbs"
      ],
      "raw_values": [
        "*gatherNetworkInfo.vbs*"
      ]
    }
  ]
}
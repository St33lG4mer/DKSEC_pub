{
  "source": "sigma",
  "name": "proc_creation_win_virtualbox_execution",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_virtualbox_execution.eql",
  "raw_query": "any where (process.command_line like~ (\"*VBoxRT.dll,RTR3Init*\", \"*VBoxC.dll*\", \"*VBoxDrv.sys*\")) or (process.command_line like~ (\"*startvm*\", \"*controlvm*\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "vboxrt.dll,rtr3init",
        "vboxc.dll",
        "vboxdrv.sys",
        "startvm",
        "controlvm"
      ],
      "raw_values": [
        "*VBoxRT.dll,RTR3Init*",
        "*VBoxC.dll*",
        "*VBoxDrv.sys*",
        "*startvm*",
        "*controlvm*"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "proc_creation_win_java_susp_child_process",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_java_susp_child_process.eql",
  "raw_query": "any where process.parent.executable:\"*\\\\java.exe\" and (process.executable like~ (\"*\\\\AppVLP.exe\", \"*\\\\bitsadmin.exe\", \"*\\\\certutil.exe\", \"*\\\\cscript.exe\", \"*\\\\curl.exe\", \"*\\\\forfiles.exe\", \"*\\\\hh.exe\", \"*\\\\mftrace.exe\", \"*\\\\mshta.exe\", \"*\\\\net.exe\", \"*\\\\net1.exe\", \"*\\\\query.exe\", \"*\\\\reg.exe\", \"*\\\\regsvr32.exe\", \"*\\\\rundll32.exe\", \"*\\\\schtasks.exe\", \"*\\\\scrcons.exe\", \"*\\\\scriptrunner.exe\", \"*\\\\sh.exe\", \"*\\\\systeminfo.exe\", \"*\\\\whoami.exe\", \"*\\\\wmic.exe\", \"*\\\\wscript.exe\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "appvlp.exe",
        "bitsadmin.exe",
        "certutil.exe",
        "cscript.exe",
        "curl.exe",
        "forfiles.exe",
        "hh.exe",
        "mftrace.exe",
        "mshta.exe",
        "net.exe",
        "net1.exe",
        "query.exe",
        "reg.exe",
        "regsvr32.exe",
        "rundll32.exe",
        "schtasks.exe",
        "scrcons.exe",
        "scriptrunner.exe",
        "sh.exe",
        "systeminfo.exe",
        "whoami.exe",
        "wmic.exe",
        "wscript.exe"
      ],
      "raw_values": [
        "*\\\\AppVLP.exe",
        "*\\\\bitsadmin.exe",
        "*\\\\certutil.exe",
        "*\\\\cscript.exe",
        "*\\\\curl.exe",
        "*\\\\forfiles.exe",
        "*\\\\hh.exe",
        "*\\\\mftrace.exe",
        "*\\\\mshta.exe",
        "*\\\\net.exe",
        "*\\\\net1.exe",
        "*\\\\query.exe",
        "*\\\\reg.exe",
        "*\\\\regsvr32.exe",
        "*\\\\rundll32.exe",
        "*\\\\schtasks.exe",
        "*\\\\scrcons.exe",
        "*\\\\scriptrunner.exe",
        "*\\\\sh.exe",
        "*\\\\systeminfo.exe",
        "*\\\\whoami.exe",
        "*\\\\wmic.exe",
        "*\\\\wscript.exe"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "java.exe"
      ],
      "raw_values": [
        "*\\\\java.exe"
      ]
    }
  ]
}
        "4624"
      ]
    },
    {
      "field": "winlog.channel",
      "raw_field": "winlog.channel",
      "operator": ":",
      "values": [
        "security"
      ],
      "raw_values": [
        "Security"
      ]
    },
    {
      "field": "winlog.event_data.authenticationpackagename",
      "raw_field": "winlog.event_data.AuthenticationPackageName",
      "operator": ":",
      "values": [
        "ntlm"
      ],
      "raw_values": [
        "NTLM"
      ]
    },
    {
      "field": "source.domain",
      "raw_field": "source.domain",
      "operator": ":",
      "values": [
        "sigmaregularexpression(regexp=sigmastring(['^[a-za-z0-9]{16}$']), flags=set())"
      ],
      "raw_values": [

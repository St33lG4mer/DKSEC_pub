      "raw_values": [
        "4776"
      ]
    },
    {
      "field": "winlog.event_data.workstation",
      "raw_field": "winlog.event_data.Workstation",
      "operator": ":",
      "values": [
        "sigmaregularexpression(regexp=sigmastring(['^[a-za-z0-9]{16}$']), flags=set())"
      ],
      "raw_values": [
        "SigmaRegularExpression(regexp=SigmaString(['^[A-Za-z0-9]{16}$']), flags=set())"

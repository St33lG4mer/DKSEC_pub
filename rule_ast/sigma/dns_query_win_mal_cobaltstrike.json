{
  "source": "sigma",
  "name": "dns_query_win_mal_cobaltstrike",
  "subtree": "rules",
  "category": "dns",
  "sigma_path": "rules/windows/dns_query/dns_query_win_mal_cobaltstrike.eql",
  "raw_query": "any where (dns.question.name like~ (\"aaa.stage.*\", \"post.1*\")) or dns.question.name:\"*.stage.123456.*\"",
  "conditions": [
    {
      "field": "dns.question.name",
      "raw_field": "dns.question.name",
      "operator": "like~",
      "values": [
        "aaa.stage.",
        "post.1"
      ],
      "raw_values": [
        "aaa.stage.*",
        "post.1*"
      ]
    },
    {
      "field": "dns.question.name",
      "raw_field": "dns.question.name",
      "operator": ":",
      "values": [
        ".stage.123456."
      ],
      "raw_values": [
        "*.stage.123456.*"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "proc_creation_win_dfsvc_suspicious_child_processes",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_dfsvc_suspicious_child_processes.eql",
  "raw_query": "any where process.parent.executable:\"*\\\\AppData\\\\Local\\\\Apps\\\\2.0\\\\*\" and (process.executable like~ (\"*\\\\calc.exe\", \"*\\\\cmd.exe\", \"*\\\\cscript.exe\", \"*\\\\explorer.exe\", \"*\\\\mshta.exe\", \"*\\\\net.exe\", \"*\\\\net1.exe\", \"*\\\\nltest.exe\", \"*\\\\notepad.exe\", \"*\\\\powershell.exe\", \"*\\\\pwsh.exe\", \"*\\\\reg.exe\", \"*\\\\regsvr32.exe\", \"*\\\\rundll32.exe\", \"*\\\\schtasks.exe\", \"*\\\\werfault.exe\", \"*\\\\wscript.exe\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "calc.exe",
        "cmd.exe",
        "cscript.exe",
        "explorer.exe",
        "mshta.exe",
        "net.exe",
        "net1.exe",
        "nltest.exe",
        "notepad.exe",
        "powershell.exe",
        "pwsh.exe",
        "reg.exe",
        "regsvr32.exe",
        "rundll32.exe",
        "schtasks.exe",
        "werfault.exe",
        "wscript.exe"
      ],
      "raw_values": [
        "*\\\\calc.exe",
        "*\\\\cmd.exe",
        "*\\\\cscript.exe",
        "*\\\\explorer.exe",
        "*\\\\mshta.exe",
        "*\\\\net.exe",
        "*\\\\net1.exe",
        "*\\\\nltest.exe",
        "*\\\\notepad.exe",
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe",
        "*\\\\reg.exe",
        "*\\\\regsvr32.exe",
        "*\\\\rundll32.exe",
        "*\\\\schtasks.exe",
        "*\\\\werfault.exe",
        "*\\\\wscript.exe"
      ]
    }
  ]
}
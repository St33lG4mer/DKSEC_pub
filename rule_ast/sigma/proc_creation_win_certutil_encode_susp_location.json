{
  "source": "sigma",
  "name": "proc_creation_win_certutil_encode_susp_location",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_certutil_encode_susp_location.eql",
  "raw_query": "any where (process.executable:\"*\\\\certutil.exe\" or process.pe.original_file_name:\"CertUtil.exe\") and process.command_line like~ (\"*-encode*\", \"*/encode*\", \"*\u2013encode*\", \"*\u2014encode*\", \"*\u2015encode*\") and (process.command_line like~ (\"*\\\\AppData\\\\Roaming\\\\*\", \"*\\\\Desktop\\\\*\", \"*\\\\Local\\\\Temp\\\\*\", \"*\\\\PerfLogs\\\\*\", \"*\\\\Users\\\\Public\\\\*\", \"*\\\\Windows\\\\Temp\\\\*\", \"*$Recycle.Bin*\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "-encode",
        "encode",
        "\u2013encode",
        "\u2014encode",
        "\u2015encode",
        "$recycle.bin"
      ],
      "raw_values": [
        "*-encode*",
        "*/encode*",
        "*\u2013encode*",
        "*\u2014encode*",
        "*\u2015encode*",
        "*\\\\AppData\\\\Roaming\\\\*",
        "*\\\\Desktop\\\\*",
        "*\\\\Local\\\\Temp\\\\*",
        "*\\\\PerfLogs\\\\*",
        "*\\\\Users\\\\Public\\\\*",
        "*\\\\Windows\\\\Temp\\\\*",
        "*$Recycle.Bin*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "certutil.exe"
      ],
      "raw_values": [
        "*\\\\certutil.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "certutil.exe"
      ],
      "raw_values": [
        "CertUtil.exe"
      ]
    }
  ]
}
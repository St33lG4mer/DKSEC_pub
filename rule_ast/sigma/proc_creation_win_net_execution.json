{
  "source": "sigma",
  "name": "proc_creation_win_net_execution",
  "subtree": "rules-threat-hunting",
  "category": "process",
  "sigma_path": "rules-threat-hunting/windows/process_creation/proc_creation_win_net_execution.eql",
  "raw_query": "any where ((process.executable like~ (\"*\\\\net.exe\", \"*\\\\net1.exe\")) or (process.pe.original_file_name like~ (\"net.exe\", \"net1.exe\"))) and (process.command_line like~ (\"* accounts*\", \"* group*\", \"* localgroup*\", \"* share*\", \"* start*\", \"* stop *\", \"* user*\", \"* view*\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "net.exe",
        "net1.exe"
      ],
      "raw_values": [
        "*\\\\net.exe",
        "*\\\\net1.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": "like~",
      "values": [
        "net.exe",
        "net1.exe"
      ],
      "raw_values": [
        "net.exe",
        "net1.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "accounts",
        "group",
        "localgroup",
        "share",
        "start",
        "stop",
        "user",
        "view"
      ],
      "raw_values": [
        "* accounts*",
        "* group*",
        "* localgroup*",
        "* share*",
        "* start*",
        "* stop *",
        "* user*",
        "* view*"
      ]
    }
  ]
}
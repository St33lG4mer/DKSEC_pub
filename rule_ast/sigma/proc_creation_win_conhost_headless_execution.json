{
  "source": "sigma",
  "name": "proc_creation_win_conhost_headless_execution",
  "subtree": "rules-threat-hunting",
  "category": "process",
  "sigma_path": "rules-threat-hunting/windows/process_creation/proc_creation_win_conhost_headless_execution.eql",
  "raw_query": "any where process.parent.executable:\"*\\\\conhost.exe\" and process.parent.command_line:\"*--headless*\"",
  "conditions": [
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "conhost.exe"
      ],
      "raw_values": [
        "*\\\\conhost.exe"
      ]
    },
    {
      "field": "process.parent.command_line",
      "raw_field": "process.parent.command_line",
      "operator": ":",
      "values": [
        "--headless"
      ],
      "raw_values": [
        "*--headless*"
      ]
    }
  ]
}
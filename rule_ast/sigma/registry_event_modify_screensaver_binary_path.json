{
  "source": "sigma",
  "name": "registry_event_modify_screensaver_binary_path",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_event/registry_event_modify_screensaver_binary_path.eql",
  "raw_query": "any where registry.path:\"*\\\\Control Panel\\\\Desktop\\\\SCRNSAVE.EXE\" and (not (process.executable like~ (\"*\\\\rundll32.exe\", \"*\\\\explorer.exe\")))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "rundll32.exe",
        "explorer.exe"
      ],
      "raw_values": [
        "*\\\\rundll32.exe",
        "*\\\\explorer.exe"
      ]
    },
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\control panel\\\\desktop\\\\scrnsave.exe"
      ],
      "raw_values": [
        "*\\\\Control Panel\\\\Desktop\\\\SCRNSAVE.EXE"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "registry_event_hybridconnectionmgr_svc_installation",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_event/registry_event_hybridconnectionmgr_svc_installation.eql",
  "raw_query": "any where registry.path:\"*\\\\Services\\\\HybridConnectionManager*\" or (winlog.event_data.EventType:\"SetValue\" and winlog.event_data.Details:\"*Microsoft.HybridConnectionManager.Listener.exe*\")",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\services\\\\hybridconnectionmanager"
      ],
      "raw_values": [
        "*\\\\Services\\\\HybridConnectionManager*"
      ]
    },
    {
      "field": "winlog.event_data.eventtype",
      "raw_field": "winlog.event_data.EventType",
      "operator": ":",
      "values": [
        "setvalue"
      ],
      "raw_values": [
        "SetValue"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        "microsoft.hybridconnectionmanager.listener.exe"
      ],
      "raw_values": [
        "*Microsoft.HybridConnectionManager.Listener.exe*"
      ]
    }
  ]
}
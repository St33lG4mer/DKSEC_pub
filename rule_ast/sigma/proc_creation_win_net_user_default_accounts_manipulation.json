        "\u0430\u0434\u043c\u0438\u043d\u0438\u0441\u0442\u0440\u0430\u0442\u043e\u0440",
        "administrateur",
        "administrador",
        "administrat\u00f6r",
        "administrator",
        "guest",
        "defaultaccount",
        "'j\u00e4rjestelm\u00e4nvalvoja'",
        "'rendszergazda'",
        "'\u0430\u0434\u043c\u0438\u043d\u0438\u0441\u0442\u0440\u0430\u0442\u043e\u0440'",
        "'administrateur'",
        "'administrador'",
        "'administrat\u00f6r'",
        "'administrator'",
        "'guest'",
        "'defaultaccount'"
      ],
      "raw_values": [
        "* J\u00e4rjestelm\u00e4nvalvoja *",
        "* Rendszergazda *",
        "* \u0410\u0434\u043c\u0438\u043d\u0438\u0441\u0442\u0440\u0430\u0442\u043e\u0440 *",
        "* Administrateur *",

{
  "source": "sigma",
  "name": "proc_creation_win_reg_machineguid",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_reg_machineguid.eql",
  "raw_query": "any where process.executable:\"*\\\\reg.exe\" and (process.command_line:\"*SOFTWARE\\\\Microsoft\\\\Cryptography*\" and process.command_line:\"*/v *\" and process.command_line:\"*MachineGuid*\")",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "reg.exe"
      ],
      "raw_values": [
        "*\\\\reg.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "cryptography",
        "machineguid"
      ],
      "raw_values": [
        "*SOFTWARE\\\\Microsoft\\\\Cryptography*",
        "*/v *",
        "*MachineGuid*"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "proc_creation_win_wmi_backdoor_exchange_transport_agent",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_wmi_backdoor_exchange_transport_agent.eql",
  "raw_query": "any where process.parent.executable:\"*\\\\EdgeTransport.exe\" and (not (process.executable:\"C:\\\\Windows\\\\System32\\\\conhost.exe\" or (process.executable:\"C:\\\\Program Files\\\\Microsoft\\\\Exchange Server\\\\*\" and process.executable:\"*\\\\Bin\\\\OleConverter.exe\")))",
  "conditions": [
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "edgetransport.exe"
      ],
      "raw_values": [
        "*\\\\EdgeTransport.exe"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "conhost.exe",
        "oleconverter.exe"
      ],
      "raw_values": [
        "C:\\\\Windows\\\\System32\\\\conhost.exe",
        "C:\\\\Program Files\\\\Microsoft\\\\Exchange Server\\\\*",
        "*\\\\Bin\\\\OleConverter.exe"
      ]
    }
  ]
}
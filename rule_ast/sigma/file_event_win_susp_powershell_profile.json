  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_susp_powershell_profile.eql",
  "raw_query": "any where file.path like~ (\"*\\\\Microsoft.PowerShell_profile.ps1\", \"*\\\\PowerShell\\\\profile.ps1\", \"*\\\\Program Files\\\\PowerShell\\\\7-preview\\\\profile.ps1\", \"*\\\\Program Files\\\\PowerShell\\\\7\\\\profile.ps1\", \"*\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\profile.ps1\", \"*\\\\WindowsPowerShell\\\\profile.ps1\")",

{
  "source": "sigma",
  "name": "image_load_office_vbadll_load",
  "subtree": "rules",
  "category": "library",
  "sigma_path": "rules/windows/image_load/image_load_office_vbadll_load.eql",
  "raw_query": "any where (process.executable like~ (\"*\\\\excel.exe\", \"*\\\\mspub.exe\", \"*\\\\onenote.exe\", \"*\\\\onenoteim.exe\", \"*\\\\outlook.exe\", \"*\\\\powerpnt.exe\", \"*\\\\winword.exe\")) and (file.path like~ (\"*\\\\VBE7.DLL\", \"*\\\\VBEUI.DLL\", \"*\\\\VBE7INTL.DLL\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "excel.exe",
        "mspub.exe",
        "onenote.exe",
        "onenoteim.exe",
        "outlook.exe",
        "powerpnt.exe",
        "winword.exe"
      ],
      "raw_values": [
        "*\\\\excel.exe",
        "*\\\\mspub.exe",
        "*\\\\onenote.exe",
        "*\\\\onenoteim.exe",
        "*\\\\outlook.exe",
        "*\\\\powerpnt.exe",
        "*\\\\winword.exe"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": "like~",
      "values": [
        "vbe7.dll",
        "vbeui.dll",
        "vbe7intl.dll"
      ],
      "raw_values": [
        "*\\\\VBE7.DLL",
        "*\\\\VBEUI.DLL",
        "*\\\\VBE7INTL.DLL"
      ]
    }
  ]
}
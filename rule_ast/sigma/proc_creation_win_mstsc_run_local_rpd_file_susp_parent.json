{
  "source": "sigma",
  "name": "proc_creation_win_mstsc_run_local_rpd_file_susp_parent",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_mstsc_run_local_rpd_file_susp_parent.eql",
  "raw_query": "any where (process.parent.executable like~ (\"*\\\\brave.exe\", \"*\\\\CCleanerBrowser.exe\", \"*\\\\chrome.exe\", \"*\\\\chromium.exe\", \"*\\\\firefox.exe\", \"*\\\\iexplore.exe\", \"*\\\\microsoftedge.exe\", \"*\\\\msedge.exe\", \"*\\\\opera.exe\", \"*\\\\vivaldi.exe\", \"*\\\\whale.exe\", \"*\\\\outlook.exe\")) and (process.executable:\"*\\\\mstsc.exe\" or process.pe.original_file_name:\"mstsc.exe\")",
  "conditions": [
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": "like~",
      "values": [
        "brave.exe",
        "ccleanerbrowser.exe",
        "chrome.exe",
        "chromium.exe",
        "firefox.exe",
        "iexplore.exe",
        "microsoftedge.exe",
        "msedge.exe",
        "opera.exe",
        "vivaldi.exe",
        "whale.exe",
        "outlook.exe"
      ],
      "raw_values": [
        "*\\\\brave.exe",
        "*\\\\CCleanerBrowser.exe",
        "*\\\\chrome.exe",
        "*\\\\chromium.exe",
        "*\\\\firefox.exe",
        "*\\\\iexplore.exe",
        "*\\\\microsoftedge.exe",
        "*\\\\msedge.exe",
        "*\\\\opera.exe",
        "*\\\\vivaldi.exe",
        "*\\\\whale.exe",
        "*\\\\outlook.exe"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "mstsc.exe"
      ],
      "raw_values": [
        "*\\\\mstsc.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "mstsc.exe"
      ],
      "raw_values": [
        "mstsc.exe"
      ]
    }
  ]
}
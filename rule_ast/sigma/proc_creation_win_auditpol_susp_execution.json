{
  "source": "sigma",
  "name": "proc_creation_win_auditpol_susp_execution",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_auditpol_susp_execution.eql",
  "raw_query": "any where (process.executable:\"*\\\\auditpol.exe\" or process.pe.original_file_name:\"AUDITPOL.EXE\") and (process.command_line like~ (\"*disable*\", \"*clear*\", \"*remove*\", \"*restore*\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "disable",
        "clear",
        "remove",
        "restore"
      ],
      "raw_values": [
        "*disable*",
        "*clear*",
        "*remove*",
        "*restore*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "auditpol.exe"
      ],
      "raw_values": [
        "*\\\\auditpol.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "auditpol.exe"
      ],
      "raw_values": [
        "AUDITPOL.EXE"
      ]
    }
  ]
}
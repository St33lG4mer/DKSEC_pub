{
  "source": "sigma",
  "name": "win_security_susp_wmi_login",
  "subtree": "rules",
  "category": "builtin",
  "sigma_path": "rules/windows/builtin/security/account_management/win_security_susp_wmi_login.eql",
  "raw_query": "any where winlog.channel:\"Security\" and (event.code:\"4624\" and process.executable:\"*\\\\WmiPrvSE.exe\")",
  "conditions": [
    {
      "field": "winlog.channel",
      "raw_field": "winlog.channel",
      "operator": ":",
      "values": [
        "security"
      ],
      "raw_values": [
        "Security"
      ]
    },
    {
      "field": "event.code",
      "raw_field": "event.code",
      "operator": ":",
      "values": [
        "4624"
      ],
      "raw_values": [
        "4624"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "wmiprvse.exe"
      ],
      "raw_values": [
        "*\\\\WmiPrvSE.exe"
      ]
    }
  ]
}
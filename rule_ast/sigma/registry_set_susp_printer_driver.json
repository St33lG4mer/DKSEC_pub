{
  "source": "sigma",
  "name": "registry_set_susp_printer_driver",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_susp_printer_driver.eql",
  "raw_query": "any where ((registry.path:\"*\\\\Control\\\\Print\\\\Environments\\\\Windows x64\\\\Drivers*\" and registry.path:\"*\\\\Manufacturer*\") and winlog.event_data.Details:\"(Empty)\") and (not (registry.path:\"*\\\\CutePDF Writer v4.0\\\\*\" or (registry.path like~ (\"*\\\\VNC Printer (PS)\\\\*\", \"*\\\\VNC Printer (UD)\\\\*\")) or registry.path:\"*\\\\Version-3\\\\PDF24\\\\*\"))",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\control\\\\print\\\\environments\\\\windows x64\\\\drivers",
        "\\\\manufacturer",
        "\\\\cutepdf writer v4.0\\\\",
        "\\\\version-3\\\\pdf24\\\\"
      ],
      "raw_values": [
        "*\\\\Control\\\\Print\\\\Environments\\\\Windows x64\\\\Drivers*",
        "*\\\\Manufacturer*",
        "*\\\\CutePDF Writer v4.0\\\\*",
        "*\\\\Version-3\\\\PDF24\\\\*"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        "(empty)"
      ],
      "raw_values": [
        "(Empty)"
      ]
    }
  ]
}
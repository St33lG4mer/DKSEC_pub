{
  "source": "sigma",
  "name": "proc_creation_win_uac_bypass_cmstp",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_uac_bypass_cmstp.eql",
  "raw_query": "any where (process.executable:\"*\\\\cmstp.exe\" or process.pe.original_file_name:\"CMSTP.EXE\") and (process.command_line like~ (\"*/s*\", \"*-s*\", \"*/au*\", \"*-au*\", \"*/ni*\", \"*-ni*\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "-au",
        "-ni"
      ],
      "raw_values": [
        "*/s*",
        "*-s*",
        "*/au*",
        "*-au*",
        "*/ni*",
        "*-ni*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "cmstp.exe"
      ],
      "raw_values": [
        "*\\\\cmstp.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "cmstp.exe"
      ],
      "raw_values": [
        "CMSTP.EXE"
      ]
    }
  ]
}
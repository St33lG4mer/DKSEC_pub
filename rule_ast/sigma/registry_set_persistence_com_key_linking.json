{
  "source": "sigma",
  "name": "registry_set_persistence_com_key_linking",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_persistence_com_key_linking.eql",
  "raw_query": "any where (registry.path:\"*HKU\\\\*\" and registry.path:\"*Classes\\\\CLSID\\\\*\" and registry.path:\"*\\\\TreatAs*\") and (not process.executable:\"C:\\\\WINDOWS\\\\system32\\\\svchost.exe\")",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "hku\\\\",
        "classes\\\\clsid\\\\",
        "\\\\treatas"
      ],
      "raw_values": [
        "*HKU\\\\*",
        "*Classes\\\\CLSID\\\\*",
        "*\\\\TreatAs*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "svchost.exe"
      ],
      "raw_values": [
        "C:\\\\WINDOWS\\\\system32\\\\svchost.exe"
      ]
    }
  ]

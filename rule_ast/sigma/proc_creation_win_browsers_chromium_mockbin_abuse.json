{
  "source": "sigma",
  "name": "proc_creation_win_browsers_chromium_mockbin_abuse",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_browsers_chromium_mockbin_abuse.eql",
  "raw_query": "any where (process.executable like~ (\"*\\\\brave.exe\", \"*\\\\chrome.exe\", \"*\\\\msedge.exe\", \"*\\\\opera.exe\", \"*\\\\vivaldi.exe\")) and process.command_line:\"*--headless*\" and (process.command_line like~ (\"*://run.mocky*\", \"*://mockbin*\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "brave.exe",
        "chrome.exe",
        "msedge.exe",
        "opera.exe",
        "vivaldi.exe"
      ],
      "raw_values": [
        "*\\\\brave.exe",
        "*\\\\chrome.exe",
        "*\\\\msedge.exe",
        "*\\\\opera.exe",
        "*\\\\vivaldi.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "run.mocky",
        "mockbin"
      ],
      "raw_values": [
        "*://run.mocky*",
        "*://mockbin*"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "--headless"
      ],
      "raw_values": [
        "*--headless*"
      ]
    }
  ]
}
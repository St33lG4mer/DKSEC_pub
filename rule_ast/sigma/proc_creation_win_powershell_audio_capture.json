{
  "source": "sigma",
  "name": "proc_creation_win_powershell_audio_capture",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_powershell_audio_capture.eql",
  "raw_query": "any where process.command_line like~ (\"*WindowsAudioDevice-Powershell-Cmdlet*\", \"*Toggle-AudioDevice*\", \"*Get-AudioDevice *\", \"*Set-AudioDevice *\", \"*Write-AudioDevice *\")",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "windowsaudiodevice-powershell-cmdlet",
        "toggle-audiodevice",
        "get-audiodevice",
        "set-audiodevice",
        "write-audiodevice"
      ],
      "raw_values": [
        "*WindowsAudioDevice-Powershell-Cmdlet*",
        "*Toggle-AudioDevice*",
        "*Get-AudioDevice *",
        "*Set-AudioDevice *",
        "*Write-AudioDevice *"
      ]
    }
  ]
}
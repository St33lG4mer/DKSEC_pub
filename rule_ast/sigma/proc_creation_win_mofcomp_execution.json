{
  "source": "sigma",
  "name": "proc_creation_win_mofcomp_execution",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_mofcomp_execution.eql",
  "raw_query": "any where ((process.executable:\"*\\\\mofcomp.exe\" or process.pe.original_file_name:\"mofcomp.exe\") and ((process.parent.executable like~ (\"*\\\\cmd.exe\", \"*\\\\powershell.exe\", \"*\\\\pwsh.exe\", \"*\\\\wsl.exe\", \"*\\\\wscript.exe\", \"*\\\\cscript.exe\")) or (process.command_line like~ (\"*\\\\AppData\\\\Local\\\\Temp*\", \"*\\\\Users\\\\Public\\\\*\", \"*\\\\WINDOWS\\\\Temp\\\\*\", \"*%temp%*\", \"*%tmp%*\", \"*%appdata%*\")))) and (not (process.parent.executable:\"C:\\\\Windows\\\\System32\\\\wbem\\\\WmiPrvSE.exe\" and process.command_line:\"*C:\\\\Windows\\\\TEMP\\\\*\" and process.command_line:\"*.mof\")) and (not (process.command_line:\"*C:\\\\Windows\\\\TEMP\\\\*\" and process.command_line:\"*.mof\"))",
  "conditions": [
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": "like~",
      "values": [
        "cmd.exe",
        "powershell.exe",
        "pwsh.exe",
        "wsl.exe",
        "wscript.exe",
        "cscript.exe"
      ],
      "raw_values": [
        "*\\\\cmd.exe",
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe",
        "*\\\\wsl.exe",
        "*\\\\wscript.exe",
        "*\\\\cscript.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "temp",
        "%temp%",
        "%tmp%",
        "%appdata%"
      ],
      "raw_values": [
        "*\\\\AppData\\\\Local\\\\Temp*",
        "*\\\\Users\\\\Public\\\\*",
        "*\\\\WINDOWS\\\\Temp\\\\*",
        "*%temp%*",
        "*%tmp%*",
        "*%appdata%*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "mofcomp.exe"
      ],
      "raw_values": [
        "*\\\\mofcomp.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "mofcomp.exe"
      ],
      "raw_values": [
        "mofcomp.exe"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "wmiprvse.exe"
      ],
      "raw_values": [
        "C:\\\\Windows\\\\System32\\\\wbem\\\\WmiPrvSE.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        ".mof"
      ],
      "raw_values": [
        "*C:\\\\Windows\\\\TEMP\\\\*",
        "*.mof"
      ]
    }
  ]
}
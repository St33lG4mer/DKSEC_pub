{
  "source": "sigma",
  "name": "registry_set_terminal_server_suspicious",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_terminal_server_suspicious.eql",
  "raw_query": "any where (registry.path like~ (\"*\\\\fDenyTSConnections\", \"*\\\\fSingleSessionPerUser\", \"*\\\\UserAuthentication\")) and winlog.event_data.Details:\"DWORD (0x00000000)\"",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": "like~",
      "values": [
        "\\\\fdenytsconnections",
        "\\\\fsinglesessionperuser",
        "\\\\userauthentication"
      ],
      "raw_values": [
        "*\\\\fDenyTSConnections",
        "*\\\\fSingleSessionPerUser",
        "*\\\\UserAuthentication"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        "dword (0x00000000)"
      ],
      "raw_values": [
        "DWORD (0x00000000)"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "proc_creation_win_bginfo_uncommon_child_process",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_bginfo_uncommon_child_process.eql",
  "raw_query": "any where process.parent.executable like~ (\"*\\\\bginfo.exe\", \"*\\\\bginfo64.exe\")",
  "conditions": [
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": "like~",
      "values": [
        "bginfo.exe",
        "bginfo64.exe"
      ],
      "raw_values": [
        "*\\\\bginfo.exe",
        "*\\\\bginfo64.exe"
      ]
    }
  ]
}
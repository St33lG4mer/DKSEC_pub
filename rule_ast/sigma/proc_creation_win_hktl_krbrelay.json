{
  "source": "sigma",
  "name": "proc_creation_win_hktl_krbrelay",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_hktl_krbrelay.eql",
  "raw_query": "any where (process.executable:\"*\\\\KrbRelay.exe\" or process.pe.original_file_name:\"KrbRelay.exe\") or (process.command_line:\"* -spn *\" and process.command_line:\"* -clsid *\" and process.command_line:\"* -rbcd *\") or (process.command_line:\"*shadowcred*\" and process.command_line:\"*clsid*\" and process.command_line:\"*spn*\") or (process.command_line:\"*spn *\" and process.command_line:\"*session *\" and process.command_line:\"*clsid *\")",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "krbrelay.exe"
      ],
      "raw_values": [
        "*\\\\KrbRelay.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "krbrelay.exe"
      ],
      "raw_values": [
        "KrbRelay.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "-spn",
        "-clsid",
        "-rbcd",
        "shadowcred",
        "clsid",
        "spn",
        "session"
      ],
      "raw_values": [
        "* -spn *",
        "* -clsid *",
        "* -rbcd *",
        "*shadowcred*",
        "*clsid*",
        "*spn*",
        "*spn *",
        "*session *",
        "*clsid *"
      ]
    }
  ]
}
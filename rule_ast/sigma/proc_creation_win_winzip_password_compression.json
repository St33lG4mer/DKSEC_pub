{
  "source": "sigma",
  "name": "proc_creation_win_winzip_password_compression",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_winzip_password_compression.eql",
  "raw_query": "any where (process.command_line like~ (\"*winzip.exe*\", \"*winzip64.exe*\")) and process.command_line:\"*-s\\\"*\" and (process.command_line like~ (\"* -min *\", \"* -a *\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "winzip.exe",
        "winzip64.exe",
        "-min"
      ],
      "raw_values": [
        "*winzip.exe*",
        "*winzip64.exe*",
        "* -min *",
        "* -a *"
      ]
    }
  ]
}
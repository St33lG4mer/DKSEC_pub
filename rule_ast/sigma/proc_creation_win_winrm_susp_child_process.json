{
  "source": "sigma",
  "name": "proc_creation_win_winrm_susp_child_process",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_winrm_susp_child_process.eql",
  "raw_query": "any where process.parent.executable:\"*\\\\wsmprovhost.exe\" and (process.executable like~ (\"*\\\\cmd.exe\", \"*\\\\sh.exe\", \"*\\\\bash.exe\", \"*\\\\powershell.exe\", \"*\\\\pwsh.exe\", \"*\\\\wsl.exe\", \"*\\\\schtasks.exe\", \"*\\\\certutil.exe\", \"*\\\\whoami.exe\", \"*\\\\bitsadmin.exe\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "cmd.exe",
        "sh.exe",
        "bash.exe",
        "powershell.exe",
        "pwsh.exe",
        "wsl.exe",
        "schtasks.exe",
        "certutil.exe",
        "whoami.exe",
        "bitsadmin.exe"
      ],
      "raw_values": [
        "*\\\\cmd.exe",
        "*\\\\sh.exe",
        "*\\\\bash.exe",
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe",
        "*\\\\wsl.exe",
        "*\\\\schtasks.exe",
        "*\\\\certutil.exe",
        "*\\\\whoami.exe",
        "*\\\\bitsadmin.exe"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "wsmprovhost.exe"
      ],
      "raw_values": [
        "*\\\\wsmprovhost.exe"
      ]
    }
  ]
}
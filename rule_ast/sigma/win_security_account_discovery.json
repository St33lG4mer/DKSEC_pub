{
  "source": "sigma",
  "name": "win_security_account_discovery",
  "subtree": "rules",
  "category": "builtin",
  "sigma_path": "rules/windows/builtin/security/win_security_account_discovery.eql",
  "raw_query": "any where winlog.channel:\"Security\" and ((event.code:\"4661\" and (winlog.event_data.ObjectType like~ (\"SAM_USER\", \"SAM_GROUP\"))) and ((winlog.event_data.ObjectName like~ (\"*-512\", \"*-502\", \"*-500\", \"*-505\", \"*-519\", \"*-520\", \"*-544\", \"*-551\", \"*-555\")) or winlog.event_data.ObjectName:\"*admin*\") and (not user.name:\"*$\"))",
  "conditions": [
    {
      "field": "winlog.event_data.objecttype",
      "raw_field": "winlog.event_data.ObjectType",
      "operator": "like~",
      "values": [
        "sam_user",
        "sam_group"
      ],
      "raw_values": [
        "SAM_USER",
        "SAM_GROUP"
      ]
    },
    {
      "field": "winlog.event_data.objectname",
      "raw_field": "winlog.event_data.ObjectName",
      "operator": "like~",
      "values": [
        "-512",
        "-502",
        "-500",
        "-505",
        "-519",
        "-520",
        "-544",
        "-551",
        "-555"
      ],
      "raw_values": [
        "*-512",
        "*-502",
        "*-500",
        "*-505",
        "*-519",
        "*-520",
        "*-544",
        "*-551",
        "*-555"
      ]
    },
    {
      "field": "winlog.channel",
      "raw_field": "winlog.channel",
      "operator": ":",
      "values": [
        "security"
      ],
      "raw_values": [
        "Security"
      ]
    },
    {
      "field": "event.code",
      "raw_field": "event.code",
      "operator": ":",
      "values": [
        "4661"
      ],
      "raw_values": [
        "4661"
      ]
    },
    {
      "field": "winlog.event_data.objectname",
      "raw_field": "winlog.event_data.ObjectName",
      "operator": ":",
      "values": [
        "admin"
      ],
      "raw_values": [
        "*admin*"
      ]
    }
  ]
}
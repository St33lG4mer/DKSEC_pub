{
  "source": "sigma",
  "name": "win_security_admin_share_access",
  "subtree": "rules",
  "category": "builtin",
  "sigma_path": "rules/windows/builtin/security/win_security_admin_share_access.eql",
  "raw_query": "any where winlog.channel:\"Security\" and ((event.code:\"5140\" and winlog.event_data.ShareName:\"Admin$\") and (not user.name:\"*$\"))",
  "conditions": [
    {
      "field": "winlog.channel",
      "raw_field": "winlog.channel",
      "operator": ":",
      "values": [
        "security"
      ],
      "raw_values": [
        "Security"
      ]
    },
    {
      "field": "event.code",
      "raw_field": "event.code",
      "operator": ":",
      "values": [
        "5140"
      ],
      "raw_values": [
        "5140"
      ]
    },
    {
      "field": "winlog.event_data.sharename",
      "raw_field": "winlog.event_data.ShareName",
      "operator": ":",
      "values": [
        "admin$"
      ],
      "raw_values": [
        "Admin$"
      ]
    }
  ]
}
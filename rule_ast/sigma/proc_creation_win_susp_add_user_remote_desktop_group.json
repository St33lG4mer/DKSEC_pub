{
  "source": "sigma",
  "name": "proc_creation_win_susp_add_user_remote_desktop_group",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_susp_add_user_remote_desktop_group.eql",
  "raw_query": "any where ((process.command_line:\"*localgroup *\" and process.command_line:\"* /add*\") or (process.command_line:\"*Add-LocalGroupMember *\" and process.command_line:\"* -Group *\")) and (process.command_line like~ (\"*Remote Desktop Users*\", \"*Utilisateurs du Bureau \u00e0 distance*\", \"*Usuarios de escritorio remoto*\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "remote desktop users",
        "utilisateurs du bureau \u00e0 distance",
        "usuarios de escritorio remoto"
      ],
      "raw_values": [
        "*Remote Desktop Users*",
        "*Utilisateurs du Bureau \u00e0 distance*",
        "*Usuarios de escritorio remoto*"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "localgroup",
        "add",
        "add-localgroupmember",
        "-group"
      ],
      "raw_values": [
        "*localgroup *",
        "* /add*",
        "*Add-LocalGroupMember *",
        "* -Group *"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "proc_creation_win_rundll32_sys",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_rundll32_sys.eql",
  "raw_query": "any where process.command_line:\"*rundll32.exe*\" and (process.command_line like~ (\"*.sys,*\", \"*.sys *\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        ".sys,",
        ".sys"
      ],
      "raw_values": [
        "*.sys,*",
        "*.sys *"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "rundll32.exe"
      ],
      "raw_values": [
        "*rundll32.exe*"
      ]
    }
  ]
}
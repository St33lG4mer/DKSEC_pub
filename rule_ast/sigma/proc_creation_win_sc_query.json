{
  "source": "sigma",
  "name": "proc_creation_win_sc_query",
  "subtree": "rules-threat-hunting",
  "category": "process",
  "sigma_path": "rules-threat-hunting/windows/process_creation/proc_creation_win_sc_query.eql",
  "raw_query": "any where ((process.executable:\"*\\\\sc.exe\" and process.pe.original_file_name:\"sc.exe\") and process.command_line:\"* query*\") and (not process.command_line:\"sc query dokan1\")",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "sc.exe"
      ],
      "raw_values": [
        "*\\\\sc.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "sc.exe"
      ],
      "raw_values": [
        "sc.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "query",
        "sc query dokan1"
      ],
      "raw_values": [
        "* query*",
        "sc query dokan1"
      ]
    }
  ]
}
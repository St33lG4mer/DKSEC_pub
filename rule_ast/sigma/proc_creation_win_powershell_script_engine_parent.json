{
  "source": "sigma",
  "name": "proc_creation_win_powershell_script_engine_parent",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_powershell_script_engine_parent.eql",
  "raw_query": "any where ((process.parent.executable like~ (\"*\\\\wscript.exe\", \"*\\\\cscript.exe\")) and (process.executable like~ (\"*\\\\powershell.exe\", \"*\\\\pwsh.exe\"))) and (not process.working_directory:\"*\\\\Health Service State\\\\*\")",
  "conditions": [
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": "like~",
      "values": [
        "wscript.exe",
        "cscript.exe"
      ],
      "raw_values": [
        "*\\\\wscript.exe",
        "*\\\\cscript.exe"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "powershell.exe",
        "pwsh.exe"
      ],
      "raw_values": [
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe"
      ]
    },
    {
      "field": "process.working_directory",
      "raw_field": "process.working_directory",
      "operator": ":",
      "values": [
        "\\\\health service state\\\\"
      ],
      "raw_values": [
        "*\\\\Health Service State\\\\*"
      ]
    }
  ]
}
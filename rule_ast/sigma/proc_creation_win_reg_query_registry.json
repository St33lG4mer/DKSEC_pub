{
  "source": "sigma",
  "name": "proc_creation_win_reg_query_registry",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_reg_query_registry.eql",
  "raw_query": "any where (process.executable:\"*\\\\reg.exe\" or process.pe.original_file_name:\"reg.exe\") and process.command_line:\"*query*\" and (process.command_line like~ (\"*currentVersion\\\\windows*\", \"*winlogon\\\\*\", \"*currentVersion\\\\shellServiceObjectDelayLoad*\", \"*currentVersion\\\\run*\", \"*currentVersion\\\\policies\\\\explorer\\\\run*\", \"*currentcontrolset\\\\services*\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "windows",
        "shellserviceobjectdelayload",
        "run",
        "services"
      ],
      "raw_values": [
        "*currentVersion\\\\windows*",
        "*winlogon\\\\*",
        "*currentVersion\\\\shellServiceObjectDelayLoad*",
        "*currentVersion\\\\run*",
        "*currentVersion\\\\policies\\\\explorer\\\\run*",
        "*currentcontrolset\\\\services*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "reg.exe"
      ],
      "raw_values": [
        "*\\\\reg.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "reg.exe"
      ],
      "raw_values": [
        "reg.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "query"
      ],
      "raw_values": [
        "*query*"
      ]
    }
  ]
}
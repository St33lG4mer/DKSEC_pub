    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "qfe list",
        "diskdrive",
        "csproduct",
        "computersystem"
      ],
      "raw_values": [
        "*qfe list*",
        "*diskdrive *",
        "*csproduct *",
        "*computersystem *",
        "* os *",
        "*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "certutil.exe",
        "wmic.exe"
      ],
      "raw_values": [
        "*\\\\certutil.exe",

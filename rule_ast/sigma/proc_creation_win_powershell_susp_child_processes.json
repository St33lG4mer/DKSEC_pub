        "certutil.exe",
        "cscript.exe",
        "forfiles.exe",
        "hh.exe",
        "mshta.exe",
        "regsvr32.exe",
        "rundll32.exe",
        "schtasks.exe",
        "scrcons.exe",
        "scriptrunner.exe",
        "sh.exe",
        "wmic.exe",
        "wscript.exe"
      ],
      "raw_values": [
        "*\\\\bash.exe",
        "*\\\\bitsadmin.exe",
        "*\\\\certutil.exe",
        "*\\\\cscript.exe",
        "*\\\\forfiles.exe",
        "*\\\\hh.exe",
        "*\\\\mshta.exe",
        "*\\\\regsvr32.exe",
        "*\\\\rundll32.exe",
        "*\\\\schtasks.exe",
        "*\\\\scrcons.exe",
        "*\\\\scriptrunner.exe",
        "*\\\\sh.exe",
        "*\\\\wmic.exe",
        "*\\\\wscript.exe"
      ]

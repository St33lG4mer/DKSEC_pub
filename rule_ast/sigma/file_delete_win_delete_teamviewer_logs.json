{
  "source": "sigma",
  "name": "file_delete_win_delete_teamviewer_logs",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_delete/file_delete_win_delete_teamviewer_logs.eql",
  "raw_query": "any where (file.path:\"*\\\\TeamViewer_*\" and file.path:\"*.log\") and (not process.executable:\"C:\\\\Windows\\\\system32\\\\svchost.exe\")",
  "conditions": [
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        "teamviewer_",
        ".log"
      ],
      "raw_values": [
        "*\\\\TeamViewer_*",
        "*.log"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "svchost.exe"
      ],
      "raw_values": [
        "C:\\\\Windows\\\\system32\\\\svchost.exe"
      ]
    }
  ]
}
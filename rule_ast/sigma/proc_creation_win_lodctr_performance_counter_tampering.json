{
  "source": "sigma",
  "name": "proc_creation_win_lodctr_performance_counter_tampering",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_lodctr_performance_counter_tampering.eql",
  "raw_query": "any where (process.executable:\"*\\\\lodctr.exe\" and process.pe.original_file_name:\"LODCTR.EXE\") and process.command_line like~ (\"* -r*\", \"* /r*\", \"* \u2013r*\", \"* \u2014r*\", \"* \u2015r*\")",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "lodctr.exe"
      ],
      "raw_values": [
        "*\\\\lodctr.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "lodctr.exe"
      ],
      "raw_values": [
        "LODCTR.EXE"
      ]
    }
  ]
}
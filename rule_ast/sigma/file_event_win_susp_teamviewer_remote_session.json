{
  "source": "sigma",
  "name": "file_event_win_susp_teamviewer_remote_session",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_susp_teamviewer_remote_session.eql",
  "raw_query": "any where (file.path like~ (\"*\\\\TeamViewer\\\\RemotePrinting\\\\tvprint.db\", \"*\\\\TeamViewer\\\\TVNetwork.log\")) or (file.path:\"*\\\\TeamViewer*\" and file.path:\"*_Logfile.log*\")",
  "conditions": [
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": "like~",
      "values": [
        "tvprint.db",
        "tvnetwork.log"
      ],
      "raw_values": [
        "*\\\\TeamViewer\\\\RemotePrinting\\\\tvprint.db",
        "*\\\\TeamViewer\\\\TVNetwork.log"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        "teamviewer",
        "_logfile.log"
      ],
      "raw_values": [
        "*\\\\TeamViewer*",
        "*_Logfile.log*"
      ]
    }
  ]
}
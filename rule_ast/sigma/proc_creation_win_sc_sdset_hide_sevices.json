{
  "source": "sigma",
  "name": "proc_creation_win_sc_sdset_hide_sevices",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_sc_sdset_hide_sevices.eql",

{
  "source": "sigma",
  "name": "win_security_hidden_user_creation",
  "subtree": "rules",
  "category": "builtin",
  "sigma_path": "rules/windows/builtin/security/win_security_hidden_user_creation.eql",
  "raw_query": "any where winlog.channel:\"Security\" and ((event.code:\"4720\" and winlog.event_data.TargetUserName:\"*$\") and (not winlog.event_data.TargetUserName:\"HomeGroupUser$\"))",
  "conditions": [
    {
      "field": "winlog.channel",
      "raw_field": "winlog.channel",
      "operator": ":",
      "values": [
        "security"
      ],
      "raw_values": [
        "Security"
      ]
    },
    {
      "field": "event.code",
      "raw_field": "event.code",
      "operator": ":",
      "values": [
        "4720"
      ],
      "raw_values": [
        "4720"
      ]
    },
    {
      "field": "winlog.event_data.targetusername",
      "raw_field": "winlog.event_data.TargetUserName",
      "operator": ":",
      "values": [
        "homegroupuser$"
      ],
      "raw_values": [
        "*$",
        "HomeGroupUser$"
      ]
    }
  ]
}
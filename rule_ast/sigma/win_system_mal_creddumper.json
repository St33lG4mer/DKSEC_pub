{
  "source": "sigma",
  "name": "win_system_mal_creddumper",
  "subtree": "rules",
  "category": "builtin",
  "sigma_path": "rules/windows/builtin/system/service_control_manager/win_system_mal_creddumper.eql",
  "raw_query": "any where winlog.channel:\"System\" and (winlog.provider_name:\"Service Control Manager\" and event.code:\"7045\" and (winlog.event_data.ImagePath like~ (\"*cachedump*\", \"*dumpsvc*\", \"*fgexec*\", \"*gsecdump*\", \"*mimidrv*\", \"*pwdump*\", \"*servpw*\")))",
  "conditions": [
    {
      "field": "winlog.event_data.imagepath",
      "raw_field": "winlog.event_data.ImagePath",
      "operator": "like~",
      "values": [
        "cachedump",
        "dumpsvc",
        "fgexec",
        "gsecdump",
        "mimidrv",
        "pwdump",
        "servpw"
      ],
      "raw_values": [
        "*cachedump*",
        "*dumpsvc*",
        "*fgexec*",
        "*gsecdump*",
        "*mimidrv*",
        "*pwdump*",
        "*servpw*"
      ]
    },
    {
      "field": "winlog.channel",
      "raw_field": "winlog.channel",
      "operator": ":",
      "values": [
        "system"
      ],
      "raw_values": [
        "System"
      ]
    },
    {
      "field": "winlog.provider_name",
      "raw_field": "winlog.provider_name",
      "operator": ":",
      "values": [
        "service control manager"
      ],
      "raw_values": [
        "Service Control Manager"
      ]
    },
    {
      "field": "event.code",
      "raw_field": "event.code",
      "operator": ":",
      "values": [
        "7045"
      ],
      "raw_values": [
        "7045"
      ]
    }
  ]
}
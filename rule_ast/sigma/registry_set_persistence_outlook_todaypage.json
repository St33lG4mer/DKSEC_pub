{
  "source": "sigma",
  "name": "registry_set_persistence_outlook_todaypage",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_persistence_outlook_todaypage.eql",
  "raw_query": "any where (registry.path:\"*Software\\\\Microsoft\\\\Office\\\\*\" and registry.path:\"*\\\\Outlook\\\\Today\\\\*\") and ((registry.path:\"*\\\\Stamp\" and winlog.event_data.Details:\"DWORD (0x00000001)\") or (registry.path like~ (\"*\\\\URL\", \"*\\\\UserDefinedUrl\"))) and (not ((process.executable like~ (\"C:\\\\Program Files\\\\Common Files\\\\Microsoft Shared\\\\ClickToRun\\\\*\", \"C:\\\\Program Files\\\\Common Files\\\\Microsoft Shared\\\\ClickToRun\\\\Updates\\\\*\")) and process.executable:\"*\\\\OfficeClickToRun.exe\"))",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": "like~",
      "values": [
        "\\\\url",
        "\\\\userdefinedurl"
      ],
      "raw_values": [
        "*\\\\URL",
        "*\\\\UserDefinedUrl"
      ]
    },
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "software\\\\microsoft\\\\office\\\\",
        "\\\\outlook\\\\today\\\\",
        "\\\\stamp"
      ],
      "raw_values": [
        "*Software\\\\Microsoft\\\\Office\\\\*",
        "*\\\\Outlook\\\\Today\\\\*",
        "*\\\\Stamp"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        "dword (0x00000001)"
      ],
      "raw_values": [
        "DWORD (0x00000001)"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "officeclicktorun.exe"
      ],
      "raw_values": [
        "*\\\\OfficeClickToRun.exe"
      ]
    }
  ]
}
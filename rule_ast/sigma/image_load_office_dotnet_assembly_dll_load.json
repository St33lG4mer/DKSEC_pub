{
  "source": "sigma",
  "name": "image_load_office_dotnet_assembly_dll_load",
  "subtree": "rules",
  "category": "library",
  "sigma_path": "rules/windows/image_load/image_load_office_dotnet_assembly_dll_load.eql",
  "raw_query": "any where (process.executable like~ (\"*\\\\excel.exe\", \"*\\\\mspub.exe\", \"*\\\\onenote.exe\", \"*\\\\onenoteim.exe\", \"*\\\\outlook.exe\", \"*\\\\powerpnt.exe\", \"*\\\\winword.exe\")) and file.path:\"C:\\\\Windows\\\\assembly\\\\*\"",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "excel.exe",
        "mspub.exe",
        "onenote.exe",
        "onenoteim.exe",
        "outlook.exe",
        "powerpnt.exe",
        "winword.exe"
      ],
      "raw_values": [
        "*\\\\excel.exe",
        "*\\\\mspub.exe",
        "*\\\\onenote.exe",
        "*\\\\onenoteim.exe",
        "*\\\\outlook.exe",
        "*\\\\powerpnt.exe",
        "*\\\\winword.exe"
      ]
    }
  ]
}
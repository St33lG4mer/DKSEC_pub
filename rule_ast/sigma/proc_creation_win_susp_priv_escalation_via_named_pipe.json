{
  "source": "sigma",
  "name": "proc_creation_win_susp_priv_escalation_via_named_pipe",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_susp_priv_escalation_via_named_pipe.eql",
  "raw_query": "any where ((process.executable like~ (\"*\\\\cmd.exe\", \"*\\\\powershell.exe\")) or (process.pe.original_file_name like~ (\"Cmd.Exe\", \"PowerShell.EXE\"))) and (process.command_line:\"*echo*\" and process.command_line:\"*>*\" and process.command_line:\"*\\\\\\\\.\\\\pipe\\\\*\")",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "cmd.exe",
        "powershell.exe"
      ],
      "raw_values": [
        "*\\\\cmd.exe",
        "*\\\\powershell.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": "like~",
      "values": [
        "cmd.exe",
        "powershell.exe"
      ],
      "raw_values": [
        "Cmd.Exe",
        "PowerShell.EXE"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "echo"
      ],
      "raw_values": [
        "*echo*",
        "*>*",
        "*\\\\\\\\.\\\\pipe\\\\*"
      ]
    }
  ]
}
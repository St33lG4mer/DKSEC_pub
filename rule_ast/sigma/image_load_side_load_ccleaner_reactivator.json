{
  "source": "sigma",
  "name": "image_load_side_load_ccleaner_reactivator",
  "subtree": "rules",
  "category": "library",
  "sigma_path": "rules/windows/image_load/image_load_side_load_ccleaner_reactivator.eql",
  "raw_query": "any where file.path:\"*\\\\CCleanerReactivator.dll\" and (not ((process.executable like~ (\"C:\\\\Program Files\\\\CCleaner\\\\*\", \"C:\\\\Program Files (x86)\\\\CCleaner\\\\*\")) and process.executable:\"*\\\\CCleanerReactivator.exe\"))",
  "conditions": [
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        "ccleanerreactivator.dll"
      ],
      "raw_values": [
        "*\\\\CCleanerReactivator.dll"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "ccleanerreactivator.exe"
      ],
      "raw_values": [
        "*\\\\CCleanerReactivator.exe"
      ]
    }
  ]
}
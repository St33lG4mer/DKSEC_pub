        "*\\\\chromium.exe",
        "*\\\\firefox.exe",
        "*\\\\Google\\\\Chrome\\\\Application\\\\chrome.exe",
        "*\\\\iexplore.exe",
        "*\\\\microsoftedge.exe",
        "*\\\\msedge.exe",
        "*\\\\Opera.exe",
        "*\\\\Vivaldi.exe",
        "*\\\\Whale.exe",
        "*\\\\olk.exe",
        "*\\\\Outlook.exe",
        "*\\\\RuntimeBroker.exe",
        "*\\\\Thunderbird.exe",
        "*\\\\Discord.exe",
        "*\\\\Keybase.exe",
        "*\\\\msteams.exe",
        "*\\\\Slack.exe",

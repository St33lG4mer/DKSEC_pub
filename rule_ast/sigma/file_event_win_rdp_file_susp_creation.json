{
  "source": "sigma",
  "name": "file_event_win_rdp_file_susp_creation",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_rdp_file_susp_creation.eql",
  "raw_query": "any where file.path:\"*.rdp\" and (process.executable like~ (\"*\\\\brave.exe\", \"*\\\\CCleaner Browser\\\\Application\\\\CCleanerBrowser.exe\", \"*\\\\chromium.exe\", \"*\\\\firefox.exe\", \"*\\\\Google\\\\Chrome\\\\Application\\\\chrome.exe\", \"*\\\\iexplore.exe\", \"*\\\\microsoftedge.exe\", \"*\\\\msedge.exe\", \"*\\\\Opera.exe\", \"*\\\\Vivaldi.exe\", \"*\\\\Whale.exe\", \"*\\\\olk.exe\", \"*\\\\Outlook.exe\", \"*\\\\RuntimeBroker.exe\", \"*\\\\Thunderbird.exe\", \"*\\\\Discord.exe\", \"*\\\\Keybase.exe\", \"*\\\\msteams.exe\", \"*\\\\Slack.exe\", \"*\\\\teams.exe\"))",

{
  "source": "sigma",
  "name": "proc_creation_win_schtasks_powershell_persistence",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_schtasks_powershell_persistence.eql",
  "raw_query": "any where process.parent.executable:\"C:\\\\WINDOWS\\\\System32\\\\svchost.exe\" and (process.parent.command_line:\"*-k netsvcs*\" and process.parent.command_line:\"*-s Schedule*\") and (process.command_line like~ (\"* -windowstyle hidden\", \"* -w hidden\", \"* -ep bypass\", \"* -noni\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "-windowstyle hidden",
        "-w hidden",
        "-ep bypass",
        "-noni"
      ],
      "raw_values": [
        "* -windowstyle hidden",
        "* -w hidden",
        "* -ep bypass",
        "* -noni"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "svchost.exe"
      ],
      "raw_values": [
        "C:\\\\WINDOWS\\\\System32\\\\svchost.exe"
      ]
    },
    {
      "field": "process.parent.command_line",
      "raw_field": "process.parent.command_line",
      "operator": ":",
      "values": [
        "-k netsvcs",
        "-s schedule"
      ],
      "raw_values": [
        "*-k netsvcs*",
        "*-s Schedule*"
      ]
    }
  ]
}
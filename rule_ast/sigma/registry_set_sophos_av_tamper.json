{
  "source": "sigma",
  "name": "registry_set_sophos_av_tamper",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_sophos_av_tamper.eql",
  "raw_query": "any where (registry.path like~ (\"*\\\\Sophos Endpoint Defense\\\\TamperProtection\\\\Config\\\\SAVEnabled*\", \"*\\\\Sophos Endpoint Defense\\\\TamperProtection\\\\Config\\\\SEDEnabled*\", \"*\\\\Sophos\\\\SAVService\\\\TamperProtection\\\\Enabled*\")) and winlog.event_data.Details:\"DWORD (0x00000000)\"",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": "like~",
      "values": [
        "\\\\sophos endpoint defense\\\\tamperprotection\\\\config\\\\savenabled",
        "\\\\sophos endpoint defense\\\\tamperprotection\\\\config\\\\sedenabled",
        "\\\\sophos\\\\savservice\\\\tamperprotection\\\\enabled"
      ],
      "raw_values": [
        "*\\\\Sophos Endpoint Defense\\\\TamperProtection\\\\Config\\\\SAVEnabled*",
        "*\\\\Sophos Endpoint Defense\\\\TamperProtection\\\\Config\\\\SEDEnabled*",
        "*\\\\Sophos\\\\SAVService\\\\TamperProtection\\\\Enabled*"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        "dword (0x00000000)"
      ],
      "raw_values": [
        "DWORD (0x00000000)"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "file_event_win_winrm_awl_bypass",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_winrm_awl_bypass.eql",
  "raw_query": "any where (file.path like~ (\"*WsmPty.xsl\", \"*WsmTxt.xsl\")) and (not (file.path like~ (\"C:\\\\Windows\\\\System32\\\\*\", \"C:\\\\Windows\\\\SysWOW64\\\\*\")))",
  "conditions": [
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": "like~",
      "values": [
        "wsmpty.xsl",
        "wsmtxt.xsl"
      ],
      "raw_values": [
        "*WsmPty.xsl",
        "*WsmTxt.xsl",
        "C:\\\\Windows\\\\System32\\\\*",
        "C:\\\\Windows\\\\SysWOW64\\\\*"
      ]
    }
  ]
}
{
  "source": "elastic",
  "name": "Potential Modification of Accessibility Binaries",
  "slug": "persistence_priv_escalation_via_accessibility_features",
  "category": "process",
  "language": "eql",
  "risk_score": 73,
  "tags": [
    "Domain: Endpoint",
    "OS: Windows",
    "Use Case: Threat Detection",
    "Tactic: Persistence",
    "Resources: Investigation Guide",
    "Data Source: Elastic Endgame",
    "Data Source: Elastic Defend",
    "Data Source: Sysmon",
    "Data Source: Microsoft Defender for Endpoint"
  ],
  "elastic_path": "rules/windows/persistence_priv_escalation_via_accessibility_features.toml",
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n process.parent.name : (\"Utilman.exe\", \"winlogon.exe\") and user.name == \"SYSTEM\" and\n process.pe.original_file_name : \"?*\" and\n process.args :\n    (\n    \"C:\\\\Windows\\\\System32\\\\osk.exe\",\n    \"C:\\\\Windows\\\\System32\\\\Magnify.exe\",\n    \"C:\\\\Windows\\\\System32\\\\Narrator.exe\",\n    \"C:\\\\Windows\\\\System32\\\\Sethc.exe\",\n    \"utilman.exe\",\n    \"ATBroker.exe\",\n    \"DisplaySwitch.exe\",\n    \"sethc.exe\"\n    )\n and not process.pe.original_file_name in\n    (\n    \"osk.exe\",\n    \"sethc.exe\",\n    \"utilman2.exe\",\n    \"DisplaySwitch.exe\",\n    \"atbroker.exe\",\n    \"ATBroker.exe\",\n    \"ScreenMagnifier.exe\",\n    \"SR.exe\",\n    \"Narrator.exe\",\n    \"magnify.exe\",\n    \"MAGNIFY.EXE\"\n    )\n",
  "conditions": [
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": ":",
      "values": [
        "utilman.exe",
        "winlogon.exe"
      ],
      "raw_values": [
        "Utilman.exe",
        "winlogon.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "osk.exe",
        "magnify.exe",
        "narrator.exe",
        "sethc.exe",
        "utilman.exe",
        "atbroker.exe",
        "displayswitch.exe"
      ],
      "raw_values": [
        "C:\\\\Windows\\\\System32\\\\osk.exe",
        "C:\\\\Windows\\\\System32\\\\Magnify.exe",
        "C:\\\\Windows\\\\System32\\\\Narrator.exe",
        "C:\\\\Windows\\\\System32\\\\Sethc.exe",
        "utilman.exe",
        "ATBroker.exe",
        "DisplaySwitch.exe",
        "sethc.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": "in",
      "values": [
        "osk.exe",
        "sethc.exe",
        "utilman2.exe",
        "displayswitch.exe",
        "atbroker.exe",
        "screenmagnifier.exe",
        "sr.exe",
        "narrator.exe",
        "magnify.exe"
      ],
      "raw_values": [
        "osk.exe",
        "sethc.exe",
        "utilman2.exe",
        "DisplaySwitch.exe",
        "atbroker.exe",
        "ATBroker.exe",
        "ScreenMagnifier.exe",
        "SR.exe",
        "Narrator.exe",
        "magnify.exe",
        "MAGNIFY.EXE"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [

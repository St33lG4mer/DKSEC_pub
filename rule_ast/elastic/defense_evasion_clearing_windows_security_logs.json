      "raw_values": [
        "audit-log-cleared",
        "Log clear"
      ]
    },
    {
      "field": "winlog.channel",
      "raw_field": "winlog.channel",
      "operator": ":",
      "values": [
        "security",
        "system"
      ],
      "raw_values": [
        "Security",
        "System"
      ]
    }
  ]

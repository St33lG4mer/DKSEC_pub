{
  "source": "elastic",
  "name": "System Information Discovery via dmidecode from Parent Shell",
  "slug": "discovery_dmidecode_system_discovery",
  "category": "process",
  "language": "eql",
  "risk_score": 21,
  "tags": [
    "Domain: Endpoint",
    "OS: Linux",
    "Use Case: Threat Detection",
    "Tactic: Discovery",
    "Data Source: Elastic Endgame",
    "Data Source: Elastic Defend",
    "Data Source: SentinelOne",
    "Resources: Investigation Guide"
  ],
  "elastic_path": "rules/linux/discovery_dmidecode_system_discovery.toml",
  "raw_query": "process where host.os.type == \"linux\" and event.type == \"start\" and event.action in (\"exec\", \"exec_event\", \"start\") and\nprocess.name == \"dmidecode\" and process.parent.name in (\"bash\", \"dash\", \"sh\", \"tcsh\", \"csh\", \"zsh\", \"ksh\", \"fish\") and\nprocess.parent.args == \"-c\" and not (\n  process.parent.command_line in (\n    \"/bin/sh -c /usr/sbin/dmidecode | /bin/grep VMware\", \"sh -c dmidecode -s system-manufacturer\"\n  ) or\n  ?process.working_directory in (\n    \"/data/oem_agent/agent_inst/sysman/emd\", \"/opt/rapid7/ir_agent/components/insight_agent/common\", \"/opt/veeam/transport\",\n    \"/data/app/oracle/agent/agent_inst/sysman/emd\", \"/home/nessus\", \"/opt/commvault\", \"/opt/nessus_agent/var/nessus/mod/com.tenable.nessus_agent/data\"\n  ) or\n  process.parent.args like \"printf*\"\n)\n",
  "conditions": [
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "in",
      "values": [
        "exec",
        "exec_event",
        "start"
      ],
      "raw_values": [
        "exec",
        "exec_event",
        "start"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": "in",
      "values": [
        "bash",
        "dash",
        "tcsh",
        "csh",
        "zsh",
        "ksh",
        "fish"
      ],
      "raw_values": [
        "bash",
        "dash",
        "sh",
        "tcsh",
        "csh",
        "zsh",
        "ksh",
        "fish"
      ]
    },
    {
      "field": "process.parent.command_line",
      "raw_field": "process.parent.command_line",
      "operator": "in",
      "values": [
        "grep vmware",
        "sh -c dmidecode -s system-manufacturer"
      ],
      "raw_values": [
        "/bin/sh -c /usr/sbin/dmidecode | /bin/grep VMware",
        "sh -c dmidecode -s system-manufacturer"
      ]
    },
    {
      "field": "process.working_directory",
      "raw_field": "process.working_directory",
      "operator": "in",
      "values": [
        "/data/oem_agent/agent_inst/sysman/emd",
        "/opt/rapid7/ir_agent/components/insight_agent/common",
        "/opt/veeam/transport",
        "/data/app/oracle/agent/agent_inst/sysman/emd",
        "/home/nessus",
        "/opt/commvault",
        "/opt/nessus_agent/var/nessus/mod/com.tenable.nessus_agent/data"
      ],
      "raw_values": [
        "/data/oem_agent/agent_inst/sysman/emd",
        "/opt/rapid7/ir_agent/components/insight_agent/common",
        "/opt/veeam/transport",
        "/data/app/oracle/agent/agent_inst/sysman/emd",
        "/home/nessus",
        "/opt/commvault",
        "/opt/nessus_agent/var/nessus/mod/com.tenable.nessus_agent/data"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "linux"
      ],
      "raw_values": [
        "linux"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "==",
      "values": [
        "dmidecode"
      ],
      "raw_values": [
        "dmidecode"
      ]
    },
    {
      "field": "process.parent.args",
      "raw_field": "process.parent.args",
      "operator": "like",
      "values": [
        "printf"
      ],
      "raw_values": [
        "printf*"
      ]
    }
  ]
}
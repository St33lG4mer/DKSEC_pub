{
  "source": "elastic",
  "name": "Interactive Terminal Spawned via Python",
  "slug": "execution_python_tty_shell",
  "category": "process",
  "language": "eql",
  "risk_score": 73,
  "tags": [
    "Domain: Endpoint",
    "OS: Linux",
    "Use Case: Threat Detection",
    "Tactic: Execution",

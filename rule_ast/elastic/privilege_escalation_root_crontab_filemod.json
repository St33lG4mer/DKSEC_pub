{
  "source": "elastic",
  "name": "Privilege Escalation via Root Crontab File Modification",
  "slug": "privilege_escalation_root_crontab_filemod",
  "category": "file",
  "language": "eql",
  "risk_score": 73,
  "tags": [
    "Domain: Endpoint",
    "OS: macOS",
    "Use Case: Threat Detection",

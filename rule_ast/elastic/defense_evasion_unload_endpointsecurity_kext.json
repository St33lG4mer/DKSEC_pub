{
  "source": "elastic",
  "name": "Attempt to Unload Elastic Endpoint Security Kernel Extension",
  "slug": "defense_evasion_unload_endpointsecurity_kext",
  "category": "process",
  "language": "eql",
  "risk_score": 73,
  "tags": [
    "Domain: Endpoint",
    "OS: macOS",
    "Use Case: Threat Detection",
    "Tactic: Defense Evasion",
    "Data Source: Elastic Defend",
    "Resources: Investigation Guide"
  ],
  "elastic_path": "rules/macos/defense_evasion_unload_endpointsecurity_kext.toml",
  "raw_query": "process where host.os.type == \"macos\" and event.type in (\"start\", \"process_started\") and\n process.name == \"kextunload\" and process.args like~ (\"*.EndpointSecurity\", \"/System/Library/Extensions/EndpointSecurity.kext\", \"EndpointSecurity.kext\")\n",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": "like~",
      "values": [
        ".endpointsecurity",
        "endpointsecurity.kext"
      ],
      "raw_values": [
        "*.EndpointSecurity",
        "/System/Library/Extensions/EndpointSecurity.kext",
        "EndpointSecurity.kext"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "in",
      "values": [
        "start",
        "process_started"
      ],
      "raw_values": [
        "start",
        "process_started"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "macos"
      ],
      "raw_values": [
        "macos"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "==",
      "values": [
        "kextunload"
      ],
      "raw_values": [
        "kextunload"
      ]
    }
  ]
}
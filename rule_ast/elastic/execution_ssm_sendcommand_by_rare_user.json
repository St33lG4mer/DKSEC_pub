  "elastic_path": "rules/integrations/aws/execution_ssm_sendcommand_by_rare_user.toml",
  "raw_query": "data_stream.dataset: \"aws.cloudtrail\"\n    and event.provider: \"ssm.amazonaws.com\"\n    and event.action: \"SendCommand\"\n    and event.outcome: \"success\"\n    and not source.address: (\n      \"ssm-guiconnect.amazonaws.com\" or\n      \"ssm.amazonaws.com\" or\n      \"inspector2.amazonaws.com\"\n    )\n",
  "conditions": [
    {
      "field": "source.address",
      "raw_field": "source.address",
      "operator": ":",
      "values": [
        "ssm-guiconnect.amazonaws.com",
        "ssm.amazonaws.com",
        "inspector2.amazonaws.com"
      ],
      "raw_values": [
        "ssm-guiconnect.amazonaws.com",
        "ssm.amazonaws.com",
        "inspector2.amazonaws.com"
      ]
    },
    {
      "field": "data_stream.dataset",
      "raw_field": "data_stream.dataset",
      "operator": ":",
      "values": [
        "aws.cloudtrail"
      ],
      "raw_values": [
        "aws.cloudtrail"
      ]
    },
    {
      "field": "event.provider",
      "raw_field": "event.provider",
      "operator": ":",
      "values": [
        "ssm.amazonaws.com"
      ],
      "raw_values": [
        "ssm.amazonaws.com"
      ]
    },
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": ":",
      "values": [
        "sendcommand"
      ],
      "raw_values": [
        "SendCommand"
      ]
    },
    {
      "field": "event.outcome",
      "raw_field": "event.outcome",
      "operator": ":",
      "values": [
        "success"
      ],
      "raw_values": [
        "success"
      ]
    }
  ]
}
  "elastic_path": "rules/windows/execution_scripting_remote_webdav.toml",
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n process.name : (\"cmd.exe\", \"powershell.exe\", \"conhost.exe\", \"wscript.exe\", \"mshta.exe\", \"curl.exe\", \"msiexec.exe\", \"bitsadmin.exe\", \"net.exe\") and\n process.command_line : (\"*trycloudflare.com*\", \"*@SSL\\\\*\", \"*\\\\webdav\\\\*\", \"*\\\\DavWWWRoot\\\\*\", \"*\\\\\\\\*.*@8080\\\\*\", \"*\\\\\\\\*.*@80\\\\*\", \"*\\\\\\\\*.*@8443\\\\*\", \"*\\\\\\\\*.*@443\\\\*\") and\n not (process.name : \"cmd.exe\" and process.args : \"\\\\\\\\?\\\\UNC\\\\*.sharepoint.com@SSL\\\\DavWWWRoot\\\\*\")\n",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "cmd.exe",
        "powershell.exe",
        "conhost.exe",
        "wscript.exe",
        "mshta.exe",
        "curl.exe",
        "msiexec.exe",
        "bitsadmin.exe",
        "net.exe"
      ],
      "raw_values": [
        "cmd.exe",
        "powershell.exe",
        "conhost.exe",
        "wscript.exe",
        "mshta.exe",
        "curl.exe",
        "msiexec.exe",
        "bitsadmin.exe",
        "net.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "trycloudflare.com"
      ],
      "raw_values": [
        "*trycloudflare.com*",
        "*@SSL\\\\*",
        "*\\\\webdav\\\\*",
        "*\\\\DavWWWRoot\\\\*",
        "*\\\\\\\\*.*@8080\\\\*",
        "*\\\\\\\\*.*@80\\\\*",
        "*\\\\\\\\*.*@8443\\\\*",
        "*\\\\\\\\*.*@443\\\\*",
        "\\\\\\\\?\\\\UNC\\\\*.sharepoint.com@SSL\\\\DavWWWRoot\\\\*"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    }
  ]
}
{
  "source": "elastic",
  "name": "Suspicious Execution from a WebDav Share",
  "slug": "execution_scripting_remote_webdav",
  "category": "process",
  "language": "eql",
  "risk_score": 73,
  "tags": [
    "Domain: Endpoint",
    "OS: Windows",
    "Use Case: Threat Detection",
    "Tactic: Execution",
    "Data Source: Elastic Endgame",

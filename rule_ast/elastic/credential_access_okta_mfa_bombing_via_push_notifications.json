  "elastic_path": "rules/integrations/okta/credential_access_okta_mfa_bombing_via_push_notifications.toml",
  "raw_query": "sequence by okta.actor.id with maxspan=10m\n  [ any\n    where data_stream.dataset == \"okta.system\"\n      and (\n        okta.event_type == \"user.mfa.okta_verify.deny_push\"\n        or (\n          okta.event_type == \"user.authentication.auth_via_mfa\"\n          and okta.debug_context.debug_data.factor == \"OKTA_VERIFY_PUSH\"\n          and okta.outcome.reason == \"INVALID_CREDENTIALS\"\n        )\n      )\n  ] with runs=5\n  until\n  [ any\n    where data_stream.dataset == \"okta.system\"\n      and okta.event_type in (\n        \"user.authentication.sso\",\n        \"user.authentication.auth_via_mfa\",\n        \"user.authentication.verify\",\n        \"user.session.start\"\n      )\n      and okta.outcome.result == \"SUCCESS\"\n  ]\n",
  "conditions": [
    {
      "field": "okta.event_type",
      "raw_field": "okta.event_type",
      "operator": "in",
      "values": [
        "user.authentication.sso",
        "user.authentication.auth_via_mfa",
        "user.authentication.verify",
        "user.session.start"
      ],
      "raw_values": [
        "user.authentication.sso",
        "user.authentication.auth_via_mfa",
        "user.authentication.verify",
        "user.session.start"
      ]
    },
    {
      "field": "data_stream.dataset",
      "raw_field": "data_stream.dataset",
      "operator": "==",
      "values": [
        "okta.system"
      ],
      "raw_values": [
        "okta.system"
      ]
    },
    {
      "field": "okta.event_type",
      "raw_field": "okta.event_type",
      "operator": "==",
      "values": [
        "user.mfa.okta_verify.deny_push",
        "user.authentication.auth_via_mfa"
      ],
      "raw_values": [
        "user.mfa.okta_verify.deny_push",
        "user.authentication.auth_via_mfa"
      ]
    },
    {
      "field": "okta.debug_context.debug_data.factor",
      "raw_field": "okta.debug_context.debug_data.factor",
      "operator": "==",
      "values": [
        "okta_verify_push"
      ],
      "raw_values": [
        "OKTA_VERIFY_PUSH"
      ]
    },
    {
      "field": "okta.outcome.reason",
      "raw_field": "okta.outcome.reason",
      "operator": "==",
      "values": [
        "invalid_credentials"
      ],
      "raw_values": [
        "INVALID_CREDENTIALS"
      ]
    },
    {
      "field": "okta.outcome.result",
      "raw_field": "okta.outcome.result",
      "operator": "==",
      "values": [
        "success"
      ],
      "raw_values": [
        "SUCCESS"
      ]
    }
  ]
}
{
  "source": "elastic",
  "name": "Potential Okta MFA Bombing via Push Notifications",
  "slug": "credential_access_okta_mfa_bombing_via_push_notifications",
  "category": "any",
  "language": "eql",
  "risk_score": 73,
  "tags": [
    "Domain: Identity",
    "Use Case: Identity and Access Audit",

        "windows"
      ]
    },
    {
      "field": "source.ip",
      "raw_field": "source.ip",
      "operator": "!=",
      "values": [
        "127.0.0.1"
      ],
      "raw_values": [
        "127.0.0.1"
      ]
    },
    {
      "field": "destination.ip",
      "raw_field": "destination.ip",
      "operator": "!=",
      "values": [
        "::1",
        "127.0.0.1"
      ],

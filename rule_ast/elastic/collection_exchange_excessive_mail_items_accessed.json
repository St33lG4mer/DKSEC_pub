  "elastic_path": "rules/integrations/o365/collection_exchange_excessive_mail_items_accessed.toml",
  "raw_query": "data_stream.dataset: \"o365.audit\" and\n    event.provider: \"Exchange\" and\n    event.action: \"MailItemsAccessed\" and\n    event.code: \"ExchangeItemAggregated\" and\n    (\n        (\n            o365.audit.OperationProperties.Name: \"IsThrottled\" and\n            o365.audit.OperationProperties.Value: \"True\"\n        ) or o365.audit.OperationCount >= 100\n    )\n",
  "conditions": [
    {
      "field": "data_stream.dataset",
      "raw_field": "data_stream.dataset",
      "operator": ":",
      "values": [
        "o365.audit"
      ],
      "raw_values": [
        "o365.audit"
      ]
    },
    {
      "field": "event.provider",
      "raw_field": "event.provider",
      "operator": ":",
      "values": [
        "exchange"
      ],
      "raw_values": [
        "Exchange"
      ]
    },
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": ":",
      "values": [
        "mailitemsaccessed"
      ],
      "raw_values": [
        "MailItemsAccessed"
      ]
    },
    {
      "field": "event.code",
      "raw_field": "event.code",
      "operator": ":",
      "values": [
        "exchangeitemaggregated"
      ],
      "raw_values": [
        "ExchangeItemAggregated"

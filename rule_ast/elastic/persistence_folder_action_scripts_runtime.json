{
  "source": "elastic",
  "name": "Persistence via Folder Action Script",
  "slug": "persistence_folder_action_scripts_runtime",
  "category": "process",
  "language": "eql",
  "risk_score": 47,
  "tags": [
    "Domain: Endpoint",
    "OS: macOS",
    "Use Case: Threat Detection",
    "Tactic: Execution",
    "Tactic: Persistence",
    "Data Source: Elastic Defend",
    "Resources: Investigation Guide"
  ],
  "elastic_path": "rules/macos/persistence_folder_action_scripts_runtime.toml",
  "raw_query": "process where host.os.type == \"macos\" and event.type in (\"start\", \"process_started\") and process.parent.name == \"com.apple.foundation.UserScriptService\" and \n ((process.name like~ (\"osascript\", \"python*\", \"tcl*\", \"node\", \"perl\", \"ruby\", \"php\")) or \n  (process.name in (\"bash\", \"csh\", \"zsh\", \"sh\") and process.args == \"-c\")) and \n not process.args like (\"/Users/*/Library/Scripts/*\", \"/Users/*/Library/Application Scripts/*\", \"/Library/Scripts/*\")\n",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "like~",
      "values": [
        "osascript",
        "python",
        "tcl",
        "node",
        "perl",
        "ruby",
        "php"
      ],
      "raw_values": [
        "osascript",
        "python*",
        "tcl*",
        "node",
        "perl",
        "ruby",
        "php"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "in",
      "values": [
        "start",
        "process_started"
      ],
      "raw_values": [
        "start",
        "process_started"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "in",
      "values": [
        "bash",
        "csh",
        "zsh"
      ],
      "raw_values": [
        "bash",
        "csh",
        "zsh",
        "sh"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "macos"
      ],
      "raw_values": [
        "macos"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": "==",
      "values": [
        "com.apple.foundation.userscriptservice"
      ],
      "raw_values": [
        "com.apple.foundation.UserScriptService"
      ]
    }
  ]
}
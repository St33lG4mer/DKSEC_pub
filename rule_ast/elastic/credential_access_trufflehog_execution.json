  "raw_query": "process where event.type == \"start\" and process.name : (\"trufflehog.exe\", \"trufflehog\") and\nprocess.args == \"--json\" and process.args == \"filesystem\"\n",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "trufflehog.exe",
        "trufflehog"
      ],
      "raw_values": [
        "trufflehog.exe",
        "trufflehog"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": "==",
      "values": [
        "--json",
        "filesystem"
      ],
      "raw_values": [
        "--json",
        "filesystem"
      ]
    }

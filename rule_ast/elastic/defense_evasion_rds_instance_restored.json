      ],
      "raw_values": [
        "RestoreDBInstanceFromDBSnapshot",
        "RestoreDBInstanceFromS3"
      ]
    },
    {
      "field": "data_stream.dataset",
      "raw_field": "data_stream.dataset",
      "operator": ":",
      "values": [

  "raw_query": "data_stream.dataset: \"aws.cloudtrail\"\n    and event.provider: \"rds.amazonaws.com\"\n    and event.action: (\"RestoreDBInstanceFromDBSnapshot\" or \"RestoreDBInstanceFromS3\")\n    and event.outcome: \"success\"\n",

{
  "source": "elastic",
  "name": "First Time Seen NewCredentials Logon Process",
  "slug": "privilege_escalation_newcreds_logon_rare_process",
  "category": "any",
  "language": "kuery",
  "risk_score": 47,
  "tags": [
    "Domain: Endpoint",
    "OS: Windows",
    "Use Case: Threat Detection",
    "Tactic: Privilege Escalation",
    "Data Source: Windows Security Event Logs",
    "Resources: Investigation Guide"
  ],
  "elastic_path": "rules/windows/privilege_escalation_newcreds_logon_rare_process.toml",
  "raw_query": "event.category:\"authentication\" and host.os.type:\"windows\" and winlog.logon.type:\"NewCredentials\" and\n    winlog.event_data.LogonProcessName:Advapi* and\n    not winlog.event_data.SubjectUserName:*$ and\n    not process.executable: (C\\:\\\\Program*Files*\\(x86\\)\\\\*.exe or C\\:\\\\Program*Files\\\\*.exe)\n",
  "conditions": [
    {
      "field": "event.category",
      "raw_field": "event.category",
      "operator": ":",
      "values": [
        "authentication"
      ],
      "raw_values": [
        "authentication"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": ":",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "winlog.logon.type",
      "raw_field": "winlog.logon.type",
      "operator": ":",
      "values": [
        "newcredentials"
      ],
      "raw_values": [
        "NewCredentials"
      ]
    }
  ]
}
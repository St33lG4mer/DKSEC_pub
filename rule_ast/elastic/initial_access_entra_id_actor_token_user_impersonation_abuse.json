{
  "source": "elastic",
  "name": "Entra ID Actor Token User Impersonation Abuse",
  "slug": "initial_access_entra_id_actor_token_user_impersonation_abuse",
  "category": "any",
  "language": "esql",
  "risk_score": 47,
  "tags": [
    "Domain: Cloud",
    "Domain: Identity",
    "Data Source: Azure",
    "Data Source: Entra ID",
    "Data Source: Entra Audit Logs",
    "Use Case: Identity and Access Audit",

{
  "source": "elastic",
  "name": "Suspicious Content Extracted or Decompressed via Funzip",
  "slug": "execution_sus_extraction_or_decrompression_via_funzip",
  "category": "process",
  "language": "eql",
  "risk_score": 47,
  "tags": [
    "Domain: Endpoint",

        "FF00::/8",
        "0.0.0.0"
      ]
    },
    {
      "field": "destination.port",
      "raw_field": "destination.port",
      "operator": ":",
      "values": [
        "2049",
        "111",
        "892",
        "597"
      ],
      "raw_values": [
        "2049",

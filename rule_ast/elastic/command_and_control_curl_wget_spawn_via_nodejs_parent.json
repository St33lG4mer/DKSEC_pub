  "elastic_path": "rules/cross-platform/command_and_control_curl_wget_spawn_via_nodejs_parent.toml",
  "raw_query": "process where event.type == \"start\" and\nevent.action in (\"exec\", \"exec_event\", \"start\", \"ProcessRollup2\", \"executed\", \"process_started\") and\nprocess.parent.name in (\"node\", \"bun\", \"node.exe\", \"bun.exe\") and (\n(\n  process.name in (\"bash\", \"dash\", \"sh\", \"tcsh\", \"csh\", \"zsh\", \"ksh\", \"fish\", \"cmd.exe\", \"bash.exe\", \"powershell.exe\") and\n  process.command_line like~ (\"*curl*http*\", \"*wget*http*\")\n) or \n(\n  process.name in (\"curl\", \"wget\", \"curl.exe\", \"wget.exe\")\n)\n) and not (\n  process.command_line like (\"*127.0.0.1*\", \"*localhost*\", \"*/home/*/.claude/shell-snapshots/*\", \"*/root/.claude/shell-snapshots/snapshot*\", \"*/Users/*/.claude/shell-snapshots/*\") or\n  process.parent.executable like (\"/*/.cursor-server/*node\", \"/home/*/cursor-agent/*/node\") \n)\n",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "curl*http",
        "wget*http"
      ],
      "raw_values": [
        "*curl*http*",
        "*wget*http*"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "127.0.0.1",
        "localhost",
        "snapshot"
      ],
      "raw_values": [
        "*127.0.0.1*",
        "*localhost*",
        "*/home/*/.claude/shell-snapshots/*",
        "*/root/.claude/shell-snapshots/snapshot*",
        "*/Users/*/.claude/shell-snapshots/*"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "node"
      ],
      "raw_values": [
        "/*/.cursor-server/*node",
        "/home/*/cursor-agent/*/node"
      ]
    },
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "in",
      "values": [
        "exec",
        "exec_event",
        "start",
        "processrollup2",
        "executed",
        "process_started"
      ],
      "raw_values": [

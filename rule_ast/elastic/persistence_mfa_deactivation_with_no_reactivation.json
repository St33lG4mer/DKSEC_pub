  "elastic_path": "rules/integrations/okta/persistence_mfa_deactivation_with_no_reactivation.toml",
  "raw_query": "sequence by okta.target.id with maxspan=12h\n    [any where data_stream.dataset == \"okta.system\" and okta.event_type in (\"user.mfa.factor.deactivate\", \"user.mfa.factor.reset_all\")\n        and okta.outcome.reason != \"User reset SECURITY_QUESTION factor\" and okta.outcome.result == \"SUCCESS\"]\n    ![any where data_stream.dataset == \"okta.system\" and okta.event_type == \"user.mfa.factor.activate\"]\n",
  "conditions": [
    {
      "field": "okta.event_type",
      "raw_field": "okta.event_type",
      "operator": "in",
      "values": [
        "user.mfa.factor.deactivate",
        "user.mfa.factor.reset_all"
      ],
      "raw_values": [
        "user.mfa.factor.deactivate",
        "user.mfa.factor.reset_all"
      ]
    },
    {
      "field": "data_stream.dataset",
      "raw_field": "data_stream.dataset",
      "operator": "==",
      "values": [
        "okta.system"
      ],
      "raw_values": [
        "okta.system"
      ]
    },
    {
      "field": "okta.outcome.reason",
      "raw_field": "okta.outcome.reason",
      "operator": "!=",
      "values": [
        "user reset security_question factor"
      ],
      "raw_values": [
        "User reset SECURITY_QUESTION factor"
      ]
    },
    {
      "field": "okta.outcome.result",
      "raw_field": "okta.outcome.result",
      "operator": "==",
      "values": [
        "success"
      ],
      "raw_values": [
        "SUCCESS"
      ]
    },
    {
      "field": "okta.event_type",
      "raw_field": "okta.event_type",
      "operator": "==",
      "values": [
        "user.mfa.factor.activate"
      ],
      "raw_values": [
        "user.mfa.factor.activate"
      ]
    }
  ]
}
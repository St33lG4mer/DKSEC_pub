{
  "source": "elastic",
  "name": "Untrusted Driver Loaded",
  "slug": "defense_evasion_untrusted_driver_loaded",
  "category": "driver",
  "language": "eql",
  "risk_score": 73,
  "tags": [
    "Domain: Endpoint",
    "OS: Windows",
    "Use Case: Threat Detection",

  "elastic_path": "rules/windows/defense_evasion_untrusted_driver_loaded.toml",
  "raw_query": "driver where host.os.type == \"windows\" and process.pid == 4 and\n  (dll.code_signature.trusted == false or dll.code_signature.exists == false) and\n  not dll.code_signature.status : (\"errorExpired\", \"errorRevoked\", \"errorCode_endpoint:*\")\n",
  "conditions": [
    {
      "field": "dll.code_signature.status",
      "raw_field": "dll.code_signature.status",
      "operator": ":",
      "values": [
        "errorexpired",
        "errorrevoked",
        "errorcode_endpoint:"
      ],
      "raw_values": [
        "errorExpired",
        "errorRevoked",
        "errorCode_endpoint:*"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    }
  ]
}
{
  "source": "elastic",
  "name": "Linux Video Recording or Screenshot Activity Detected",
  "slug": "collection_potential_video_recording_or_screenshot_activity",
  "category": "any",
  "language": "kuery",
  "risk_score": 21,
  "tags": [
    "Domain: Endpoint",

  "elastic_path": "rules/linux/collection_potential_video_recording_or_screenshot_activity.toml",
  "raw_query": "event.category:process and host.os.type:\"linux\" and event.type:\"start\" and event.action:(\"exec\" or \"exec_event\" or \"start\") and\nprocess.name:(\n  \"gnome-screenshot\" or \"spectacle\" or \"xfce4-screenshooter\" or \"mate-screenshot\" or \"scrot\" or \"maim\" or \"import\" or \"grim\" or\n  \"grimshot\" or \"slurp\" or \"flameshot\" or \"shutter\" or \"ksnip\" or \"deepin-screenshot\" or \"simplescreenrecorder\" or \"kazam\" or\n  \"vokoscreen\" or \"recordmydesktop\" or \"obs\" or \"obs-studio\"\n) and\nnot process.args:(\"-h\" or \"--help\" or \"--version\")\n",
  "conditions": [
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": ":",
      "values": [
        "exec",

{
  "source": "elastic",
  "name": "Suspicious Microsoft HTML Application Child Process",
  "slug": "defense_evasion_mshta_susp_child",
  "category": "process",
  "language": "eql",
  "risk_score": 73,
  "tags": [
    "Domain: Endpoint",
    "OS: Windows",
    "Use Case: Threat Detection",
    "Tactic: Defense Evasion",
    "Data Source: Elastic Endgame",
    "Data Source: Elastic Defend",
    "Data Source: Windows Security Event Logs",
    "Data Source: Microsoft Defender for Endpoint",
    "Data Source: Sysmon",
    "Data Source: SentinelOne",
    "Data Source: Crowdstrike",
    "Resources: Investigation Guide"
  ],
  "elastic_path": "rules/windows/defense_evasion_mshta_susp_child.toml",
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n process.parent.name : \"mshta.exe\" and\n (\n  process.name : (\"cmd.exe\", \"powershell.exe\", \"certutil.exe\", \"bitsadmin.exe\", \"curl.exe\", \"msiexec.exe\", \"schtasks.exe\", \"reg.exe\", \"wscript.exe\", \"rundll32.exe\") or\n  process.executable : (\"C:\\\\Users\\\\*\\\\*.exe\", \"\\\\Device\\\\HarddiskVolume*\\\\Users\\\\*\\\\*.exe\")\n  )\n",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "cmd.exe",
        "powershell.exe",
        "certutil.exe",
        "bitsadmin.exe",
        "curl.exe",
        "msiexec.exe",
        "schtasks.exe",
        "reg.exe",
        "wscript.exe",
        "rundll32.exe",
        ".exe"
      ],
      "raw_values": [
        "cmd.exe",
        "powershell.exe",
        "certutil.exe",
        "bitsadmin.exe",
        "curl.exe",
        "msiexec.exe",
        "schtasks.exe",
        "reg.exe",
        "wscript.exe",
        "rundll32.exe",
        "C:\\\\Users\\\\*\\\\*.exe",
        "\\\\Device\\\\HarddiskVolume*\\\\Users\\\\*\\\\*.exe"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": ":",
      "values": [
        "mshta.exe"
      ],
      "raw_values": [
        "mshta.exe"
      ]
    }
  ]
}
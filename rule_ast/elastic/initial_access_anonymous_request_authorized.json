  "elastic_path": "rules/integrations/kubernetes/initial_access_anonymous_request_authorized.toml",
  "raw_query": "data_stream.dataset:\"kubernetes.audit_logs\" and\nkubernetes.audit.annotations.authorization_k8s_io/decision:\"allow\" and\nkubernetes.audit.user.username:(\"system:anonymous\" or \"system:unauthenticated\" or not *) and\nuser_agent.original:(* and not (*kubernetes/$Format)) and\nnot kubernetes.audit.requestURI:(/healthz* or /livez* or /readyz* or /version or /.well-known/oauth-authorization-server)\n",
  "conditions": [
    {
      "field": "kubernetes.audit.user.username",
      "raw_field": "kubernetes.audit.user.username",
      "operator": ":",
      "values": [
        "system:anonymous",
        "system:unauthenticated"
      ],
      "raw_values": [
        "system:anonymous",
        "system:unauthenticated"
      ]
    },
    {
      "field": "data_stream.dataset",
      "raw_field": "data_stream.dataset",
      "operator": ":",
      "values": [
        "kubernetes.audit_logs"
      ],
      "raw_values": [
        "kubernetes.audit_logs"
      ]
    },
    {
      "field": "decision",
      "raw_field": "decision",
      "operator": ":",
      "values": [
        "allow"
      ],
      "raw_values": [
        "allow"
      ]
    }
  ]
}
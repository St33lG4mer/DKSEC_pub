{
  "source": "elastic",
  "name": "Curl SOCKS Proxy Detected via Defend for Containers",
  "slug": "command_and_control_curl_socks_proxy_detected_inside_container",
  "category": "process",
  "language": "eql",
  "risk_score": 47,
  "tags": [
    "Data Source: Elastic Defend for Containers",

        "*;BA*",
        "*;SY*",
        "*;WD*",
        "sdset",
        "*D;*"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],

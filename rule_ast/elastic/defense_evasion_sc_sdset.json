  "elastic_path": "rules/windows/defense_evasion_sc_sdset.toml",
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n  (process.name : \"sc.exe\" or ?process.pe.original_file_name : \"sc.exe\") and\n  process.args : \"sdset\" and process.args : \"*D;*\" and\n  process.args : (\"*;IU*\", \"*;SU*\", \"*;BA*\", \"*;SY*\", \"*;WD*\")\n",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.args",

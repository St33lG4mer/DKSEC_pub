{
  "source": "elastic",
  "name": "Process Spawned from Message-of-the-Day (MOTD)",
  "slug": "persistence_message_of_the_day_execution",
  "category": "process",
  "language": "eql",
  "risk_score": 73,
  "tags": [
    "Domain: Endpoint",

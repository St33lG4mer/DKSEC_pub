        "*TCPSocket.open*",
        "*io.popen*",
        "*os.execute*",
        "./*",
        "/boot/*",
        "/dev/shm/*",
        "/etc/cron.*/*",
        "/etc/init.d/*",
        "/etc/update-motd.d/*",

  "elastic_path": "rules/integrations/aws/defense_evasion_cloudwatch_alarm_deletion.toml",
  "raw_query": "data_stream.dataset: \"aws.cloudtrail\" \n  and event.provider: \"monitoring.amazonaws.com\" \n  and event.action: \"DeleteAlarms\"\n  and event.outcome: \"success\"\n  and source.ip: *\n  and not user_agent.original : \"AWS Internal\"\n",
  "conditions": [
    {
      "field": "data_stream.dataset",
      "raw_field": "data_stream.dataset",
      "operator": ":",
      "values": [
        "aws.cloudtrail"
      ],
      "raw_values": [
        "aws.cloudtrail"
      ]
    },
    {
      "field": "event.provider",
      "raw_field": "event.provider",
      "operator": ":",
      "values": [
        "monitoring.amazonaws.com"
      ],
      "raw_values": [
        "monitoring.amazonaws.com"
      ]
    },
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": ":",
      "values": [
        "deletealarms"
      ],
      "raw_values": [
        "DeleteAlarms"
      ]
    },
    {
      "field": "event.outcome",
      "raw_field": "event.outcome",
      "operator": ":",
      "values": [
        "success"
      ],
      "raw_values": [
        "success"
      ]
    },
    {
      "field": "user_agent.original",
      "raw_field": "user_agent.original",
      "operator": ":",
      "values": [
        "aws internal"
      ],
      "raw_values": [
        "AWS Internal"
      ]
    }
  ]
}
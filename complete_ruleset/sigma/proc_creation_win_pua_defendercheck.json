{
  "source": "sigma",
  "name": "proc_creation_win_pua_defendercheck",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_pua_defendercheck.eql",
  "raw_query": "any where process.executable:\"*\\\\DefenderCheck.exe\" or process.pe.description:\"DefenderCheck\"",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "defendercheck.exe"
      ],
      "raw_values": [
        "*\\\\DefenderCheck.exe"
      ]
    },
    {
      "field": "process.pe.description",
      "raw_field": "process.pe.description",
      "operator": ":",
      "values": [
        "defendercheck"
      ],
      "raw_values": [
        "DefenderCheck"
      ]
    }
  ]
}
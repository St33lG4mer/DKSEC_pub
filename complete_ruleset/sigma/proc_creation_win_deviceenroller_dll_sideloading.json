{
  "source": "sigma",
  "name": "proc_creation_win_deviceenroller_dll_sideloading",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_deviceenroller_dll_sideloading.eql",
  "raw_query": "any where (process.executable:\"*\\\\deviceenroller.exe\" or process.pe.original_file_name:\"deviceenroller.exe\") and process.command_line:\"*/PhoneDeepLink*\"",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "deviceenroller.exe"
      ],
      "raw_values": [
        "*\\\\deviceenroller.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "deviceenroller.exe"
      ],
      "raw_values": [
        "deviceenroller.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "phonedeeplink"
      ],
      "raw_values": [
        "*/PhoneDeepLink*"
      ]
    }
  ]
}
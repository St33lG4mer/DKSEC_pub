{
  "source": "sigma",
  "name": "file_event_win_new_files_in_uncommon_appdata_folder",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_new_files_in_uncommon_appdata_folder.eql",
  "raw_query": "any where (file.path:\"C:\\\\Users\\\\*\" and file.path:\"*\\\\AppData\\\\*\" and (file.path like~ (\"*.bat\", \"*.cmd\", \"*.cpl\", \"*.dll\", \"*.exe\", \"*.hta\", \"*.iso\", \"*.lnk\", \"*.msi\", \"*.ps1\", \"*.psm1\", \"*.scr\", \"*.vbe\", \"*.vbs\"))) and (not (file.path:\"C:\\\\Users\\\\*\" and (file.path like~ (\"*\\\\AppData\\\\Local\\\\*\", \"*\\\\AppData\\\\LocalLow\\\\*\", \"*\\\\AppData\\\\Roaming\\\\*\"))))",
  "conditions": [
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": "like~",
      "values": [
        ".bat",
        ".cmd",
        ".cpl",
        ".dll",
        ".exe",
        ".hta",
        ".iso",
        ".lnk",
        ".msi",
        ".ps1",
        ".psm1",
        ".scr",
        ".vbe",
        ".vbs"
      ],
      "raw_values": [
        "*.bat",
        "*.cmd",
        "*.cpl",
        "*.dll",
        "*.exe",
        "*.hta",
        "*.iso",
        "*.lnk",
        "*.msi",
        "*.ps1",
        "*.psm1",
        "*.scr",
        "*.vbe",
        "*.vbs",
        "*\\\\AppData\\\\Local\\\\*",
        "*\\\\AppData\\\\LocalLow\\\\*",
        "*\\\\AppData\\\\Roaming\\\\*"
      ]
    }
  ]
}
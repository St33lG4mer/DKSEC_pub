{
  "source": "sigma",
  "name": "proc_creation_win_dtrace_kernel_dump",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_dtrace_kernel_dump.eql",
  "raw_query": "any where (process.executable:\"*\\\\dtrace.exe\" and process.command_line:\"*lkd(0)*\") or (process.command_line:\"*syscall:::return*\" and process.command_line:\"*lkd(*\")",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "dtrace.exe"
      ],
      "raw_values": [
        "*\\\\dtrace.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "lkd(0)",
        "syscall:::return",
        "lkd("
      ],
      "raw_values": [
        "*lkd(0)*",
        "*syscall:::return*",
        "*lkd(*"
      ]
    }
  ]
}
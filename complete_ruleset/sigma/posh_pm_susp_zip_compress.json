{
  "source": "sigma",
  "name": "posh_pm_susp_zip_compress",
  "subtree": "rules",
  "category": "powershell",
  "sigma_path": "rules/windows/powershell/powershell_module/posh_pm_susp_zip_compress.eql",
  "raw_query": "any where winlog.event_data.ContextInfo:\"*Compress-Archive -Path*-DestinationPath $env:TEMP*\" and winlog.event_data.ContextInfo:\"*Compress-Archive -Path*-DestinationPath*\\\\AppData\\\\Local\\\\Temp\\\\*\" and winlog.event_data.ContextInfo:\"*Compress-Archive -Path*-DestinationPath*:\\\\Windows\\\\Temp\\\\*\"",
  "conditions": [
    {
      "field": "winlog.event_data.contextinfo",
      "raw_field": "winlog.event_data.ContextInfo",
      "operator": ":",
      "values": [
        "compress-archive -path*-destinationpath $env:temp",
        "compress-archive -path*-destinationpath*\\\\appdata\\\\local\\\\temp\\\\",
        "compress-archive -path*-destinationpath*:\\\\windows\\\\temp\\\\"
      ],
      "raw_values": [
        "*Compress-Archive -Path*-DestinationPath $env:TEMP*",
        "*Compress-Archive -Path*-DestinationPath*\\\\AppData\\\\Local\\\\Temp\\\\*",
        "*Compress-Archive -Path*-DestinationPath*:\\\\Windows\\\\Temp\\\\*"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "proc_creation_win_renamed_rurat",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_renamed_rurat.eql",
  "raw_query": "any where process.pe.product:\"Remote Utilities\" and (not (process.executable like~ (\"*\\\\rutserv.exe\", \"*\\\\rfusclient.exe\")))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "rutserv.exe",
        "rfusclient.exe"
      ],
      "raw_values": [
        "*\\\\rutserv.exe",
        "*\\\\rfusclient.exe"
      ]
    },
    {
      "field": "process.pe.product",
      "raw_field": "process.pe.product",
      "operator": ":",
      "values": [
        "remote utilities"
      ],
      "raw_values": [
        "Remote Utilities"
      ]
    }
  ]
}
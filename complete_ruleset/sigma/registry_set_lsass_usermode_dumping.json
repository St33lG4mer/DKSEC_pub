{
  "source": "sigma",
  "name": "registry_set_lsass_usermode_dumping",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_lsass_usermode_dumping.eql",
  "raw_query": "any where (registry.path like~ (\"*\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\Windows Error Reporting\\\\LocalDumps\\\\DumpType*\", \"*\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\Windows Error Reporting\\\\LocalDumps\\\\lsass.exe\\\\DumpType*\")) and winlog.event_data.Details:\"DWORD (0x00000002)\"",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": "like~",
      "values": [
        "\\\\software\\\\microsoft\\\\windows\\\\windows error reporting\\\\localdumps\\\\dumptype",
        "\\\\software\\\\microsoft\\\\windows\\\\windows error reporting\\\\localdumps\\\\lsass.exe\\\\dumptype"
      ],
      "raw_values": [
        "*\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\Windows Error Reporting\\\\LocalDumps\\\\DumpType*",
        "*\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\Windows Error Reporting\\\\LocalDumps\\\\lsass.exe\\\\DumpType*"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        "dword (0x00000002)"
      ],
      "raw_values": [
        "DWORD (0x00000002)"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "file_event_win_susp_executable_creation",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_susp_executable_creation.eql",
  "raw_query": "any where file.path like~ (\"*:\\\\$Recycle.Bin.exe\", \"*:\\\\Documents and Settings.exe\", \"*:\\\\MSOCache.exe\", \"*:\\\\PerfLogs.exe\", \"*:\\\\Recovery.exe\", \"*.bat.exe\", \"*.sys.exe\")",
  "conditions": [
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": "like~",
      "values": [
        "$recycle.bin.exe",
        "documents and settings.exe",
        "msocache.exe",
        "perflogs.exe",
        "recovery.exe",
        ".bat.exe",
        ".sys.exe"
      ],
      "raw_values": [
        "*:\\\\$Recycle.Bin.exe",
        "*:\\\\Documents and Settings.exe",
        "*:\\\\MSOCache.exe",
        "*:\\\\PerfLogs.exe",
        "*:\\\\Recovery.exe",
        "*.bat.exe",
        "*.sys.exe"
      ]
    }
  ]
}
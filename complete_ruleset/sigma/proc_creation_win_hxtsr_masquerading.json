{
  "source": "sigma",
  "name": "proc_creation_win_hxtsr_masquerading",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_hxtsr_masquerading.eql",
  "raw_query": "any where process.executable:\"*\\\\hxtsr.exe\" and (not (process.executable:\"*:\\\\program files\\\\windowsapps\\\\microsoft.windowscommunicationsapps_*\" and process.executable:\"*\\\\hxtsr.exe\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "hxtsr.exe",
        "microsoft.windowscommunicationsapps_"
      ],
      "raw_values": [
        "*\\\\hxtsr.exe",
        "*:\\\\program files\\\\windowsapps\\\\microsoft.windowscommunicationsapps_*"
      ]
    }
  ]
}
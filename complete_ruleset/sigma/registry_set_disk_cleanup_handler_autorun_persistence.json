{
  "source": "sigma",
  "name": "registry_set_disk_cleanup_handler_autorun_persistence",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_disk_cleanup_handler_autorun_persistence.eql",
  "raw_query": "any where registry.path:\"*\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Explorer\\\\VolumeCaches\\\\*\" and ((registry.path:\"*\\\\Autorun*\" and winlog.event_data.Details:\"DWORD (0x00000001)\") or ((registry.path like~ (\"*\\\\CleanupString*\", \"*\\\\PreCleanupString*\")) and (winlog.event_data.Details like~ (\"*cmd*\", \"*powershell*\", \"*rundll32*\", \"*mshta*\", \"*cscript*\", \"*wscript*\", \"*wsl*\", \"*\\\\Users\\\\Public\\\\*\", \"*\\\\Windows\\\\TEMP\\\\*\", \"*\\\\Microsoft\\\\Windows\\\\Start Menu\\\\Programs\\\\Startup\\\\*\"))))",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": "like~",
      "values": [
        "\\\\cleanupstring",
        "\\\\precleanupstring"
      ],
      "raw_values": [
        "*\\\\CleanupString*",
        "*\\\\PreCleanupString*"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": "like~",
      "values": [
        "cmd",
        "powershell",
        "rundll32",
        "mshta",
        "cscript",
        "wscript",
        "wsl",
        "\\\\users\\\\public\\\\",
        "\\\\windows\\\\temp\\\\",
        "\\\\microsoft\\\\windows\\\\start menu\\\\programs\\\\startup\\\\"
      ],
      "raw_values": [
        "*cmd*",
        "*powershell*",
        "*rundll32*",
        "*mshta*",
        "*cscript*",
        "*wscript*",
        "*wsl*",
        "*\\\\Users\\\\Public\\\\*",
        "*\\\\Windows\\\\TEMP\\\\*",
        "*\\\\Microsoft\\\\Windows\\\\Start Menu\\\\Programs\\\\Startup\\\\*"
      ]
    },
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\software\\\\microsoft\\\\windows\\\\currentversion\\\\explorer\\\\volumecaches\\\\",
        "\\\\autorun"
      ],
      "raw_values": [
        "*\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Explorer\\\\VolumeCaches\\\\*",
        "*\\\\Autorun*"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        "dword (0x00000001)"
      ],
      "raw_values": [
        "DWORD (0x00000001)"
      ]
    }
  ]
}
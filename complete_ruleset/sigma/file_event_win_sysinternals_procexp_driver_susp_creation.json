{
  "source": "sigma",
  "name": "file_event_win_sysinternals_procexp_driver_susp_creation",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_sysinternals_procexp_driver_susp_creation.eql",
  "raw_query": "any where (file.path:\"*\\\\PROCEXP*\" and file.path:\"*.sys\") and (not (process.executable like~ (\"*\\\\procexp.exe\", \"*\\\\procexp64.exe\")))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "procexp.exe",
        "procexp64.exe"
      ],
      "raw_values": [
        "*\\\\procexp.exe",
        "*\\\\procexp64.exe"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        "procexp",
        ".sys"
      ],
      "raw_values": [
        "*\\\\PROCEXP*",
        "*.sys"
      ]
    }
  ]
}
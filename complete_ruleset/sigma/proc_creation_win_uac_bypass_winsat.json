{
  "source": "sigma",
  "name": "proc_creation_win_uac_bypass_winsat",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_uac_bypass_winsat.eql",
  "raw_query": "any where (winlog.event_data.IntegrityLevel like~ (\"High\", \"System\", \"S-1-16-16384\", \"S-1-16-12288\")) and process.parent.executable:\"*\\\\AppData\\\\Local\\\\Temp\\\\system32\\\\winsat.exe\" and process.parent.command_line:\"*C:\\\\Windows \\\\system32\\\\winsat.exe*\"",
  "conditions": [
    {
      "field": "winlog.event_data.integritylevel",
      "raw_field": "winlog.event_data.IntegrityLevel",
      "operator": "like~",
      "values": [
        "high",
        "system",
        "s-1-16-16384",
        "s-1-16-12288"
      ],
      "raw_values": [
        "High",
        "System",
        "S-1-16-16384",
        "S-1-16-12288"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "winsat.exe"
      ],
      "raw_values": [
        "*\\\\AppData\\\\Local\\\\Temp\\\\system32\\\\winsat.exe"
      ]
    },
    {
      "field": "process.parent.command_line",
      "raw_field": "process.parent.command_line",
      "operator": ":",
      "values": [
        "winsat.exe"
      ],
      "raw_values": [
        "*C:\\\\Windows \\\\system32\\\\winsat.exe*"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "proc_creation_win_lolbin_mavinject_process_injection",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_lolbin_mavinject_process_injection.eql",
  "raw_query": "any where process.command_line:\"* /INJECTRUNNING *\" and (not process.parent.executable:\"C:\\\\Windows\\\\System32\\\\AppVClient.exe\")",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "injectrunning"
      ],
      "raw_values": [
        "* /INJECTRUNNING *"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.executable",
      "operator": ":",
      "values": [
        "appvclient.exe"
      ],
      "raw_values": [
        "C:\\\\Windows\\\\System32\\\\AppVClient.exe"
      ]
    }
  ]
}
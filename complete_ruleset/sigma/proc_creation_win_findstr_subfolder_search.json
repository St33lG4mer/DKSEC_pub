{
  "source": "sigma",
  "name": "proc_creation_win_findstr_subfolder_search",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_findstr_subfolder_search.eql",
  "raw_query": "any where (process.command_line:\"*findstr*\" or process.executable:\"*findstr.exe\" or process.pe.original_file_name:\"FINDSTR.EXE\") and (process.command_line like~ (\"* -s *\", \"* /s *\", \"* \u2013s *\", \"* \u2014s *\", \"* \u2015s *\") and process.command_line like~ (\"* -i *\", \"* /i *\", \"* \u2013i *\", \"* \u2014i *\", \"* \u2015i *\"))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "findstr"
      ],
      "raw_values": [
        "*findstr*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "findstr.exe"
      ],
      "raw_values": [
        "*findstr.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "findstr.exe"
      ],
      "raw_values": [
        "FINDSTR.EXE"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "proc_creation_win_nltest_execution",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_nltest_execution.eql",
  "raw_query": "any where process.executable:\"*\\\\nltest.exe\" or process.pe.original_file_name:\"nltestrk.exe\"",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "nltest.exe"
      ],
      "raw_values": [
        "*\\\\nltest.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "nltestrk.exe"
      ],
      "raw_values": [
        "nltestrk.exe"
      ]
    }
  ]
}
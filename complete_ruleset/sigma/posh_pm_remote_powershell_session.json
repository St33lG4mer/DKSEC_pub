{
  "source": "sigma",
  "name": "posh_pm_remote_powershell_session",
  "subtree": "rules",
  "category": "powershell",
  "sigma_path": "rules/windows/powershell/powershell_module/posh_pm_remote_powershell_session.eql",
  "raw_query": "any where (winlog.event_data.ContextInfo:\"* = ServerRemoteHost *\" and winlog.event_data.ContextInfo:\"*wsmprovhost.exe*\") and (not winlog.event_data.ContextInfo:\"*\\\\Windows\\\\system32\\\\WindowsPowerShell\\\\v1.0\\\\Modules\\\\Microsoft.PowerShell.Archive\\\\Microsoft.PowerShell.Archive.psm1*\")",
  "conditions": [
    {
      "field": "winlog.event_data.contextinfo",
      "raw_field": "winlog.event_data.ContextInfo",
      "operator": ":",
      "values": [
        "= serverremotehost",
        "wsmprovhost.exe",
        "\\\\windows\\\\system32\\\\windowspowershell\\\\v1.0\\\\modules\\\\microsoft.powershell.archive\\\\microsoft.powershell.archive.psm1"
      ],
      "raw_values": [
        "* = ServerRemoteHost *",
        "*wsmprovhost.exe*",
        "*\\\\Windows\\\\system32\\\\WindowsPowerShell\\\\v1.0\\\\Modules\\\\Microsoft.PowerShell.Archive\\\\Microsoft.PowerShell.Archive.psm1*"
      ]
    }
  ]
}
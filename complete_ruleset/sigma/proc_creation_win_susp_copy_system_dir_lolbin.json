{
  "source": "sigma",
  "name": "proc_creation_win_susp_copy_system_dir_lolbin",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_susp_copy_system_dir_lolbin.eql",
  "raw_query": "any where ((process.executable:\"*\\\\cmd.exe\" and process.command_line:\"*copy *\") or ((process.executable like~ (\"*\\\\powershell.exe\", \"*\\\\pwsh.exe\")) and (process.command_line like~ (\"*copy-item*\", \"* copy *\", \"*cpi *\", \"* cp *\"))) or ((process.executable like~ (\"*\\\\robocopy.exe\", \"*\\\\xcopy.exe\")) or (process.pe.original_file_name like~ (\"robocopy.exe\", \"XCOPY.EXE\")))) and ((process.command_line like~ (\"*\\\\System32*\", \"*\\\\SysWOW64*\", \"*\\\\WinSxS*\")) and (process.command_line like~ (\"*\\\\bitsadmin.exe*\", \"*\\\\calc.exe*\", \"*\\\\certutil.exe*\", \"*\\\\cmdl32.exe*\", \"*\\\\cscript.exe*\", \"*\\\\mshta.exe*\", \"*\\\\rundll32.exe*\", \"*\\\\wscript.exe*\", \"*\\\\ie4uinit.exe*\")))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "powershell.exe",
        "pwsh.exe",
        "robocopy.exe",
        "xcopy.exe"
      ],
      "raw_values": [
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe",
        "*\\\\robocopy.exe",
        "*\\\\xcopy.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "copy-item",
        "copy",
        "cpi",
        "system32",
        "syswow64",
        "winsxs",
        "bitsadmin.exe",
        "calc.exe",
        "certutil.exe",
        "cmdl32.exe",
        "cscript.exe",
        "mshta.exe",
        "rundll32.exe",
        "wscript.exe",
        "ie4uinit.exe"
      ],
      "raw_values": [
        "*copy-item*",
        "* copy *",
        "*cpi *",
        "* cp *",
        "*\\\\System32*",
        "*\\\\SysWOW64*",
        "*\\\\WinSxS*",
        "*\\\\bitsadmin.exe*",
        "*\\\\calc.exe*",
        "*\\\\certutil.exe*",
        "*\\\\cmdl32.exe*",
        "*\\\\cscript.exe*",
        "*\\\\mshta.exe*",
        "*\\\\rundll32.exe*",
        "*\\\\wscript.exe*",
        "*\\\\ie4uinit.exe*"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": "like~",
      "values": [
        "robocopy.exe",
        "xcopy.exe"
      ],
      "raw_values": [
        "robocopy.exe",
        "XCOPY.EXE"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "cmd.exe"
      ],
      "raw_values": [
        "*\\\\cmd.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "copy"
      ],
      "raw_values": [
        "*copy *"
      ]
    }
  ]
}
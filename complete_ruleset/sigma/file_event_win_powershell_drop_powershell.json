{
  "source": "sigma",
  "name": "file_event_win_powershell_drop_powershell",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_powershell_drop_powershell.eql",
  "raw_query": "any where ((process.executable like~ (\"*\\\\powershell.exe\", \"*\\\\pwsh.exe\")) and file.path:\"*.ps1\") and (not (file.path:\"*__PSScriptPolicyTest_*\" or (file.path:\"C:\\\\Users\\\\*\" and file.path:\"*\\\\AppData\\\\Local\\\\Temp\\\\*\") or file.path:\"C:\\\\Windows\\\\Temp\\\\*\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "powershell.exe",
        "pwsh.exe"
      ],
      "raw_values": [
        "*\\\\powershell.exe",
        "*\\\\pwsh.exe"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        ".ps1",
        "__psscriptpolicytest_"
      ],
      "raw_values": [
        "*.ps1",
        "*__PSScriptPolicyTest_*",
        "C:\\\\Users\\\\*",
        "*\\\\AppData\\\\Local\\\\Temp\\\\*",
        "C:\\\\Windows\\\\Temp\\\\*"
      ]
    }
  ]
}
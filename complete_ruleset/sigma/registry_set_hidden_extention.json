{
  "source": "sigma",
  "name": "registry_set_hidden_extention",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_hidden_extention.eql",
  "raw_query": "any where (registry.path:\"*\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Explorer\\\\Advanced\\\\HideFileExt\" and winlog.event_data.Details:\"DWORD (0x00000001)\") or (registry.path:\"*\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Explorer\\\\Advanced\\\\Hidden\" and winlog.event_data.Details:\"DWORD (0x00000002)\")",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\software\\\\microsoft\\\\windows\\\\currentversion\\\\explorer\\\\advanced\\\\hidefileext",
        "\\\\software\\\\microsoft\\\\windows\\\\currentversion\\\\explorer\\\\advanced\\\\hidden"
      ],
      "raw_values": [
        "*\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Explorer\\\\Advanced\\\\HideFileExt",
        "*\\\\SOFTWARE\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\Explorer\\\\Advanced\\\\Hidden"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        "dword (0x00000001)",
        "dword (0x00000002)"
      ],
      "raw_values": [
        "DWORD (0x00000001)",
        "DWORD (0x00000002)"
      ]
    }
  ]
}
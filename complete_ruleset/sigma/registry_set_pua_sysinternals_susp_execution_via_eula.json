{
  "source": "sigma",
  "name": "registry_set_pua_sysinternals_susp_execution_via_eula",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_pua_sysinternals_susp_execution_via_eula.eql",
  "raw_query": "any where (registry.path like~ (\"*\\\\Active Directory Explorer*\", \"*\\\\Handle*\", \"*\\\\LiveKd*\", \"*\\\\Process Explorer*\", \"*\\\\ProcDump*\", \"*\\\\PsExec*\", \"*\\\\PsLoglist*\", \"*\\\\PsPasswd*\", \"*\\\\SDelete*\", \"*\\\\Sysinternals*\")) and registry.path:\"*\\\\EulaAccepted\"",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": "like~",
      "values": [
        "\\\\active directory explorer",
        "\\\\handle",
        "\\\\livekd",
        "\\\\process explorer",
        "\\\\procdump",
        "\\\\psexec",
        "\\\\psloglist",
        "\\\\pspasswd",
        "\\\\sdelete",
        "\\\\sysinternals"
      ],
      "raw_values": [
        "*\\\\Active Directory Explorer*",
        "*\\\\Handle*",
        "*\\\\LiveKd*",
        "*\\\\Process Explorer*",
        "*\\\\ProcDump*",
        "*\\\\PsExec*",
        "*\\\\PsLoglist*",
        "*\\\\PsPasswd*",
        "*\\\\SDelete*",
        "*\\\\Sysinternals*"
      ]
    },
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\eulaaccepted"
      ],
      "raw_values": [
        "*\\\\EulaAccepted"
      ]
    }
  ]
}
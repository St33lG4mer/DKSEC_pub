{
  "source": "sigma",
  "name": "registry_set_powershell_as_service",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_powershell_as_service.eql",
  "raw_query": "any where registry.path:\"*\\\\Services\\\\*\" and registry.path:\"*\\\\ImagePath\" and (winlog.event_data.Details like~ (\"*powershell*\", \"*pwsh*\"))",
  "conditions": [
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": "like~",
      "values": [
        "powershell",
        "pwsh"
      ],
      "raw_values": [
        "*powershell*",
        "*pwsh*"
      ]
    },
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\services\\\\",
        "\\\\imagepath"
      ],
      "raw_values": [
        "*\\\\Services\\\\*",
        "*\\\\ImagePath"
      ]
    }
  ]
}
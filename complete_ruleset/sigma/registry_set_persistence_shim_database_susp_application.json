{
  "source": "sigma",
  "name": "registry_set_persistence_shim_database_susp_application",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_persistence_shim_database_susp_application.eql",
  "raw_query": "any where registry.path:\"*\\\\SOFTWARE\\\\Microsoft\\\\Windows NT\\\\CurrentVersion\\\\AppCompatFlags\\\\Custom\\\\*\" and (registry.path like~ (\"*\\\\csrss.exe\", \"*\\\\dllhost.exe\", \"*\\\\explorer.exe\", \"*\\\\RuntimeBroker.exe\", \"*\\\\services.exe\", \"*\\\\sihost.exe\", \"*\\\\svchost.exe\", \"*\\\\taskhostw.exe\", \"*\\\\winlogon.exe\", \"*\\\\WmiPrvSe.exe\"))",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": "like~",
      "values": [
        "\\\\csrss.exe",
        "\\\\dllhost.exe",
        "\\\\explorer.exe",
        "\\\\runtimebroker.exe",
        "\\\\services.exe",
        "\\\\sihost.exe",
        "\\\\svchost.exe",
        "\\\\taskhostw.exe",
        "\\\\winlogon.exe",
        "\\\\wmiprvse.exe"
      ],
      "raw_values": [
        "*\\\\csrss.exe",
        "*\\\\dllhost.exe",
        "*\\\\explorer.exe",
        "*\\\\RuntimeBroker.exe",
        "*\\\\services.exe",
        "*\\\\sihost.exe",
        "*\\\\svchost.exe",
        "*\\\\taskhostw.exe",
        "*\\\\winlogon.exe",
        "*\\\\WmiPrvSe.exe"
      ]
    },
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\software\\\\microsoft\\\\windows nt\\\\currentversion\\\\appcompatflags\\\\custom\\\\"
      ],
      "raw_values": [
        "*\\\\SOFTWARE\\\\Microsoft\\\\Windows NT\\\\CurrentVersion\\\\AppCompatFlags\\\\Custom\\\\*"
      ]
    }
  ]
}
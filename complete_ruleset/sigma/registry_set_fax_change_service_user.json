{
  "source": "sigma",
  "name": "registry_set_fax_change_service_user",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_fax_change_service_user.eql",
  "raw_query": "any where registry.path:\"HKLM\\\\System\\\\CurrentControlSet\\\\Services\\\\Fax\\\\ObjectName\" and (not winlog.event_data.Details:\"*NetworkService*\")",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "hklm\\\\system\\\\currentcontrolset\\\\services\\\\fax\\\\objectname"
      ],
      "raw_values": [
        "HKLM\\\\System\\\\CurrentControlSet\\\\Services\\\\Fax\\\\ObjectName"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        "networkservice"
      ],
      "raw_values": [
        "*NetworkService*"
      ]
    }
  ]
}
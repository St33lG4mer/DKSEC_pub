{
  "source": "sigma",
  "name": "proc_creation_win_susp_gather_network_info_execution",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_susp_gather_network_info_execution.eql",
  "raw_query": "any where process.command_line:\"*gatherNetworkInfo.vbs*\" and (not (process.executable like~ (\"*\\\\cscript.exe\", \"*\\\\wscript.exe\")))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "cscript.exe",
        "wscript.exe"
      ],
      "raw_values": [
        "*\\\\cscript.exe",
        "*\\\\wscript.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "gathernetworkinfo.vbs"
      ],
      "raw_values": [
        "*gatherNetworkInfo.vbs*"
      ]
    }
  ]
}
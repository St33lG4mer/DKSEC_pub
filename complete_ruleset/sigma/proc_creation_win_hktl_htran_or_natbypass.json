{
  "source": "sigma",
  "name": "proc_creation_win_hktl_htran_or_natbypass",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_hktl_htran_or_natbypass.eql",
  "raw_query": "any where (process.executable like~ (\"*\\\\htran.exe\", \"*\\\\lcx.exe\")) or (process.command_line like~ (\"*.exe -tran *\", \"*.exe -slave *\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "htran.exe",
        "lcx.exe"
      ],
      "raw_values": [
        "*\\\\htran.exe",
        "*\\\\lcx.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        ".exe -tran",
        ".exe -slave"
      ],
      "raw_values": [
        "*.exe -tran *",
        "*.exe -slave *"
      ]
    }
  ]
}
{
  "source": "sigma",
  "name": "proc_creation_win_regsvr32_remote_share",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_regsvr32_remote_share.eql",
  "raw_query": "any where (process.executable:\"*\\\\regsvr32.exe\" or process.pe.original_file_name:\"\\\\REGSVR32.EXE\") and process.command_line:\"* \\\\\\\\*\"",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "regsvr32.exe"
      ],
      "raw_values": [
        "*\\\\regsvr32.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "\\\\regsvr32.exe"
      ],
      "raw_values": [
        "\\\\REGSVR32.EXE"
      ]
    }
  ]
}
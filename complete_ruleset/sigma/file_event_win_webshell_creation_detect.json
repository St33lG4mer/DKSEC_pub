{
  "source": "sigma",
  "name": "file_event_win_webshell_creation_detect",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_webshell_creation_detect.eql",
  "raw_query": "any where ((file.path:\"*\\\\inetpub\\\\wwwroot\\\\*\" and (file.path like~ (\"*.ashx*\", \"*.asp*\", \"*.ph*\", \"*.soap*\"))) or ((file.path like~ (\"*\\\\www\\\\*\", \"*\\\\htdocs\\\\*\", \"*\\\\html\\\\*\")) and file.path:\"*.ph*\")) and (not ((file.path like~ (\"*\\\\AppData\\\\Local\\\\Temp\\\\*\", \"*\\\\Windows\\\\Temp\\\\*\")) or process.executable:\"System\" or file.path:\"*\\\\xampp*\"))",
  "conditions": [
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": "like~",
      "values": [
        ".ashx",
        ".asp",
        ".ph",
        ".soap"
      ],
      "raw_values": [
        "*.ashx*",
        "*.asp*",
        "*.ph*",
        "*.soap*",
        "*\\\\www\\\\*",
        "*\\\\htdocs\\\\*",
        "*\\\\html\\\\*",
        "*\\\\AppData\\\\Local\\\\Temp\\\\*",
        "*\\\\Windows\\\\Temp\\\\*"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        ".ph",
        "xampp"
      ],
      "raw_values": [
        "*\\\\inetpub\\\\wwwroot\\\\*",
        "*.ph*",
        "*\\\\xampp*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "system"
      ],
      "raw_values": [
        "System"
      ]
    }
  ]
}
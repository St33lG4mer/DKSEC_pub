{
  "source": "sigma",
  "name": "win_security_invoke_obfuscation_via_use_rundll32_services_security",
  "subtree": "rules",
  "category": "builtin",
  "sigma_path": "rules/windows/builtin/security/win_security_invoke_obfuscation_via_use_rundll32_services_security.eql",
  "raw_query": "any where winlog.channel:\"Security\" and (event.code:\"4697\" and (winlog.event_data.ServiceFileName:\"*&&*\" and winlog.event_data.ServiceFileName:\"*rundll32*\" and winlog.event_data.ServiceFileName:\"*shell32.dll*\" and winlog.event_data.ServiceFileName:\"*shellexec_rundll*\") and (winlog.event_data.ServiceFileName like~ (\"*value*\", \"*invoke*\", \"*comspec*\", \"*iex*\")))",
  "conditions": [
    {
      "field": "winlog.event_data.servicefilename",
      "raw_field": "winlog.event_data.ServiceFileName",
      "operator": "like~",
      "values": [
        "value",
        "invoke",
        "comspec",
        "iex"
      ],
      "raw_values": [
        "*value*",
        "*invoke*",
        "*comspec*",
        "*iex*"
      ]
    },
    {
      "field": "winlog.channel",
      "raw_field": "winlog.channel",
      "operator": ":",
      "values": [
        "security"
      ],
      "raw_values": [
        "Security"
      ]
    },
    {
      "field": "event.code",
      "raw_field": "event.code",
      "operator": ":",
      "values": [
        "4697"
      ],
      "raw_values": [
        "4697"
      ]
    },
    {
      "field": "winlog.event_data.servicefilename",
      "raw_field": "winlog.event_data.ServiceFileName",
      "operator": ":",
      "values": [
        "rundll32",
        "shell32.dll",
        "shellexec_rundll"
      ],
      "raw_values": [
        "*&&*",
        "*rundll32*",
        "*shell32.dll*",
        "*shellexec_rundll*"
      ]
    }
  ]
}
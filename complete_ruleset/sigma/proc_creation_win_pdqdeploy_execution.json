{
  "source": "sigma",
  "name": "proc_creation_win_pdqdeploy_execution",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_pdqdeploy_execution.eql",
  "raw_query": "any where process.pe.description:\"PDQ Deploy Console\" or process.pe.product:\"PDQ Deploy\" or process.pe.company:\"PDQ.com\" or process.pe.original_file_name:\"PDQDeployConsole.exe\"",
  "conditions": [
    {
      "field": "process.pe.description",
      "raw_field": "process.pe.description",
      "operator": ":",
      "values": [
        "pdq deploy console"
      ],
      "raw_values": [
        "PDQ Deploy Console"
      ]
    },
    {
      "field": "process.pe.product",
      "raw_field": "process.pe.product",
      "operator": ":",
      "values": [
        "pdq deploy"
      ],
      "raw_values": [
        "PDQ Deploy"
      ]
    },
    {
      "field": "process.pe.company",
      "raw_field": "process.pe.company",
      "operator": ":",
      "values": [
        "pdq.com"
      ],
      "raw_values": [
        "PDQ.com"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "pdqdeployconsole.exe"
      ],
      "raw_values": [
        "PDQDeployConsole.exe"
      ]
    }
  ]
}
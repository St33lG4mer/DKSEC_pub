{
  "source": "sigma",
  "name": "registry_set_netsh_help_dll_persistence_susp_location",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_netsh_help_dll_persistence_susp_location.eql",
  "raw_query": "any where registry.path:\"*\\\\SOFTWARE\\\\Microsoft\\\\NetSh*\" and ((winlog.event_data.Details like~ (\"*:\\\\Perflogs\\\\*\", \"*:\\\\Users\\\\Public\\\\*\", \"*:\\\\Windows\\\\Temp\\\\*\", \"*\\\\AppData\\\\Local\\\\Temp\\\\*\", \"*\\\\Temporary Internet*\")) or ((winlog.event_data.Details:\"*:\\\\Users\\\\*\" and winlog.event_data.Details:\"*\\\\Favorites\\\\*\") or (winlog.event_data.Details:\"*:\\\\Users\\\\*\" and winlog.event_data.Details:\"*\\\\Favourites\\\\*\") or (winlog.event_data.Details:\"*:\\\\Users\\\\*\" and winlog.event_data.Details:\"*\\\\Contacts\\\\*\") or (winlog.event_data.Details:\"*:\\\\Users\\\\*\" and winlog.event_data.Details:\"*\\\\Pictures\\\\*\")))",
  "conditions": [
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": "like~",
      "values": [
        ":\\\\perflogs\\\\",
        ":\\\\users\\\\public\\\\",
        ":\\\\windows\\\\temp\\\\",
        "\\\\appdata\\\\local\\\\temp\\\\",
        "\\\\temporary internet"
      ],
      "raw_values": [
        "*:\\\\Perflogs\\\\*",
        "*:\\\\Users\\\\Public\\\\*",
        "*:\\\\Windows\\\\Temp\\\\*",
        "*\\\\AppData\\\\Local\\\\Temp\\\\*",
        "*\\\\Temporary Internet*"
      ]
    },
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\software\\\\microsoft\\\\netsh"
      ],
      "raw_values": [
        "*\\\\SOFTWARE\\\\Microsoft\\\\NetSh*"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        ":\\\\users\\\\",
        "\\\\favorites\\\\",
        "\\\\favourites\\\\",
        "\\\\contacts\\\\",
        "\\\\pictures\\\\"
      ],
      "raw_values": [
        "*:\\\\Users\\\\*",
        "*\\\\Favorites\\\\*",
        "*\\\\Favourites\\\\*",
        "*\\\\Contacts\\\\*",
        "*\\\\Pictures\\\\*"
      ]
    }
  ]
}
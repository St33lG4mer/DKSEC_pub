{
  "source": "sigma",
  "name": "proc_creation_win_powershell_zip_compress",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_powershell_zip_compress.eql",
  "raw_query": "any where process.command_line like~ (\"*Compress-Archive -Path*-DestinationPath $env:TEMP*\", \"*Compress-Archive -Path*-DestinationPath*\\\\AppData\\\\Local\\\\Temp\\\\*\", \"*Compress-Archive -Path*-DestinationPath*:\\\\Windows\\\\Temp\\\\*\")",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "compress-archive -path*-destinationpath $env:temp"
      ],
      "raw_values": [
        "*Compress-Archive -Path*-DestinationPath $env:TEMP*",
        "*Compress-Archive -Path*-DestinationPath*\\\\AppData\\\\Local\\\\Temp\\\\*",
        "*Compress-Archive -Path*-DestinationPath*:\\\\Windows\\\\Temp\\\\*"
      ]
    }
  ]
}
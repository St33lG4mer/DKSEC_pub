{
  "source": "sigma",
  "name": "proc_creation_win_hktl_hydra",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_hktl_hydra.eql",
  "raw_query": "any where (process.command_line:\"*-u *\" and process.command_line:\"*-p *\") and (process.command_line like~ (\"*^USER^*\", \"*^PASS^*\"))",

{
  "source": "sigma",
  "name": "proc_creation_win_wermgr_susp_exec_location",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_wermgr_susp_exec_location.eql",
  "raw_query": "any where process.executable:\"*\\\\wermgr.exe\" and (not (process.executable like~ (\"C:\\\\Windows\\\\System32\\\\*\", \"C:\\\\Windows\\\\SysWOW64\\\\*\", \"C:\\\\Windows\\\\WinSxS\\\\*\")))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "wermgr.exe"
      ],
      "raw_values": [
        "*\\\\wermgr.exe"
      ]
    }
  ]
}
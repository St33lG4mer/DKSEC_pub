{
  "source": "sigma",
  "name": "registry_set_evtx_file_key_tamper",
  "subtree": "rules",
  "category": "registry",
  "sigma_path": "rules/windows/registry/registry_set/registry_set_evtx_file_key_tamper.eql",
  "raw_query": "any where (registry.path:\"*\\\\SYSTEM\\\\CurrentControlSet\\\\Services\\\\EventLog\\\\*\" and registry.path:\"*\\\\File\") and (not winlog.event_data.Details:\"*\\\\System32\\\\Winevt\\\\Logs\\\\*\")",
  "conditions": [
    {
      "field": "registry.path",
      "raw_field": "registry.path",
      "operator": ":",
      "values": [
        "\\\\system\\\\currentcontrolset\\\\services\\\\eventlog\\\\",
        "\\\\file"
      ],
      "raw_values": [
        "*\\\\SYSTEM\\\\CurrentControlSet\\\\Services\\\\EventLog\\\\*",
        "*\\\\File"
      ]
    },
    {
      "field": "registry.data.strings",
      "raw_field": "winlog.event_data.Details",
      "operator": ":",
      "values": [
        "\\\\system32\\\\winevt\\\\logs\\\\"
      ],
      "raw_values": [
        "*\\\\System32\\\\Winevt\\\\Logs\\\\*"
      ]
    }
  ]
}
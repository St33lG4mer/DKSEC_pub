{
  "source": "sigma",
  "name": "proc_creation_win_powershell_download_cradle_obfuscated",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_powershell_download_cradle_obfuscated.eql",
  "raw_query": "any where process.executable:\"*\\\\powershell.exe\" and (process.command_line:\"*http://127.0.0.1*\" and process.command_line:\"*%{(IRM $_)}*\" and process.command_line:\"*Invoke*\")",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "powershell.exe"
      ],
      "raw_values": [
        "*\\\\powershell.exe"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "127.0.0.1",
        "%{(irm $_)}",
        "invoke"
      ],
      "raw_values": [
        "*http://127.0.0.1*",
        "*%{(IRM $_)}*",
        "*Invoke*"
      ]
    }
  ]
}
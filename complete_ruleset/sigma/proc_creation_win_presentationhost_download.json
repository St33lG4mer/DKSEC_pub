{
  "source": "sigma",
  "name": "proc_creation_win_presentationhost_download",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_presentationhost_download.eql",
  "raw_query": "any where (process.executable:\"*\\\\presentationhost.exe\" or process.pe.original_file_name:\"PresentationHost.exe\") and (process.command_line like~ (\"*http://*\", \"*https://*\", \"*ftp://*\"))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "presentationhost.exe"
      ],
      "raw_values": [
        "*\\\\presentationhost.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "presentationhost.exe"
      ],
      "raw_values": [
        "PresentationHost.exe"
      ]
    }
  ]
}
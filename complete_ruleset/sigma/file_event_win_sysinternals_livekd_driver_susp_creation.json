{
  "source": "sigma",
  "name": "file_event_win_sysinternals_livekd_driver_susp_creation",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_sysinternals_livekd_driver_susp_creation.eql",
  "raw_query": "any where file.path:\"C:\\\\Windows\\\\System32\\\\drivers\\\\LiveKdD.SYS\" and (not (process.executable like~ (\"*\\\\livekd.exe\", \"*\\\\livek64.exe\")))",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like~",
      "values": [
        "livekd.exe",
        "livek64.exe"
      ],
      "raw_values": [
        "*\\\\livekd.exe",
        "*\\\\livek64.exe"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": ":",
      "values": [
        "livekdd.sys"
      ],
      "raw_values": [
        "C:\\\\Windows\\\\System32\\\\drivers\\\\LiveKdD.SYS"
      ]
    }
  ]
}
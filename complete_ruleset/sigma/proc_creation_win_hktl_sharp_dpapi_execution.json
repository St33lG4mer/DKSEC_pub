{
  "source": "sigma",
  "name": "proc_creation_win_hktl_sharp_dpapi_execution",
  "subtree": "rules",
  "category": "process",
  "sigma_path": "rules/windows/process_creation/proc_creation_win_hktl_sharp_dpapi_execution.eql",
  "raw_query": "any where (process.executable:\"*\\\\SharpDPAPI.exe\" or process.pe.original_file_name:\"SharpDPAPI.exe\") or ((process.command_line like~ (\"* backupkey *\", \"* blob *\", \"* certificates *\", \"* credentials *\", \"* keepass *\", \"* masterkeys *\", \"* rdg *\", \"* vaults *\")) and ((process.command_line:\"* {*\" and process.command_line:\"*}:*\") or (process.command_line like~ (\"* /file:*\", \"* /machine*\", \"* /mkfile:*\", \"* /password:*\", \"* /pvk:*\", \"* /server:*\", \"* /target:*\", \"* /unprotect*\"))))",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": "like~",
      "values": [
        "backupkey",
        "blob",
        "certificates",
        "credentials",
        "keepass",
        "masterkeys",
        "rdg",
        "vaults",
        "file:",
        "machine",
        "mkfile:",
        "password:",
        "pvk:",
        "server:",
        "target:",
        "unprotect"
      ],
      "raw_values": [
        "* backupkey *",
        "* blob *",
        "* certificates *",
        "* credentials *",
        "* keepass *",
        "* masterkeys *",
        "* rdg *",
        "* vaults *",
        "* /file:*",
        "* /machine*",
        "* /mkfile:*",
        "* /password:*",
        "* /pvk:*",
        "* /server:*",
        "* /target:*",
        "* /unprotect*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "sharpdpapi.exe"
      ],
      "raw_values": [
        "*\\\\SharpDPAPI.exe"
      ]
    },
    {
      "field": "process.pe.original_file_name",
      "raw_field": "process.pe.original_file_name",
      "operator": ":",
      "values": [
        "sharpdpapi.exe"
      ],
      "raw_values": [
        "SharpDPAPI.exe"
      ]
    }
  ]
}
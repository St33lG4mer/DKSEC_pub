{
  "source": "sigma",
  "name": "file_event_win_office_outlook_newform",
  "subtree": "rules",
  "category": "file",
  "sigma_path": "rules/windows/file/file_event/file_event_win_office_outlook_newform.eql",
  "raw_query": "any where process.executable:\"*\\\\outlook.exe\" and (file.path like~ (\"*\\\\AppData\\\\Local\\\\Microsoft\\\\FORMS\\\\IPM*\", \"*\\\\Local Settings\\\\Application Data\\\\Microsoft\\\\Forms*\"))",
  "conditions": [
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": "like~",
      "values": [
        "ipm",
        "forms"
      ],
      "raw_values": [
        "*\\\\AppData\\\\Local\\\\Microsoft\\\\FORMS\\\\IPM*",
        "*\\\\Local Settings\\\\Application Data\\\\Microsoft\\\\Forms*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "outlook.exe"
      ],
      "raw_values": [
        "*\\\\outlook.exe"
      ]
    }
  ]
}
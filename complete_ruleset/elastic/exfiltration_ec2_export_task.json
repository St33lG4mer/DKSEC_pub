        "exportimage",
        "createstoreimagetask"
      ],
      "raw_values": [
        "CreateInstanceExportTask",
        "ExportImage",
        "CreateStoreImageTask"
      ]
    },
    {
      "field": "data_stream.dataset",
      "raw_field": "data_stream.dataset",
      "operator": ":",
      "values": [
        "aws.cloudtrail"
      ],
      "raw_values": [
        "aws.cloudtrail"
      ]
    },
    {
      "field": "event.provider",
      "raw_field": "event.provider",
      "operator": ":",
      "values": [
        "ec2.amazonaws.com"
      ],
      "raw_values": [
        "ec2.amazonaws.com"
      ]
    },
    {
      "field": "event.outcome",
      "raw_field": "event.outcome",
      "operator": ":",
      "values": [
        "success"
      ],
      "raw_values": [

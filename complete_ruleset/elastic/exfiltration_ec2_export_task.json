  "raw_query": "data_stream.dataset: \"aws.cloudtrail\" and \n    event.provider: \"ec2.amazonaws.com\" and \n    event.action: (\"CreateInstanceExportTask\" or \"ExportImage\" or \"CreateStoreImageTask\") and \n    event.outcome: \"success\"\n",

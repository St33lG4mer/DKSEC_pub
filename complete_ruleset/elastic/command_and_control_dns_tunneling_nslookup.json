  "elastic_path": "rules/windows/command_and_control_dns_tunneling_nslookup.toml",
  "raw_query": "sequence by host.id with maxspan=5m\n[process where host.os.type == \"windows\" and event.type == \"start\" and\n  process.name : \"nslookup.exe\" and process.args:(\"-querytype=*\", \"-qt=*\", \"-q=*\", \"-type=*\")] with runs = 10\n",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "-querytype=",
        "-qt=",
        "-q=",
        "-type="
      ],
      "raw_values": [
        "-querytype=*",
        "-qt=*",
        "-q=*",
        "-type=*"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": ":",
      "values": [
        "nslookup.exe"
      ],
      "raw_values": [
        "nslookup.exe"
      ]
    }
  ]
}
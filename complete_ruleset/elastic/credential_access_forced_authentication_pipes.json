  "elastic_path": "rules/cross-platform/credential_access_forced_authentication_pipes.toml",
  "raw_query": "sequence with maxspan=15s\n[network where host.os.type == \"linux\" and event.action == \"connection_attempted\" and destination.port == 445 and not startswith~(string(destination.ip), string(host.ip))] by host.ip, data_stream.namespace\n[file where host.os.type == \"windows\" and event.code == \"5145\" and file.name : (\"Spoolss\", \"netdfs\", \"lsarpc\", \"lsass\", \"netlogon\", \"samr\", \"efsrpc\", \"FssagentRpc\")] by source.ip, data_stream.namespace\n",
  "conditions": [
    {
      "field": "file.name",
      "raw_field": "file.name",
      "operator": ":",
      "values": [
        "spoolss",
        "netdfs",
        "lsarpc",
        "lsass",
        "netlogon",
        "samr",
        "efsrpc",
        "fssagentrpc"
      ],
      "raw_values": [
        "Spoolss",
        "netdfs",
        "lsarpc",
        "lsass",
        "netlogon",
        "samr",
        "efsrpc",

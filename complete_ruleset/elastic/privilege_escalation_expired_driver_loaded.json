  "elastic_path": "rules/windows/privilege_escalation_expired_driver_loaded.toml",
  "raw_query": "driver where host.os.type == \"windows\" and process.pid == 4 and\n  dll.code_signature.status : (\"errorExpired\", \"errorRevoked\")\n",
  "conditions": [
    {
      "field": "dll.code_signature.status",
      "raw_field": "dll.code_signature.status",
      "operator": ":",
      "values": [
        "errorexpired",
        "errorrevoked"
      ],
      "raw_values": [
        "errorExpired",
        "errorRevoked"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    }
  ]
}
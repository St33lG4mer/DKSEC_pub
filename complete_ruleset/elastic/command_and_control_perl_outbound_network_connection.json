        "exec"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "==",
      "values": [
        "perl"
      ],
      "raw_values": [
        "perl"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": "like",
      "values": [
        "xpath"
      ],
      "raw_values": [
        "/usr/bin/xpath"
      ]
    }
  ]

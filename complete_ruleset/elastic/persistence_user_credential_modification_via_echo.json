  "elastic_path": "rules/linux/persistence_user_credential_modification_via_echo.toml",
  "raw_query": "process where host.os.type == \"linux\" and event.type == \"start\" and event.action == \"exec\" and\nprocess.name in (\"bash\", \"dash\", \"sh\", \"tcsh\", \"csh\", \"zsh\", \"ksh\", \"fish\") and\nprocess.command_line like (\n  \"*echo*> /etc/passwd*\", \"*echo*>/etc/passwd*\",\n  \"*echo*> /etc/shadow*\", \"*echo*>/etc/shadow*\"\n) and\nnot (\n  process.parent.command_line == \"runc init\" or\n  process.parent.executable in (\"/usr/bin/make\", \"/bin/make\")\n)\n",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "passwd",
        "shadow"
      ],
      "raw_values": [
        "*echo*> /etc/passwd*",
        "*echo*>/etc/passwd*",
        "*echo*> /etc/shadow*",
        "*echo*>/etc/shadow*"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "in",
      "values": [

{
  "source": "elastic",
  "name": "Linux User Account Credential Modification",
  "slug": "persistence_user_credential_modification_via_echo",
  "category": "process",
  "language": "eql",
  "risk_score": 47,
  "tags": [
    "Domain: Endpoint",

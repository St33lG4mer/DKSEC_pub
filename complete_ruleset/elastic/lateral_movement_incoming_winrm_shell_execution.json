{
  "source": "elastic",
  "name": "Incoming Execution via WinRM Remote Shell",
  "slug": "lateral_movement_incoming_winrm_shell_execution",
  "category": "any",
  "language": "eql",
  "risk_score": 47,
  "tags": [
    "Domain: Endpoint",

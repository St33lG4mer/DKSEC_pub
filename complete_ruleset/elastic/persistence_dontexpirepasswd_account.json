{
  "source": "elastic",
  "name": "Account Configured with Never-Expiring Password",
  "slug": "persistence_dontexpirepasswd_account",
  "category": "any",
  "language": "eql",
  "risk_score": 47,
  "tags": [
    "Domain: Endpoint",
    "OS: Windows",
    "Use Case: Threat Detection",
    "Tactic: Persistence",
    "Data Source: Active Directory",
    "Resources: Investigation Guide",
    "Use Case: Active Directory Monitoring",
    "Data Source: Windows Security Event Logs"
  ],
  "elastic_path": "rules/windows/persistence_dontexpirepasswd_account.toml",
  "raw_query": "any where host.os.type == \"windows\" and\n(\n  (\n    event.code == \"4738\" and winlog.event_data.NewUACList == \"USER_DONT_EXPIRE_PASSWORD\" and not user.id == \"S-1-5-18\"\n  ) or\n  (\n    event.code == \"5136\" and winlog.event_data.AttributeLDAPDisplayName == \"userAccountControl\" and\n    winlog.event_data.AttributeValue in (\"66048\", \"66080\") and winlog.event_data.OperationType == \"%%14674\" and\n    not (\n      winlog.event_data.SubjectUserName : \"*svc*\" or\n      winlog.event_data.ObjectDN : \"*Service*\"\n    )\n  )\n)\n",
  "conditions": [
    {
      "field": "winlog.event_data.attributevalue",
      "raw_field": "winlog.event_data.AttributeValue",
      "operator": "in",
      "values": [
        "66048",
        "66080"
      ],
      "raw_values": [
        "66048",
        "66080"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.code",
      "raw_field": "event.code",
      "operator": "==",
      "values": [
        "4738",
        "5136"
      ],
      "raw_values": [
        "4738",
        "5136"
      ]
    },
    {
      "field": "winlog.event_data.newuaclist",
      "raw_field": "winlog.event_data.NewUACList",
      "operator": "==",
      "values": [
        "user_dont_expire_password"
      ],
      "raw_values": [
        "USER_DONT_EXPIRE_PASSWORD"
      ]
    },
    {
      "field": "user.id",
      "raw_field": "user.id",
      "operator": "==",
      "values": [
        "s-1-5-18"
      ],
      "raw_values": [
        "S-1-5-18"
      ]
    },
    {
      "field": "winlog.event_data.attributeldapdisplayname",
      "raw_field": "winlog.event_data.AttributeLDAPDisplayName",
      "operator": "==",
      "values": [
        "useraccountcontrol"
      ],
      "raw_values": [
        "userAccountControl"
      ]
    },
    {
      "field": "winlog.event_data.operationtype",
      "raw_field": "winlog.event_data.OperationType",
      "operator": "==",
      "values": [
        "%%14674"
      ],
      "raw_values": [
        "%%14674"
      ]
    },
    {
      "field": "winlog.event_data.subjectusername",
      "raw_field": "winlog.event_data.SubjectUserName",
      "operator": ":",
      "values": [
        "svc"
      ],
      "raw_values": [
        "*svc*"
      ]
    },
    {
      "field": "winlog.event_data.objectdn",
      "raw_field": "winlog.event_data.ObjectDN",
      "operator": ":",
      "values": [
        "service"
      ],
      "raw_values": [
        "*Service*"
      ]
    }
  ]
}
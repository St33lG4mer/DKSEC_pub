  "elastic_path": "rules/integrations/aws/impact_rds_snapshot_deleted.toml",
  "raw_query": "any where data_stream.dataset == \"aws.cloudtrail\"\n    and event.provider == \"rds.amazonaws.com\"\n    and event.outcome == \"success\"\n    and (\n        event.action in (\"DeleteDBSnapshot\", \"DeleteDBClusterSnapshot\") or\n        (event.action == \"ModifyDBInstance\" and stringContains(aws.cloudtrail.request_parameters, \"backupRetentionPeriod=0\"))\n    )\n    and not (\n        user_agent.original == \"backup.amazonaws.com\" \n        and source.address == \"backup.amazonaws.com\"\n    )\n",
  "conditions": [
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "in",
      "values": [
        "deletedbsnapshot",
        "deletedbclustersnapshot"
      ],
      "raw_values": [
        "DeleteDBSnapshot",
        "DeleteDBClusterSnapshot"
      ]
    },
    {
      "field": "data_stream.dataset",
      "raw_field": "data_stream.dataset",
      "operator": "==",

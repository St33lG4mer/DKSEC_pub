{
  "source": "elastic",
  "name": "Conhost Spawned By Suspicious Parent Process",
  "slug": "execution_via_hidden_shell_conhost",
  "category": "process",
  "language": "eql",
  "risk_score": 73,
  "tags": [
    "Domain: Endpoint",
    "OS: Windows",
    "Use Case: Threat Detection",
    "Tactic: Execution",

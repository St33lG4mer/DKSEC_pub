      "values": [
        "macos"
      ],
      "raw_values": [
        "macos"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "==",
      "values": [
        "launchctl"
      ],
      "raw_values": [
        "launchctl"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",

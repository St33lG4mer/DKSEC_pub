  "raw_query": "process where host.os.type == \"macos\" and event.type in (\"start\", \"process_started\") and\n  process.name == \"launchctl\" and\n  (process.parent.code_signature.exists == false or process.parent.code_signature.trusted == false) and\n  process.args == \"setenv\"\n",
  "conditions": [
    {
      "field": "event.type",

  "elastic_path": "rules/linux/execution_suspicious_mining_process_creation_events.toml",
  "raw_query": "file where host.os.type == \"linux\" and event.type == \"creation\" and event.action in (\"creation\", \"file_create_event\") and (\n  (\n    file.name like~ (\n      \"moneroocean_miner.service\", \"c3pool_miner.service\", \"pnsd.service\", \"apache4.service\", \"pastebin.service\", \"xvf.service\"\n    )\n  ) or\n  (\n    process.executable like \"/usr/local/share/aliyun-assist/*/aliyun-service\" and file.name like~ \"aliyun.service\"\n  )\n)\n",
  "conditions": [
    {
      "field": "file.name",
      "raw_field": "file.name",
      "operator": "like~",
      "values": [
        "moneroocean_miner.service",
        "c3pool_miner.service",
        "pnsd.service",
        "apache4.service",
        "pastebin.service",
        "xvf.service",
        "aliyun.service"
      ],
      "raw_values": [
        "moneroocean_miner.service",
        "c3pool_miner.service",
        "pnsd.service",
        "apache4.service",
        "pastebin.service",
        "xvf.service",
        "aliyun.service"
      ]
    },
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "in",
      "values": [
        "creation",
        "file_create_event"
      ],
      "raw_values": [
        "creation",
        "file_create_event"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "linux"
      ],
      "raw_values": [
        "linux"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "creation"
      ],
      "raw_values": [
        "creation"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": "like",
      "values": [
        "aliyun-service"
      ],
      "raw_values": [
        "/usr/local/share/aliyun-assist/*/aliyun-service"
      ]
    }
  ]
}
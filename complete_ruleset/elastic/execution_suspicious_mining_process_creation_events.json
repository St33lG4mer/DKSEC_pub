{
  "source": "elastic",
  "name": "Suspicious Mining Process Creation Event",
  "slug": "execution_suspicious_mining_process_creation_events",
  "category": "file",
  "language": "eql",
  "risk_score": 47,
  "tags": [
    "Domain: Endpoint",

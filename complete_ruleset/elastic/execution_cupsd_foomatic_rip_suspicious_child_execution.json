  "elastic_path": "rules/linux/execution_cupsd_foomatic_rip_suspicious_child_execution.toml",
  "raw_query": "process where host.os.type == \"linux\" and event.type == \"start\" and event.action in (\"exec\", \"exec_event\", \"start\", \"ProcessRollup2\") and\nprocess.parent.name in (\"foomatic-rip\", \"cupsd\") and process.command_line like (\n  // persistence\n  \"*cron*\", \"*/etc/rc.local*\", \"*/dev/tcp/*\", \"*/etc/init.d*\", \"*/etc/update-motd.d*\", \"*/etc/sudoers*\",\n  \"*/etc/profile*\", \"*autostart*\", \"*/etc/ssh*\", \"*/home/*/.ssh/*\", \"*/root/.ssh*\", \"*~/.ssh/*\", \"*udev*\",\n  \"*/etc/shadow*\", \"*/etc/passwd*\",\n\n  // Downloads\n  \"*curl*\", \"*wget*\",\n\n  // encoding and decoding\n  \"*base64 *\", \"*base32 *\", \"*xxd *\", \"*openssl*\",\n\n  // reverse connections\n  \"*GS_ARGS=*\", \"*/dev/tcp*\", \"*/dev/udp/*\", \"*import*pty*spawn*\", \"*import*subprocess*call*\", \"*TCPSocket.new*\",\n  \"*TCPSocket.open*\", \"*io.popen*\", \"*os.execute*\", \"*fsockopen*\", \"*disown*\", \"*nohup*\",\n\n  // SO loads\n  \"*openssl*-engine*.so*\", \"*cdll.LoadLibrary*.so*\", \"*ruby*-e**Fiddle.dlopen*.so*\", \"*Fiddle.dlopen*.so*\",\n  \"*cdll.LoadLibrary*.so*\",\n\n  // misc. suspicious command lines\n   \"*/etc/ld.so*\", \"*/dev/shm/*\", \"*/var/tmp*\", \"*echo*\", \"*>>*\", \"*|*\"\n) and not process.args like \"gs*\"\n",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.command_line",
      "operator": ":",
      "values": [
        "cron",
        "rc.local",
        "init.d",
        "update-motd.d",
        "sudoers",
        "profile",
        "autostart",
        "ssh",
        ".ssh",
        "udev",
        "shadow",
        "passwd",
        "curl",
        "wget",
        "base64",
        "base32",
        "xxd",
        "openssl",
        "gs_args=",
        "tcp",
        "import*pty*spawn",
        "import*subprocess*call",
        "tcpsocket.new",
        "tcpsocket.open",
        "io.popen",
        "os.execute",
        "fsockopen",
        "disown",
        "nohup",
        "openssl*-engine*.so",
        "cdll.loadlibrary*.so",
        "ruby*-e**fiddle.dlopen*.so",
        "fiddle.dlopen*.so",
        "ld.so",
        "tmp",
        "echo"
      ],
      "raw_values": [

{
  "source": "elastic",
  "name": "Signed Proxy Execution via MS Work Folders",
  "slug": "defense_evasion_workfolders_control_execution",
  "category": "process",
  "language": "eql",
  "risk_score": 47,
  "tags": [
    "Domain: Endpoint",
    "OS: Windows",
    "Use Case: Threat Detection",
    "Tactic: Defense Evasion",
    "Resources: Investigation Guide",
    "Data Source: Elastic Endgame",
    "Data Source: Windows Security Event Logs",
    "Data Source: Microsoft Defender for Endpoint",
    "Data Source: Sysmon",
    "Data Source: SentinelOne",
    "Data Source: Crowdstrike"
  ],
  "elastic_path": "rules/windows/defense_evasion_workfolders_control_execution.toml",
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n  process.name : \"control.exe\" and process.parent.name : \"WorkFolders.exe\" and\n  not process.executable : (\n    \"?:\\\\Windows\\\\System32\\\\control.exe\",\n    \"?:\\\\Windows\\\\SysWOW64\\\\control.exe\",\n\n    /* Crowdstrike specific condition as it uses NT Object paths */\n    \"\\\\Device\\\\HarddiskVolume*\\\\Windows\\\\System32\\\\control.exe\",\n    \"\\\\Device\\\\HarddiskVolume*\\\\Windows\\\\SysWOW64\\\\control.exe\"\n  )\n",
  "conditions": [
    {
      "field": "process.name",
      "raw_field": "process.executable",
      "operator": ":",
      "values": [
        "control.exe"
      ],
      "raw_values": [
        "?:\\\\Windows\\\\System32\\\\control.exe",
        "?:\\\\Windows\\\\SysWOW64\\\\control.exe",
        "\\\\Device\\\\HarddiskVolume*\\\\Windows\\\\System32\\\\control.exe",
        "\\\\Device\\\\HarddiskVolume*\\\\Windows\\\\SysWOW64\\\\control.exe",
        "control.exe"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "windows"
      ],
      "raw_values": [
        "windows"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": ":",
      "values": [
        "workfolders.exe"
      ],
      "raw_values": [
        "WorkFolders.exe"
      ]
    }
  ]
}
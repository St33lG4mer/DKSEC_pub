      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.parent.args",
      "raw_field": "process.parent.args",
      "operator": "==",
      "values": [
        "--message-loop-type-ui",
        "--service-sandbox-type=none"
      ],
      "raw_values": [

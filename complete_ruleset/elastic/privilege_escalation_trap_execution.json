  "elastic_path": "rules/cross-platform/privilege_escalation_trap_execution.toml",
  "raw_query": "process where event.type == \"start\" and event.action in (\"exec\", \"exec_event\", \"executed\", \"process_started\") and\nprocess.name == \"trap\" and process.args : \"SIG*\"\n",
  "conditions": [
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "in",
      "values": [
        "exec",
        "exec_event",
        "executed",
        "process_started"
      ],
      "raw_values": [
        "exec",
        "exec_event",
        "executed",
        "process_started"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "==",
      "values": [
        "trap"
      ],
      "raw_values": [
        "trap"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "sig"
      ],
      "raw_values": [
        "SIG*"
      ]
    }
  ]
}
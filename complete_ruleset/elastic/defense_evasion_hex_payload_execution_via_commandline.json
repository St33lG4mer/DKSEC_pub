      "values": [
        "snap",
        "printf",
        "sed"
      ],
      "raw_values": [
        "snap",
        "printf",
        "sed"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",

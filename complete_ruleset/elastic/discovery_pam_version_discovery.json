{
  "source": "elastic",
  "name": "Pluggable Authentication Module (PAM) Version Discovery",
  "slug": "discovery_pam_version_discovery",
  "category": "process",
  "language": "eql",
  "risk_score": 21,
  "tags": [
    "Domain: Endpoint",
    "OS: Linux",
    "Use Case: Threat Detection",
    "Tactic: Discovery",
    "Tactic: Persistence",
    "Tactic: Credential Access",
    "Data Source: Elastic Defend",
    "Data Source: Elastic Endgame",
    "Data Source: Crowdstrike",
    "Data Source: SentinelOne",
    "Resources: Investigation Guide"
  ],
  "elastic_path": "rules/linux/discovery_pam_version_discovery.toml",
  "raw_query": "process where host.os.type == \"linux\" and event.type == \"start\" and\n  event.action in (\"exec\", \"exec_event\", \"start\", \"ProcessRollup2\") and ?process.parent.name != null and\n  (\n    (process.name in (\"dpkg\", \"dpkg-query\") and process.args == \"libpam-modules\") or\n    (process.name == \"rpm\" and process.args == \"pam\")\n  ) and\nnot (\n  ?process.parent.name in (\"dcservice\", \"inspectorssmplugin\") or\n  ?process.working_directory in (\"/var/ossec\", \"/opt/msp-agent\") or\n  ?process.parent.executable in (\n    \"/opt/CyberCNSAgent/cybercnsagent_linux\", \"/usr/local/manageengine/uems_agent/bin/dcpatchscan\",\n    \"/usr/local/manageengine/uems_agent/bin/dcconfig\", \"/usr/share/vicarius/topiad\",\n    \"/etc/rc.d/init.d/sshd-chroot\"\n  )\n)\n",
  "conditions": [
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": "in",
      "values": [
        "exec",
        "exec_event",
        "start",
        "processrollup2"
      ],
      "raw_values": [
        "exec",
        "exec_event",
        "start",
        "ProcessRollup2"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "in",
      "values": [
        "dpkg",
        "dpkg-query"
      ],
      "raw_values": [
        "dpkg",
        "dpkg-query"
      ]
    },
    {
      "field": "process.parent.name",
      "raw_field": "process.parent.name",
      "operator": "in",
      "values": [
        "dcservice",
        "inspectorssmplugin",
        "cybercnsagent_linux",
        "dcpatchscan",
        "dcconfig",
        "topiad",
        "sshd-chroot"
      ],
      "raw_values": [
        "dcservice",
        "inspectorssmplugin",
        "/opt/CyberCNSAgent/cybercnsagent_linux",
        "/usr/local/manageengine/uems_agent/bin/dcpatchscan",
        "/usr/local/manageengine/uems_agent/bin/dcconfig",
        "/usr/share/vicarius/topiad",
        "/etc/rc.d/init.d/sshd-chroot"
      ]
    },
    {
      "field": "process.working_directory",
      "raw_field": "process.working_directory",
      "operator": "in",
      "values": [
        "/var/ossec",
        "/opt/msp-agent"
      ],
      "raw_values": [
        "/var/ossec",
        "/opt/msp-agent"
      ]
    },
    {
      "field": "host.os.type",
      "raw_field": "host.os.type",
      "operator": "==",
      "values": [
        "linux"
      ],
      "raw_values": [
        "linux"
      ]
    },
    {
      "field": "event.type",
      "raw_field": "event.type",
      "operator": "==",
      "values": [
        "start"
      ],
      "raw_values": [
        "start"
      ]
    },
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": "==",
      "values": [
        "libpam-modules",
        "pam"
      ],
      "raw_values": [
        "libpam-modules",
        "pam"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "==",
      "values": [
        "rpm"
      ],
      "raw_values": [
        "rpm"
      ]
    }
  ]
}
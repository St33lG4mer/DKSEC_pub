  "raw_query": "event.category:process and host.os.type:windows and\n  powershell.file.script_block_text : (\n    KerberosRequestorSecurityToken\n  ) and not user.id : (\"S-1-5-18\" or \"S-1-5-20\") and\n  not powershell.file.script_block_text : (\n    (\"sentinelbreakpoints\" and (\"Set-PSBreakpoint\" or \"Set-HookFunctionTabs\")) or\n    (\"function global\" and \"\\\\windows\\\\sentinel\\\\4\")\n  )\n",
  "conditions": [
    {
      "field": "user.id",
      "raw_field": "user.id",
      "operator": ":",
      "values": [
        "s-1-5-18",
        "s-1-5-20"
      ],
      "raw_values": [
        "S-1-5-18",
        "S-1-5-20"
      ]
    },
    {
      "field": "powershell.file.script_block_text",
      "raw_field": "powershell.file.script_block_text",
      "operator": ":",
      "values": [
        "sentinelbreakpoints",
        "set-psbreakpoint",
        "set-hookfunctiontabs"
      ],
      "raw_values": [
        "sentinelbreakpoints",
        "Set-PSBreakpoint",
        "Set-HookFunctionTabs"
      ]

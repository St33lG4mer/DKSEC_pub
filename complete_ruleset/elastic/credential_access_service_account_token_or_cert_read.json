{
  "source": "elastic",
  "name": "Service Account Token or Certificate Read Detected via Defend for Containers",
  "slug": "credential_access_service_account_token_or_cert_read",
  "category": "any",
  "language": "eql",
  "risk_score": 47,
  "tags": [
    "Data Source: Elastic Defend for Containers",
    "Domain: Container",
    "OS: Linux",
    "Use Case: Threat Detection",
    "Tactic: Credential Access",
    "Resources: Investigation Guide"
  ],
  "elastic_path": "rules/integrations/cloud_defend/credential_access_service_account_token_or_cert_read.toml",
  "raw_query": "any where host.os.type == \"linux\" and process.interactive == true and container.id like \"*\" and (\n  (event.category == \"file\" and event.type == \"change\" and event.action == \"open\" and\n  file.path in (\n    \"/var/run/secrets/kubernetes.io/serviceaccount/token\",\n    \"/var/run/secrets/kubernetes.io/serviceaccount/ca.crt\",\n    \"/run/secrets/kubernetes.io/serviceaccount/token\",\n    \"/run/secrets/kubernetes.io/serviceaccount/ca.crt\"\n  )) or\n  (event.category == \"process\" and event.type == \"start\" and event.action == \"exec\" and\n  (\n    process.name in (\"cat\", \"head\", \"tail\", \"more\", \"less\", \"sed\", \"awk\") or\n    process.args in (\n      \"cat\", \"/bin/cat\", \"/usr/bin/cat\", \"/usr/local/bin/cat\",\n      \"head\", \"/bin/head\", \"/usr/bin/head\", \"/usr/local/bin/head\",\n      \"tail\", \"/bin/tail\", \"/usr/bin/tail\", \"/usr/local/bin/tail\",\n      \"more\", \"/bin/more\", \"/usr/bin/more\", \"/usr/local/bin/more\",\n      \"less\", \"/bin/less\", \"/usr/bin/less\", \"/usr/local/bin/less\",\n      \"sed\", \"/bin/sed\", \"/usr/bin/sed\", \"/usr/local/bin/sed\",\n      \"awk\", \"/bin/awk\", \"/usr/bin/awk\", \"/usr/local/bin/awk\"\n    )\n  ) and process.args like (\n    \"*/run/secrets/kubernetes.io/serviceaccount/token*\",\n    \"*/run/secrets/kubernetes.io/serviceaccount/ca.crt*\"\n  ))\n)\n",
  "conditions": [
    {
      "field": "process.command_line",
      "raw_field": "process.args",
      "operator": ":",
      "values": [
        "token",
        "ca.crt"
      ],
      "raw_values": [
        "*/run/secrets/kubernetes.io/serviceaccount/token*",
        "*/run/secrets/kubernetes.io/serviceaccount/ca.crt*"
      ]
    },
    {
      "field": "file.path",
      "raw_field": "file.path",
      "operator": "in",
      "values": [
        "token",
        "ca.crt"
      ],
      "raw_values": [
        "/var/run/secrets/kubernetes.io/serviceaccount/token",
        "/var/run/secrets/kubernetes.io/serviceaccount/ca.crt",
        "/run/secrets/kubernetes.io/serviceaccount/token",
        "/run/secrets/kubernetes.io/serviceaccount/ca.crt"
      ]
    },
    {
      "field": "process.name",
      "raw_field": "process.name",
      "operator": "in",

{
  "source": "elastic",
  "name": "Azure Storage Account Deletion by Unusual User",
  "slug": "impact_azure_storage_account_deletion",
  "category": "any",
  "language": "kuery",
  "risk_score": 47,
  "tags": [
    "Domain: Cloud",
    "Domain: Storage",
    "Data Source: Azure",
    "Data Source: Azure Activity Logs",
    "Use Case: Threat Detection",
    "Tactic: Impact",
    "Resources: Investigation Guide"
  ],
  "elastic_path": "rules/integrations/azure/impact_azure_storage_account_deletion.toml",
  "raw_query": "data_stream.dataset: azure.activitylogs and\n    azure.activitylogs.operation_name: \"MICROSOFT.STORAGE/STORAGEACCOUNTS/DELETE\" and\n    azure.activitylogs.identity.claims_initiated_by_user.name: *\n",
  "conditions": [
    {
      "field": "azure.activitylogs.operation_name",
      "raw_field": "azure.activitylogs.operation_name",
      "operator": ":",
      "values": [
        "microsoft.storage/storageaccounts/delete"
      ],
      "raw_values": [
        "MICROSOFT.STORAGE/STORAGEACCOUNTS/DELETE"
      ]
    }
  ]
}
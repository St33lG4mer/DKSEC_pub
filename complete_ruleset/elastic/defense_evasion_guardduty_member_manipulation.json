  "raw_query": "data_stream.dataset: \"aws.cloudtrail\"\n    and event.provider: \"guardduty.amazonaws.com\"\n    and event.action: (\n        \"DisassociateFromAdministratorAccount\" or\n        \"DeleteMembers\" or\n        \"StopMonitoringMembers\" or\n        \"DeleteInvitations\" or\n        \"DisassociateMembers\"\n    )\n    and event.outcome: \"success\"\n",

        "SolarWinds.Collector.Service.exe",
        "SolarwindsDiagnostics.exe"
      ]
    },
    {
      "field": "http.request.body.content",
      "raw_field": "http.request.body.content",
      "operator": ":",
      "values": [
        "post",
        "put",
        "/swip/systemdescription",
        "/swip/events",
        "get",
        "head",
        "/swip/upload.ashx",
        "solarwinds.com"
      ],

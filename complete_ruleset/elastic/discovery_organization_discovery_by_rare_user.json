  "elastic_path": "rules/integrations/aws/discovery_organization_discovery_by_rare_user.toml",
  "raw_query": "data_stream.dataset: \"aws.cloudtrail\"\n    and event.outcome: \"success\"\n    and source.ip:*\n    and not aws.cloudtrail.session_credential_from_console: \"true\"\n    and not aws.cloudtrail.user_identity.type: \"AWSService\"\n    and (\n        (\n            event.provider: \"organizations.amazonaws.com\"\n            and event.action: (\n                \"DescribeOrganization\" or \"DescribeOrgnanizationalUnit\" or \"ListAccounts\" or \"ListRoots\"\n                or \"ListOrganizationalUnitsForParent\" or \"ListAccountsForParent\" or \"ListPolicies\"\n                or \"ListAWSServiceAccessForOrganization\" or \"ListDelegatedAdministrators\"\n                or \"ListDelegatedServicesForAccount\" or \"DescribeResourcePolicy\"\n            )\n        )\n        or (\n            event.provider: \"iam.amazonaws.com\"\n            and event.action: (\"ListAccountAliases\" or \"GetAccountSummary\")\n        )\n    )\n",
  "conditions": [
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": ":",
      "values": [
        "describeorganization",
        "describeorgnanizationalunit",
        "listaccounts",
        "listroots",
        "listorganizationalunitsforparent",
        "listaccountsforparent",
        "listpolicies",
        "listawsserviceaccessfororganization",
        "listdelegatedadministrators",
        "listdelegatedservicesforaccount",
        "describeresourcepolicy",
        "listaccountaliases",
        "getaccountsummary"
      ],
      "raw_values": [

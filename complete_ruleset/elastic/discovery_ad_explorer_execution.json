  "elastic_path": "rules/windows/discovery_ad_explorer_execution.toml",
  "raw_query": "process where host.os.type == \"windows\" and event.type == \"start\" and\n  (process.name : \"ADExplorer*.exe\" or ?process.pe.original_file_name == \"AdExp\")\n",

{
  "source": "elastic",
  "name": "PowerShell Suspicious Payload Encoded and Compressed",
  "slug": "defense_evasion_posh_compressed",
  "category": "any",
  "language": "kuery",
  "risk_score": 73,
  "tags": [
    "Domain: Endpoint",
    "OS: Windows",

  "elastic_path": "rules/integrations/aws/discovery_ec2_userdata_request_for_ec2_instance.toml",
  "raw_query": "data_stream.dataset: \"aws.cloudtrail\"\n    and event.provider: \"ec2.amazonaws.com\"\n    and event.action: \"DescribeInstanceAttribute\"\n    and event.outcome: \"success\"\n    and aws.cloudtrail.flattened.request_parameters.attribute: \"userData\"\n    and not aws.cloudtrail.user_identity.invoked_by: (\n        \"AWS Internal\" or\n        \"cloudformation.amazonaws.com\" or \n        \"aidevops.amazonaws.com\" or \n        \"elasticmapreduce.amazonaws.com\" or \n        \"aiops.amazonaws.com\"\n    )\n",
  "conditions": [
    {
      "field": "aws.cloudtrail.user_identity.invoked_by",
      "raw_field": "aws.cloudtrail.user_identity.invoked_by",
      "operator": ":",
      "values": [
        "aws internal",
        "cloudformation.amazonaws.com",
        "aidevops.amazonaws.com",
        "elasticmapreduce.amazonaws.com",
        "aiops.amazonaws.com"
      ],
      "raw_values": [
        "AWS Internal",
        "cloudformation.amazonaws.com",
        "aidevops.amazonaws.com",
        "elasticmapreduce.amazonaws.com",
        "aiops.amazonaws.com"
      ]
    },
    {
      "field": "data_stream.dataset",
      "raw_field": "data_stream.dataset",
      "operator": ":",
      "values": [
        "aws.cloudtrail"
      ],
      "raw_values": [
        "aws.cloudtrail"
      ]
    },
    {
      "field": "event.provider",
      "raw_field": "event.provider",
      "operator": ":",
      "values": [
        "ec2.amazonaws.com"
      ],
      "raw_values": [
        "ec2.amazonaws.com"
      ]
    },
    {
      "field": "event.action",
      "raw_field": "event.action",
      "operator": ":",
      "values": [
        "describeinstanceattribute"
      ],
      "raw_values": [
        "DescribeInstanceAttribute"
      ]
    },
    {
      "field": "event.outcome",
      "raw_field": "event.outcome",
      "operator": ":",
      "values": [
        "success"
      ],
      "raw_values": [
        "success"
      ]
    },
    {
      "field": "aws.cloudtrail.flattened.request_parameters.attribute",
      "raw_field": "aws.cloudtrail.flattened.request_parameters.attribute",

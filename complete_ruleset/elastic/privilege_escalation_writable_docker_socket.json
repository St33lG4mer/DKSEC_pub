{
  "source": "elastic",
  "name": "Potential Privilege Escalation through Writable Docker Socket",
  "slug": "privilege_escalation_writable_docker_socket",
  "category": "process",
  "language": "eql",
  "risk_score": 47,
  "tags": [
    "Domain: Endpoint",
    "OS: Linux",
    "Use Case: Threat Detection",
    "Tactic: Privilege Escalation",
    "Domain: Container",
